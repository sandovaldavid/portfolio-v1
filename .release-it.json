{
  "git": {
    "tagName": "v${version}",
    "tagAnnotation": "Release ${version}",
    "commitMessage": "chore(release): v${version}",
    "push": true,
    "pushArgs": "--follow-tags",
    "pullTags": false,
    "requireUpstream": true,
    "requireCleanWorkingDir": true,
    "requireBranch": ["main"],
    "getLatestTagFromAllBranches": false
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": true,
    "releaseName": "Release ${version}",
    "preRelease": false
  },
  "changelog": {
    "file": "CHANGELOG.md",
    "preset": "conventionalcommits",
    "header": "# Changelog\n\nAll notable changes to this project will be documented in this file.\n\nThe format is based on [Keep a Changelog](https://keepachangelog.com/),\nand this project adheres to [Semantic Versioning](https://semver.org/)."
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    }
  },
  "hooks": {
    "before:init": [],
    "after:release": "echo 'Release v${version} complete!'"
  }
}
