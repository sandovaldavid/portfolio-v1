{
	"name": "Portfolio Dev Container",

	// Build from local Dockerfile but pull cached layers from GHCR for instant startup
	"build": {
		"dockerfile": "Dockerfile",
		"context": "..",
		"cacheFrom": ["ghcr.io/sandovaldavid/portfolio-v1/devcontainer:develop"]
	},

	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash"
			},
			"extensions": [
				"astro-build.astro-vscode",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"bradlc.vscode-tailwindcss",
				"christian-kohler.path-intellisense"
			]
		}
	},
	"remoteUser": "pwuser",
	"containerUser": "pwuser",
	"updateRemoteUserUID": true,
	"mounts": [
		"source=${localWorkspaceFolderBasename}-devcontainer-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
	],
	"postCreateCommand": "sudo mkdir -p node_modules && sudo chown -R $(id -u):$(id -g) node_modules && bun install --frozen-lockfile",
	"forwardPorts": [4321]
}
