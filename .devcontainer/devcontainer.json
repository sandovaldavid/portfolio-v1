{
	"name": "Portfolio-v1",

	"build": {
		"dockerfile": "Dockerfile",
		"context": "..",
		"args": {
			"PLAYWRIGHT_VERSION": "1.61.1",
			"BUN_VERSION": "1.3.14"
		}
	},

	"remoteUser": "pwuser",
	"updateRemoteUserUID": true,

	"features": {
		"ghcr.io/devcontainers/features/common-utils:2.5.9": {
			"installZsh": true,
			"configureZshAsDefaultShell": true,
			"installOhMyZsh": false,
			"installOhMyZshConfig": false,
			"upgradePackages": false,
			"username": "pwuser"
		},
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1.10.0": {},
		"ghcr.io/devcontainers/features/github-cli:1.1.0": {}
	},

	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh",
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode",
				"files.eol": "\n",
				"eslint.validate": ["javascript", "typescript", "astro"],
				"[astro]": {
					"editor.defaultFormatter": "astro-build.astro-vscode"
				}
			},
			"extensions": [
				"astro-build.astro-vscode",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"bradlc.vscode-tailwindcss",
				"christian-kohler.path-intellisense",
				"ms-playwright.playwright",
				"redhat.vscode-yaml",
				"EditorConfig.EditorConfig",
				"DavidAnson.vscode-markdownlint"
			]
		}
	},

	"workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/portfolio-v1,type=bind",
	"workspaceFolder": "/workspaces/portfolio-v1",

	"mounts": [
		"source=${localWorkspaceFolderBasename}-devcontainer-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
		"source=devcontainer-${localWorkspaceFolderBasename}-zsh-history,target=/commandhistory,type=volume"
	],

	"appPort": ["127.0.0.1:4321:4321", "127.0.0.1:9323:9323"],
	"portsAttributes": {
		"4321": {
			"label": "Astro development server (published on host localhost)",
			"onAutoForward": "ignore"
		},
		"9323": {
			"label": "Playwright HTML report (published on host localhost)",
			"onAutoForward": "ignore"
		}
	},

	"containerEnv": {
		"DEVCONTAINER": "true",
		"HOST_WORKSPACE_FOLDER": "${localWorkspaceFolder}",
		"NODE_ENV": "development",
		"PLAYWRIGHT_BROWSERS_PATH": "/ms-playwright",
		"TERM": "xterm-256color",
		"ZSH_HISTORY_FILE": "/commandhistory/.zsh_history"
	},

	"init": true,
	"runArgs": ["--ipc=host", "--security-opt", "label=disable"],

	"postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
	"postStartCommand": "bash .devcontainer/scripts/post-start.sh",
	"postAttachCommand": "bash .devcontainer/scripts/post-start.sh",
	"waitFor": "postStartCommand",

	"hostRequirements": {
		"cpus": 2,
		"memory": "4gb",
		"storage": "16gb"
	},

	"shutdownAction": "stopContainer"
}
