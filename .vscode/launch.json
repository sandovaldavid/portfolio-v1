{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch Chrome",
			"request": "launch",
			"type": "chrome",
			"url": "http://localhost:4321",
			"webRoot": "${workspaceFolder}"
		},
		{
			"command": "bun run dev",
			"name": "Development server (Bun)",
			"request": "launch",
			"type": "node-terminal"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Unit Tests (Vitest)",
			"autoAttachChildProcesses": true,
			"program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
			"args": ["run"],
			"smartStep": true,
			"console": "integratedTerminal"
		}
	]
}
