{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Portfolio: Start Dev Server on Host",
			"type": "shell",
			"command": "bun run dev:host",
			"problemMatcher": [],
			"presentation": {
				"panel": "dedicated",
				"reveal": "always"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Portfolio: Open Host Browser",
			"type": "shell",
			"command": "code --open-url http://localhost:4321",
			"problemMatcher": []
		},
		{
			"label": "Portfolio: Run Quality Checks",
			"type": "shell",
			"command": "bun run check",
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "Portfolio: Build Project",
			"type": "shell",
			"command": "bun run build",
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Portfolio: Run Unit Tests",
			"type": "shell",
			"command": "bun run test:unit:ci",
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "Portfolio: Run Playwright Smoke Tests",
			"type": "shell",
			"command": "bun run test:e2e:smoke",
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "Portfolio: Serve Playwright Report on Host",
			"type": "shell",
			"command": "bun run test:e2e:report",
			"problemMatcher": [],
			"presentation": {
				"panel": "dedicated",
				"reveal": "always"
			}
		},
		{
			"label": "Portfolio: Open Playwright Report",
			"type": "shell",
			"command": "code --open-url http://localhost:9323",
			"problemMatcher": []
		},
		{
			"label": "Portfolio: Format Tracked Files",
			"type": "shell",
			"command": "bun run format",
			"problemMatcher": []
		},
		{
			"label": "Portfolio: Lint",
			"type": "shell",
			"command": "bun run lint",
			"problemMatcher": []
		},
		{
			"label": "Portfolio: Lint and Fix",
			"type": "shell",
			"command": "bun run lint:fix",
			"problemMatcher": []
		}
	]
}
