{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"paths": {
			"@assets/*": ["./src/assets/*"],
			"@entities/*": ["./src/entities/*"],
			"@features/*": ["./src/features/*"],
			"@shared/*": ["./src/shared/*"],
			"@widgets/*": ["./src/widgets/*"],
			"@app/*": ["./src/app/*"]
		}
	},
	"exclude": ["tests/", "playwright.config.ts", "vitest.config.ts"]
}
