FROM mcr.microsoft.com/playwright:v1.61.1-noble

ENV DEBIAN_FRONTEND=noninteractive

USER root
RUN apt-get update && apt-get install -y unzip && rm -rf /var/lib/apt/lists/*
RUN npm install -g bun@1.3.14

USER pwuser
WORKDIR /workspace
ENTRYPOINT ["bash", "-c", "bun install --frozen-lockfile && bun --version && bunx playwright --version && bun run build && mkdir -p playwright-report test-results && bunx playwright test \"$@\"", "--"]
