{
	"name": "porfolio-dev",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "prettier --write \"src/**/*.{astro,js,ts,jsx,tsx,css,md,json}\"",
		"format:check": "prettier --check \"src/**/*.{astro,js,ts,jsx,tsx,css,md,json}\"",
		"lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
		"lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
		"screenshots": "node docs/testing/capture-screenshots.mjs",
		"test": "bunx playwright test",
		"test:docker": "bash docker-test.sh",
		"test:local": "bunx playwright test --project=chromium --project=firefox --project='Mobile Chrome'",
		"test:snapshots": "bunx playwright test tests/e2e/visual.spec.ts --update-snapshots --project=chromium --project=firefox --project='Mobile Chrome'",
		"test:snapshots:all": "bunx playwright test tests/e2e/visual.spec.ts --update-snapshots",
		"test:ui": "bunx playwright test --ui",
		"test:debug": "bunx playwright test --debug",
		"test:unit": "vitest",
		"test:unit:ui": "vitest --ui",
		"test:unit:coverage": "vitest --coverage",
		"test:all": "bun run test:unit && bun run test",
		"lighthouse": "lhci autorun",
		"lighthouse:collect": "lhci collect",
		"lighthouse:assert": "lhci assert",
		"bundle:analyze": "node scripts/analyze-bundle.js"
	},
	"dependencies": {
		"@astrojs/check": "0.9.6",
		"@fontsource-variable/onest": "^5.2.11",
		"@fontsource/geist-mono": "^5.2.8",
		"@fontsource/geist-sans": "^5.2.5",
		"@tailwindcss/vite": "^4.3.1",
		"@vercel/analytics": "^1.6.1",
		"astro": "^6.4.8",
		"astro-i18n": "^2.2.4",
		"astro-robots-txt": "1.0.0",
		"prettier": "^3.8.4",
		"prettier-plugin-astro": "^0.14.1",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@eslint/js": "^10.0.1",
		"@lhci/cli": "^0.14.0",
		"@playwright/test": "^1.61.1",
		"@typescript-eslint/eslint-plugin": "^8.61.1",
		"@typescript-eslint/parser": "^8.61.1",
		"eslint": "^10.5.0",
		"husky": "^9.1.7",
		"lightningcss": "1.30.2",
		"playwright": "^1.61.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"vite": "^7.3.5",
		"vitest": "^4.1.9"
	}
}
