{
	"name": "portfolio-v1",
	"private": true,
	"type": "module",
	"version": "1.6.2",
	"packageManager": "bun@1.3.14",
	"scripts": {
		"dev": "astro dev",
		"build": "astro check --minimumFailingSeverity hint && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "node scripts/format-tracked-files.mjs --write",
		"format:check": "node scripts/format-tracked-files.mjs --check",
		"lint:eslint": "eslint .",
		"lint:architecture": "node scripts/check-architecture.mjs",
		"lint": "bun run lint:eslint && bun run lint:architecture",
		"lint:fix": "eslint . --fix && bun run lint:architecture",
		"typecheck:astro": "astro check --minimumFailingSeverity hint",
		"typecheck:tooling": "tsc --noEmit --project tsconfig.tooling.json",
		"typecheck": "bun run typecheck:astro && bun run typecheck:tooling",
		"check:docs": "node scripts/check-doc-links.mjs",
		"check:devcontainer": "node scripts/check-devcontainer.mjs",
		"check": "bun run format:check && bun run check:docs && bun run check:devcontainer && bun run lint && bun run typecheck",
		"check:links": "node scripts/check-built-links.mjs",
		"screenshots": "node docs/testing/capture-screenshots.mjs",
		"test": "node scripts/run-playwright.mjs",
		"test:docker": "bash docker-test.sh",
		"test:local": "node scripts/run-playwright.mjs --project=chromium --project=firefox --project='Mobile Chrome'",
		"test:e2e:smoke": "node scripts/run-playwright.mjs tests/e2e/smoke.spec.ts tests/e2e/performance.spec.ts --project=chromium",
		"test:e2e:desktop": "node scripts/run-playwright.mjs --project=chromium --project=firefox --project=webkit",
		"test:e2e:extended": "node scripts/run-playwright.mjs --project=chromium --project=firefox --project=webkit --project='Mobile Chrome' --project='Mobile Safari'",
		"test:e2e:visual": "node scripts/run-playwright.mjs tests/e2e/visual.spec.ts --project=chromium --project=firefox --project='Mobile Chrome'",
		"test:e2e:visual:docker": "CI=true RUN_VISUAL_TESTS=true bash docker-test.sh tests/e2e/visual.spec.ts --project=chromium --project=firefox --project='Mobile Chrome'",
		"test:snapshots": "node scripts/run-playwright.mjs tests/e2e/visual.spec.ts --update-snapshots --project=chromium --project=firefox --project='Mobile Chrome'",
		"test:snapshots:all": "node scripts/run-playwright.mjs tests/e2e/visual.spec.ts --update-snapshots",
		"test:ui": "node scripts/run-playwright.mjs --ui",
		"test:debug": "node scripts/run-playwright.mjs --debug",
		"test:unit": "vitest",
		"test:unit:ci": "vitest run",
		"test:unit:ui": "vitest --ui",
		"test:unit:coverage": "echo 'Unit coverage scope: shared i18n and content-ID utilities only; not whole-repository coverage.' && vitest run --coverage",
		"test:all": "bun run test:unit:ci && bun run test",
		"lighthouse": "lhci autorun",
		"lighthouse:collect": "lhci collect",
		"lighthouse:assert": "lhci assert",
		"bundle:analyze": "node scripts/analyze-bundle.js",
		"performance:check": "node scripts/check-route-performance.mjs",
		"bundle:visualize": "ANALYZE_BUNDLE=true bun run build && bun run bundle:analyze"
	},
	"dependencies": {
		"@astrojs/mdx": "7.0.3",
		"@astrojs/rss": "^4.0.19",
		"@astrojs/sitemap": "^3.7.3",
		"@tailwindcss/vite": "^4.3.3",
		"@vercel/analytics": "^1.6.1",
		"astro": "^7.1.3",
		"astro-robots-txt": "1.0.0",
		"tailwindcss": "^4.3.3"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@axe-core/playwright": "^4.12.1",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@eslint/js": "^10.0.1",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "1.61.1",
		"@tailwindcss/typography": "^0.5.20",
		"@types/node": "^22.20.1",
		"@typescript-eslint/eslint-plugin": "^8.65.0",
		"@typescript-eslint/parser": "^8.65.0",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^10.7.0",
		"eslint-plugin-astro": "~3.0.1",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lightningcss": "1.32.0",
		"prettier": "^3.9.5",
		"prettier-plugin-astro": "^0.14.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"typescript": "^5.9.3",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	}
}
