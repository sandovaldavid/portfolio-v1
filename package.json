{
	"name": "portfolio-v1",
	"private": true,
	"type": "module",
	"version": "1.6.2-beta.0",
	"packageManager": "bun@1.3.14",
	"scripts": {
		"dev": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck:astro": "astro check",
		"typecheck:tooling": "tsc --noEmit --project tsconfig.tooling.json",
		"typecheck": "bun run typecheck:astro && bun run typecheck:tooling",
		"check": "bun run format:check && bun run lint && bun run typecheck",
		"screenshots": "node docs/testing/capture-screenshots.mjs",
		"test": "bunx playwright test",
		"test:docker": "bash docker-test.sh",
		"test:local": "bunx playwright test --project=chromium --project=firefox --project='Mobile Chrome'",
		"test:snapshots": "bunx playwright test tests/e2e/visual.spec.ts --update-snapshots --project=chromium --project=firefox --project='Mobile Chrome'",
		"test:snapshots:all": "bunx playwright test tests/e2e/visual.spec.ts --update-snapshots",
		"test:ui": "bunx playwright test --ui",
		"test:debug": "bunx playwright test --debug",
		"test:unit": "vitest",
		"test:unit:ui": "vitest --ui",
		"test:unit:coverage": "vitest --coverage",
		"test:all": "bun run test:unit && bun run test",
		"lighthouse": "lhci autorun",
		"lighthouse:collect": "lhci collect",
		"lighthouse:assert": "lhci assert",
		"bundle:analyze": "node scripts/analyze-bundle.js"
	},
	"dependencies": {
		"@astrojs/mdx": "7.0.3",
		"@astrojs/rss": "^4.0.19",
		"@astrojs/sitemap": "^3.7.3",
		"@tailwindcss/vite": "^4.3.2",
		"@vercel/analytics": "^2.0.1",
		"astro": "^7.1.1",
		"astro-robots-txt": "1.0.0",
		"tailwindcss": "^4.3.2"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.6",
		"@axe-core/playwright": "^4.12.1",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@eslint/js": "^10.0.1",
		"@lhci/cli": "^0.14.0",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/typography": "^0.5.20",
		"@types/node": "^26.1.1",
		"@typescript-eslint/eslint-plugin": "^8.64.0",
		"@typescript-eslint/parser": "^8.64.0",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^10.7.0",
		"eslint-plugin-astro": "~3.0.0",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lightningcss": "1.30.2",
		"prettier": "^3.9.5",
		"prettier-plugin-astro": "^0.14.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"typescript": "^7.0.2",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	}
}
