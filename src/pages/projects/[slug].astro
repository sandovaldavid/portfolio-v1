---
import { getRelativeLocaleUrl } from 'astro:i18n';
import Layout from '@app/layouts/Layout.astro';
import { getProjectBySlug, getProjectsData } from '@entities/project';
import {
	createScopedUiTranslator,
	getLanguageFromLocale,
	Language,
} from '@shared/config/i18n';
import { ProjectCaseStudy } from '@widgets/project-case-study';

export async function getStaticPaths() {
	const projects = await getProjectsData(Language.ENGLISH);
	return projects.map(project => ({
		params: { slug: project.slug },
		props: { slug: project.slug },
	}));
}

const lang = getLanguageFromLocale(Astro.currentLocale);
const slug = Astro.params.slug ?? '';
const tProjects = createScopedUiTranslator(lang, 'sections.projects');
const project = await getProjectBySlug(lang, slug);

if (!project) {
	return Astro.redirect('/404');
}

const pageTitle = `${project.title} — ${tProjects('caseStudy')} | David Sandoval`;
---

<Layout
	title={pageTitle}
	description={project.description}
	img_preview={project.image.src}
	isHome={false}
>
	<div class="py-16 md:py-24">
		<ProjectCaseStudy
			project={project}
			backLink={getRelativeLocaleUrl(lang, 'projects')}
			backText={tProjects('back')}
			codeButtonText={tProjects('codeButton')}
			previewButtonText={tProjects('previewButton')}
			caseStudyLabel={tProjects('caseStudyBanner')}
			labelProblem={tProjects('problem')}
			labelApproach={tProjects('approach')}
			labelTradeoffs={tProjects('tradeoffs')}
			labelOutcome={tProjects('outcome')}
			labelLearnings={tProjects('learnings')}
			labelTimeline={tProjects('timeline')}
			labelRole={tProjects('role')}
		/>
	</div>
</Layout>
