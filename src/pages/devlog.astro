---
import { getRelativeLocaleUrl } from 'astro:i18n';
import Layout from '@app/layouts/Layout.astro';
import { getDevlogPosts, getDevlogSlug } from '@entities/devlog';
import { createScopedUiTranslator, getLanguageFromLocale } from '@shared/config/i18n';
import { DevlogCard } from '@widgets/devlog';

const lang = getLanguageFromLocale(Astro.currentLocale);
const tDevlog = createScopedUiTranslator(lang, 'pages.devlog');
const posts = await getDevlogPosts(lang);
---

<Layout
	title={tDevlog('pageTitle')}
	description={tDevlog('pageDescription')}
	img_preview="/projects/portfolio.webp"
	isHome={false}
>
	<div class="py-16 md:py-24">
		<div class="mx-auto max-w-4xl">
			<header class="mb-12">
				<p
					class="mb-2 font-retro-tag text-sm font-bold uppercase tracking-widest text-primary-500 dark:text-primary-400"
				>
					{tDevlog('label')}
				</p>
				<h1 class="mb-4 text-3xl font-bold font-pixel-clean tracking-wide md:text-5xl">
					{tDevlog('heading')}
				</h1>
				<p class="max-w-2xl text-base leading-relaxed text-content-muted">
					{tDevlog('subheading')}
				</p>
			</header>

			<div class="space-y-6">
				{
					posts.map(post => (
						<DevlogCard
							post={post}
							readMoreText={tDevlog('readMore')}
							readMoreLink={getRelativeLocaleUrl(
								lang,
								`devlog/${getDevlogSlug(post)}`
							)}
						/>
					))
				}
			</div>
		</div>
	</div>
</Layout>
