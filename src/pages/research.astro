---
import Layout from '@app/layouts/Layout.astro';
import { createScopedUiTranslator, Language } from '@shared/config/i18n';
import { ResearchContent } from '@widgets/research-content';

const lang = Language.ENGLISH;
const tPage = createScopedUiTranslator(lang, 'pages.research');
---

<Layout
	title={tPage('pageTitle')}
	description={tPage('pageDescription')}
	img_preview="/projects/portfolio.webp"
	pageType="research"
>
	<ResearchContent {lang} backHref="/#research" />
</Layout>
