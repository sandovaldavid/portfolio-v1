---
import Layout from '@app/layouts/Layout.astro';
import { getLangFromUrl, useTranslations, useTranslationsList } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';
import { siteConfig } from '@shared/config/site.config';
import BrainIcon from '@assets/icons/Brain.astro';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);
const tList = useTranslationsList(lang);

const keywords = tList('research.thesis.keywords') as string[];
const isEN = lang === Language.ENGLISH;

const metrics = [
	{ prefix: 'ACC', text: t('research.thesis.metrics.accuracy') },
	{ prefix: 'F1',  text: t('research.thesis.metrics.f1') },
	{ prefix: 'AUC', text: t('research.thesis.metrics.auc') },
	{ prefix: 'LOSS', text: t('research.thesis.metrics.loss') },
];

const labels = {
	problem:    isEN ? 'PROBLEM STATEMENT'     : 'PLANTEAMIENTO DEL PROBLEMA',
	hypothesis: isEN ? 'RESEARCH HYPOTHESIS'   : 'HIPÓTESIS DE INVESTIGACIÓN',
	approach:   isEN ? 'METHODOLOGY (MSR)'     : 'METODOLOGÍA (MSR)',
	dataset:    isEN ? 'DATASET'               : 'CONJUNTO DE DATOS',
	metrics:    isEN ? 'EVALUATION METRICS'    : 'MÉTRICAS DE EVALUACIÓN',
	arch:       isEN ? 'MODEL ARCHITECTURE'    : 'ARQUITECTURA DEL MODELO',
	pipeline:   isEN ? 'DATA PIPELINE'         : 'PIPELINE DE DATOS',
	keywords:   isEN ? 'KEYWORDS'              : 'PALABRAS CLAVE',
	status:     isEN ? 'CURRENT STATUS'        : 'ESTADO ACTUAL',
	contact:    isEN ? 'INTERESTED? REACH OUT' : '¿INTERESADO? CONTÁCTAME',
};

const pageTitle = isEN
	? 'Research — BiLSTM OSS Abandonment | David Sandoval'
	: 'Investigación — BiLSTM Abandono OSS | David Sandoval';
const pageDesc = isEN
	? 'Thesis research: predicting OSS repository abandonment using BiLSTM neural networks. Mining Software Repositories, deep learning, GitHub data.'
	: 'Investigación de tesis: predicción del abandono de repositorios OSS usando redes neuronales BiLSTM. Minería de repositorios, deep learning.';

const pipelineSteps = isEN
	? ['GitHub API / GH Archive', 'Raw Repo Activity Data', 'Feature Engineering', 'Temporal Sequences', 'BiLSTM Training', 'Abandonment Classifier']
	: ['GitHub API / GH Archive', 'Datos Crudos de Actividad', 'Ingeniería de Características', 'Secuencias Temporales', 'Entrenamiento BiLSTM', 'Clasificador de Abandono'];

const archDetails = isEN ? [
	{ label: 'Input', value: 'Time-series of repo activity signals (T steps)' },
	{ label: 'Layer 1', value: 'BiLSTM — 128 units forward + backward' },
	{ label: 'Layer 2', value: 'BiLSTM — 64 units with dropout (0.3)' },
	{ label: 'Layer 3', value: 'Dense — 32 units, ReLU activation' },
	{ label: 'Output', value: 'Sigmoid — P(abandoned) ∈ [0,1]' },
	{ label: 'Loss', value: 'Binary Cross-Entropy + class weights' },
	{ label: 'Optimizer', value: 'Adam (lr=1e-3)' },
] : [
	{ label: 'Entrada', value: 'Serie temporal de señales de actividad del repo (T pasos)' },
	{ label: 'Capa 1', value: 'BiLSTM — 128 unidades forward + backward' },
	{ label: 'Capa 2', value: 'BiLSTM — 64 unidades con dropout (0.3)' },
	{ label: 'Capa 3', value: 'Dense — 32 unidades, activación ReLU' },
	{ label: 'Salida', value: 'Sigmoid — P(abandonado) ∈ [0,1]' },
	{ label: 'Pérdida', value: 'Binary Cross-Entropy + pesos de clase' },
	{ label: 'Optimizador', value: 'Adam (lr=1e-3)' },
];

const features = isEN ? [
	'Commit frequency (weekly rolling avg)',
	'Unique contributors per time window',
	'Open issue aging (days unresolved)',
	'PR merge rate & close rate',
	'Days since last commit',
	'Bus factor estimate',
	'Issue response time',
	'Release cadence',
] : [
	'Frecuencia de commits (promedio semanal)',
	'Contribuidores únicos por ventana temporal',
	'Antigüedad de issues abiertos (días sin resolver)',
	'Tasa de merge/cierre de PRs',
	'Días desde el último commit',
	'Estimación del bus factor',
	'Tiempo de respuesta a issues',
	'Cadencia de releases',
];
---

<Layout
	title={pageTitle}
	description={pageDesc}
	img_preview="/projects/portfolio.webp"
	isHome={false}
>
	<div class="w-full max-w-5xl mx-auto px-4 font-mono">

		<!-- Back button -->
		<a
			href={isEN ? '/en/#research' : '/#research'}
			class="inline-flex items-center gap-2 mb-8 text-xs font-bold uppercase tracking-wider text-text-muted hover:text-primary-500 transition-colors group"
		>
			<span class="group-hover:-translate-x-1 transition-transform">◀</span>
			{isEN ? 'Back to Portfolio' : 'Volver al Portfolio'}
		</a>

		<!-- Header -->
		<div class="border-2 border-black dark:border-white bg-primary-500 px-6 py-5 mb-8 shadow-[6px_6px_0px_0px_var(--color-border-strong)]">
			<div class="flex items-start gap-4">
				<BrainIcon class="w-8 h-8 text-white dark:text-black shrink-0 mt-1" />
				<div class="flex-1">
					<p class="font-gaming-mono text-xs sm:text-sm uppercase tracking-wider text-white/90 dark:text-black/80 mb-1 font-bold">
						{t('research.thesis.institution')} · {t('research.thesis.label')}
					</p>
					<h1 class="font-pixel-clean text-xl sm:text-3xl font-bold text-white dark:text-black uppercase leading-snug">
						{t('research.thesis.title')}
					</h1>
				</div>
				<span class="shrink-0 font-gaming-mono text-xs bg-white dark:bg-black text-primary-600 dark:text-primary-400 px-2.5 py-1 font-bold uppercase tracking-wider animate-pulse whitespace-nowrap self-start">
					{t('research.thesis.status')}
				</span>
			</div>
		</div>

		<!-- Main grid -->
		<div class="grid grid-cols-1 lg:grid-cols-5 gap-6 items-start">

			<!-- Left column (3/5) -->
			<div class="lg:col-span-3 flex flex-col gap-6">

				<!-- Problem -->
				<div class="border-2 border-border-subtle bg-surface p-5">
					<h2 class="font-gaming-mono text-sm sm:text-base font-bold text-primary-500 uppercase tracking-wider mb-3">▸ {labels.problem}</h2>
					<p class="text-sm leading-relaxed text-text-main">
						{t('research.thesis.problem')}
					</p>
				</div>

				<!-- Hypothesis -->
				<div class="border-2 border-primary-500/40 bg-primary-500/5 p-5">
					<h2 class="font-gaming-mono text-sm sm:text-base font-bold text-primary-500 uppercase tracking-wider mb-3">▸ {labels.hypothesis}</h2>
					<p class="text-sm leading-relaxed italic text-text-main">
						"{t('research.thesis.hypothesis')}"
					</p>
				</div>

				<!-- Methodology -->
				<div class="border-2 border-border-subtle bg-surface p-5">
					<h2 class="font-gaming-mono text-sm sm:text-base font-bold text-primary-500 uppercase tracking-wider mb-3">▸ {labels.approach}</h2>
					<p class="text-sm leading-relaxed text-text-main mb-4">
						{t('research.thesis.approach')}
					</p>

					<!-- Pipeline flow -->
					<div class="mt-4">
						<p class="font-gaming-mono text-xs sm:text-sm text-text-muted uppercase tracking-wider mb-2 font-bold">{labels.pipeline}</p>
						<div class="flex flex-wrap items-center gap-1">
							{pipelineSteps.map((step, i) => (
								<>
									<span class="font-gaming-mono text-xs sm:text-sm uppercase border border-primary-500/50 text-primary-500 px-2.5 py-1.5 bg-primary-500/5 font-bold">
										{step}
									</span>
									{i < pipelineSteps.length - 1 && (
										<span class="text-primary-500 font-bold text-xs">→</span>
									)}
								</>
							))}
						</div>
					</div>
				</div>

				<!-- Feature engineering -->
				<div class="border-2 border-border-subtle bg-surface p-5">
					<h2 class="font-gaming-mono text-sm sm:text-base font-bold text-primary-500 uppercase tracking-wider mb-3">
						▸ {isEN ? 'ENGINEERED FEATURES' : 'CARACTERÍSTICAS INGENIERIZADAS'}
					</h2>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
						{features.map((feat, i) => (
							<div class="flex items-start gap-2 text-sm text-text-main">
								<span class="font-pixel-clean text-[8px] font-bold bg-primary-500/20 text-primary-500 px-1.5 py-0.5 shrink-0 mt-0.5 min-w-[28px] text-center">
									F{String(i + 1).padStart(2, '0')}
								</span>
								<span class="leading-snug">{feat}</span>
							</div>
						))}
					</div>
				</div>

				<!-- Dataset -->
				<div class="border-2 border-border-subtle bg-surface p-5">
					<h2 class="font-gaming-mono text-sm sm:text-base font-bold text-primary-500 uppercase tracking-wider mb-3">▸ {labels.dataset}</h2>
					<p class="text-sm leading-relaxed text-text-main">
						{t('research.thesis.dataset')}
					</p>
				</div>

			</div>

			<!-- Right column (2/5) -->
			<div class="lg:col-span-2 flex flex-col gap-6">

				<!-- Model Architecture -->
				<div class="border-2 border-border-subtle bg-surface p-5">
					<h2 class="font-gaming-mono text-sm sm:text-base font-bold text-primary-500 uppercase tracking-wider mb-3">▸ {labels.arch}</h2>
					<div class="flex flex-col gap-2">
						{archDetails.map(({ label, value }) => (
							<div class="border border-border-subtle p-2.5 text-sm flex justify-between items-start gap-4">
								<span class="font-bold text-primary-500 uppercase tracking-wider shrink-0 text-xs sm:text-sm font-gaming-mono">{label}</span>
								<span class="text-text-main leading-snug text-right">{value}</span>
							</div>
						))}
					</div>
				</div>

				<!-- Metrics -->
				<div class="border-2 border-border-subtle bg-surface p-5">
					<h2 class="font-gaming-mono text-sm sm:text-base font-bold text-primary-500 uppercase tracking-wider mb-3">▸ {labels.metrics}</h2>
					<div class="flex flex-col gap-2">
						{metrics.map(({ prefix, text }) => (
							<div class="flex items-start gap-2">
								<span class="shrink-0 font-pixel-clean text-sm font-bold bg-primary-500 text-white dark:text-black px-2 py-1 mt-0.5 uppercase min-w-[36px] text-center">
									{prefix}
								</span>
								<span class="text-sm text-text-main leading-snug">{text}</span>
							</div>
						))}
					</div>
				</div>

				<!-- Status -->
				<div class="border-2 border-emerald-500/40 bg-emerald-500/5 p-5">
					<h2 class="font-gaming-mono text-sm sm:text-base font-bold text-emerald-500 uppercase tracking-wider mb-3">▸ {labels.status}</h2>
					<div class="flex items-center gap-2 mb-2">
						<span class="w-2.5 h-2.5 bg-emerald-500 animate-pulse rounded-none shrink-0"></span>
						<span class="font-gaming-mono text-xs sm:text-sm font-bold text-emerald-500 uppercase">{t('research.thesis.status')}</span>
					</div>
					<p class="text-sm text-text-muted leading-relaxed">
						{isEN
							? 'Actively training BiLSTM models and comparing against ML baselines. Results will be published upon thesis completion.'
							: 'Entrenamiento activo de modelos BiLSTM y comparación con baselines de ML. Los resultados se publicarán al completar la tesis.'}
					</p>
				</div>

				<!-- Keywords -->
				<div class="border-2 border-border-subtle bg-surface p-5">
					<h2 class="font-gaming-mono text-sm sm:text-base font-bold text-text-muted uppercase tracking-wider mb-3">{labels.keywords}</h2>
					<div class="flex flex-wrap gap-1.5">
						{keywords.map(kw => (
							<span class="font-gaming-mono text-xs sm:text-sm uppercase border border-primary-500/40 text-primary-500 px-2 py-0.5 hover:bg-primary-500/10 transition-colors cursor-default font-bold">
								{kw}
							</span>
						))}
					</div>
				</div>

			</div>
		</div>

		<!-- Contact CTA — horizontal bar inspired by header -->
		<div class="mt-12 border-2 border-black dark:border-white bg-primary-500 px-6 py-4 shadow-[6px_6px_0px_0px_var(--color-border-strong)]">
			<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
				<!-- Left: icon + label + description -->
				<div class="flex items-center gap-3 flex-1 min-w-0">
					<span class="shrink-0 font-gaming-mono text-lg text-white dark:text-black" aria-hidden="true">✉</span>
					<div class="flex flex-col gap-0.5 min-w-0">
						<h2 class="font-gaming-mono text-xs sm:text-sm font-bold text-white/90 dark:text-black/80 uppercase tracking-wider">
							{labels.contact}
						</h2>
						<p class="text-xs text-white/80 dark:text-black/70 leading-snug">
							{isEN
								? 'Collaborations, questions or opportunities.'
								: 'Colaboraciones, preguntas u oportunidades.'}
						</p>
					</div>
				</div>
				<!-- Right: CTA button -->
				<a
					href={`mailto:${siteConfig.email}?subject=${encodeURIComponent(isEN ? 'Research Collaboration' : 'Colaboración en Investigación')}`}
					class="shrink-0 flex items-center justify-center gap-1.5 px-5 py-2 bg-white dark:bg-black text-primary-500 dark:text-primary-400 font-gaming-mono text-xs sm:text-sm font-bold uppercase tracking-wider hover:bg-white/90 dark:hover:bg-black/90 hover:-translate-x-px hover:-translate-y-px transition-all whitespace-nowrap self-start sm:self-center"
				>
					<span aria-hidden="true">→</span>
					{isEN ? 'Contact' : 'Contactar'}
				</a>
			</div>
		</div>

	</div>
</Layout>
