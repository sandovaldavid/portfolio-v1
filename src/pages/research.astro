---
import Layout from '@app/layouts/Layout.astro';
import { ResearchContent } from '@widgets/research-content';
import { useTranslations } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

const lang = Language.ENGLISH;
const t = useTranslations(lang);
---

<Layout
	title={t('research.page-title')}
	description={t('research.page-description')}
	img_preview="/projects/portfolio.webp"
	isHome={false}
	article={true}
>
	<ResearchContent {lang} backHref="/#research" />
</Layout>
