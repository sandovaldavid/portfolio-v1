---
import Layout from '@app/layouts/Layout.astro';
import { TAGS } from '@entities/technology';
import { SectionContainer } from '@shared/ui';
import { getLocalizedPath } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

const lang = Language.ENGLISH;

const frontendTechs = [
	TAGS.TYPESCRIPT,
	TAGS.ANGULAR,
	TAGS.RXJS,
	TAGS.NEXTJS,
	TAGS.REACT,
	TAGS.ASTRO,
	TAGS.TAILWIND,
	TAGS.JAVASCRIPT,
	TAGS.CSS,
	TAGS.HTML,
	TAGS.BOOTSTRAP,
].filter(Boolean);

const backendTechs = [
	TAGS.CSHARP,
	TAGS.JAVA,
	TAGS.PYTHON,
	TAGS.DJANGO,
	TAGS.EXPRESS,
	TAGS.POSTGRESQL,
	TAGS.MYSQL,
	TAGS.SQLITE,
].filter(Boolean);

const toolsTechs = [TAGS.CLOUDINARY, TAGS.SANITY, TAGS.CHARTJS, TAGS.MARKDOWN].filter(Boolean);
---

<Layout
	title="Skills and Technologies - David Sandoval"
	description="Explore the complete inventory of programming languages, frameworks, libraries, and tools used by David Sandoval."
	img_preview="/projects/portfolio.webp"
	isHome={false}
>
	<SectionContainer id="all-skills" class="w-full max-w-5xl px-4 flex flex-col gap-8">
		<div class="text-center space-y-3 mb-4">
			<h2
				class="text-4xl md:text-5xl font-bold font-pixel-clean text-content-strong uppercase tracking-wide"
			>
				Skills Inventory
			</h2>
			<p class="text-content-muted font-mono text-base uppercase">
				[ Skills Database Loaded: 100% Complete // Class: Systems Engineer ]
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full mt-2">
			<!-- Frontend Spells Card -->
			<article
				class="rounded-none bg-surface border-2 border-black dark:border-white p-6 shadow-[3px_3px_0px_var(--color-primary-500)] hover:-translate-y-1 hover:shadow-[5px_5px_0px_var(--color-primary-500)] transition-all duration-150 flex flex-col gap-4"
			>
				<h3
					class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 border-b-2 border-dashed border-edge-subtle pb-2"
				>
					[ FRONTEND SPELLS ]
				</h3>
				<div class="grid grid-cols-2 gap-2">
					{
						frontendTechs.map(tech => {
							const Icon = tech.icon;
							return (
								<div class="flex items-center gap-2 p-2 border border-edge-subtle bg-surface/50 hover:bg-primary-500/5 hover:border-primary-500/30 transition-all duration-150 group cursor-default">
									{Icon && (
										<Icon class="w-4 h-4 text-primary-500 dark:text-primary-400 shrink-0" />
									)}
									<span class="font-gaming-mono text-xs uppercase tracking-wider text-content-strong font-bold">
										{tech.name}
									</span>
								</div>
							);
						})
					}
				</div>
			</article>

			<!-- Backend Runes Card -->
			<article
				class="rounded-none bg-surface border-2 border-black dark:border-white p-6 shadow-[3px_3px_0px_var(--color-primary-500)] hover:-translate-y-1 hover:shadow-[5px_5px_0px_var(--color-primary-500)] transition-all duration-150 flex flex-col gap-4"
			>
				<h3
					class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 border-b-2 border-dashed border-edge-subtle pb-2"
				>
					[ BACKEND RUNES ]
				</h3>
				<div class="grid grid-cols-2 gap-2">
					{
						backendTechs.map(tech => {
							const Icon = tech.icon;
							return (
								<div class="flex items-center gap-2 p-2 border border-edge-subtle bg-surface/50 hover:bg-primary-500/5 hover:border-primary-500/30 transition-all duration-150 group cursor-default">
									{Icon && (
										<Icon class="w-4 h-4 text-primary-500 dark:text-primary-400 shrink-0" />
									)}
									<span class="font-gaming-mono text-xs uppercase tracking-wider text-content-strong font-bold">
										{tech.name}
									</span>
								</div>
							);
						})
					}
				</div>
			</article>

			<!-- Tools & Utility Card -->
			<article
				class="rounded-none bg-surface border-2 border-black dark:border-white p-6 shadow-[3px_3px_0px_var(--color-primary-500)] hover:-translate-y-1 hover:shadow-[5px_5px_0px_var(--color-primary-500)] transition-all duration-150 flex flex-col gap-4 md:col-span-2 lg:col-span-1"
			>
				<h3
					class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 border-b-2 border-dashed border-edge-subtle pb-2"
				>
					[ UTILITIES & ITEMS ]
				</h3>
				<div class="grid grid-cols-2 gap-2">
					{
						toolsTechs.map(tech => {
							const Icon = tech.icon;
							return (
								<div class="flex items-center gap-2 p-2 border border-edge-subtle bg-surface/50 hover:bg-primary-500/5 hover:border-primary-500/30 transition-all duration-150 group cursor-default">
									{Icon && (
										<Icon class="w-4 h-4 text-primary-500 dark:text-primary-400 shrink-0" />
									)}
									<span class="font-gaming-mono text-xs uppercase tracking-wider text-content-strong font-bold">
										{tech.name}
									</span>
								</div>
							);
						})
					}
				</div>
			</article>
		</div>

		<!-- Back Button -->
		<div class="w-full flex justify-center mt-8">
			<a
				href={getLocalizedPath(lang, '/')}
				class="inline-flex items-center justify-center rounded-none bg-primary-500 text-white dark:text-black border-2 border-black dark:border-white text-base px-6 py-3.5 font-bold uppercase tracking-wider transition-all duration-100 shadow-[3px_3px_0px_0px_var(--color-edge-strong)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[5px_5px_0px_0px_var(--color-edge-strong)] active:translate-x-[1px] active:translate-y-[1px] active:shadow-none"
			>
				[ RETURN TO HOME ]
			</a>
		</div>
	</SectionContainer>
</Layout>
