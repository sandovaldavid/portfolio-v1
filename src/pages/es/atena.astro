---
import Layout from '@app/layouts/Layout.astro';
import { TAGS } from '@shared/config/technology';
import { TechPill, SectionContainer } from '@shared/ui';
import { getLocalizedPath } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

const lang = Language.SPANISH;

const atenaTechs = [
	TAGS.TYPESCRIPT,
	TAGS.ANGULAR,
	TAGS.RXJS,
	TAGS.JAVASCRIPT,
	TAGS.CSS,
	TAGS.HTML,
	TAGS.TAILWIND,
].filter(Boolean);
---

<Layout
	title="Trabajo en Atena - David Sandoval"
	description="Detalles de la experiencia profesional y logros de David Sandoval en Atena como desarrollador de software."
	img_preview="/projects/portfolio.webp"
	isHome={false}
>
	<SectionContainer id="atena-details" class="w-full max-w-4xl px-4 flex flex-col gap-8">
		<!-- Section Header -->
		<div class="text-center space-y-3">
			<h1
				class="text-4xl md:text-5xl font-bold font-pixel-clean text-content-strong uppercase tracking-wide"
			>
				Detalles de Misión: ATENA
			</h1>
			<p class="text-content-muted font-mono text-sm uppercase">
				[ ROL: DESARROLLADOR DE SOFTWARE // RANGO: EXPERTO FRONTEND ]
			</p>
		</div>

		<!-- Mission Card Dashboard -->
		<div
			class="border-2 border-black dark:border-white bg-surface shadow-retro-2xl p-6 md:p-8 flex flex-col gap-6"
		>
			<!-- Header Block -->
			<div
				class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b-2 border-dashed border-edge-subtle pb-4 gap-4"
			>
				<div>
					<span
						class="text-content-muted text-xs font-bold tracking-wider uppercase block"
						>COMPAÑÍA / ORGANIZACIÓN</span
					>
					<span class="text-2xl font-bold text-content-strong font-mono">ATENA</span>
				</div>
				<div class="sm:text-right">
					<span
						class="text-content-muted text-xs font-bold tracking-wider uppercase block"
						>PERÍODO OPERATIVO</span
					>
					<span
						class="text-base font-bold text-status-success-text font-mono uppercase bg-status-success-bg px-2.5 py-1 border border-status-success-border"
						>[ OCTUBRE 2025 – PRESENTE ]</span
					>
				</div>
			</div>

			<!-- Core Duties & Achievements -->
			<div class="space-y-6">
				<div>
					<h2
						class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 mb-3"
					>
						[ OBJETIVOS DE LA MISIÓN ]
					</h2>
					<p class="text-content text-base leading-relaxed font-mono">
						Liderar la ingeniería de interfaces de usuario y diseñar arquitecturas de
						frontend modulares, mantenibles y de alto rendimiento utilizando Angular
						como core framework.
					</p>
				</div>

				<div>
					<h2
						class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 mb-3"
					>
						[ LOGROS Y ACCIONES CLAVE ]
					</h2>
					<ul class="space-y-4 text-base font-mono">
						<li class="flex items-start gap-3">
							<span
								class="shrink-0 w-2 h-2 rounded-none bg-primary-500 dark:bg-primary-400 mt-2.5"
							></span>
							<span class="text-content leading-relaxed">
								<strong>Arquitectura Angular Premium:</strong> Diseñé y reestructuré componentes
								bajo una metodología modular y de inyección de dependencias limpia, permitiendo
								al equipo de desarrollo escalar el codebase sin colisiones de estado.
							</span>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="shrink-0 w-2 h-2 rounded-none bg-primary-500 dark:bg-primary-400 mt-2.5"
							></span>
							<span class="text-content leading-relaxed">
								<strong>Optimización de Rendimiento Frontend:</strong> Reduje el tamaño
								de los bundles de producción mediante lazy loading, agitación de árbol
								(tree shaking) y optimización de assets, aumentando sustancialmente el
								índice de Web Vitals.
							</span>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="shrink-0 w-2 h-2 rounded-none bg-primary-500 dark:bg-primary-400 mt-2.5"
							></span>
							<span class="text-content leading-relaxed">
								<strong>Reactividad Robusta con RxJS:</strong> Implementé flujos reactivos
								asíncronos para el manejo de datos en tiempo real, garantizando interfaces
								de usuario sumamente dinámicas y libres de fugas de memoria.
							</span>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="shrink-0 w-2 h-2 rounded-none bg-primary-500 dark:bg-primary-400 mt-2.5"
							></span>
							<span class="text-content leading-relaxed">
								<strong>Colaboración API Segura:</strong> Integré de manera segura APIs
								y servicios en la nube, coordinando validaciones estrictas de tipo (TypeScript)
								a lo largo de toda la capa de consumo de datos.
							</span>
						</li>
					</ul>
				</div>

				<!-- Weapon & Tech Arsenal -->
				<div class="border-t-2 border-dashed border-edge-subtle pt-4">
					<h2
						class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 mb-3"
					>
						[ ARSENAL TECNOLÓGICO ]
					</h2>
					<div class="flex flex-wrap gap-2.5 mt-2">
						{
							atenaTechs.map(tech => (
								<TechPill
									label={tech.name}
									icon={tech.icon}
									variant="stack"
									class="px-2.5 py-1.5 text-xs font-mono font-semibold"
								/>
							))
						}
					</div>
				</div>
			</div>
		</div>

		<!-- Back Button -->
		<div class="w-full flex justify-center mt-4">
			<a
				href={getLocalizedPath(lang, '/')}
				class="inline-flex items-center justify-center rounded-none bg-surface text-content-strong border-2 border-black dark:border-white text-base px-6 py-3.5 font-bold uppercase tracking-wider transition-all duration-100 shadow-retro-md hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-retro-xl active:translate-x-[1px] active:translate-y-[1px] active:shadow-retro-xs"
			>
				[ RETORNAR AL INICIO ]
			</a>
		</div>
	</SectionContainer>
</Layout>
