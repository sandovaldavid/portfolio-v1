---
import { render } from 'astro:content';
import Layout from '@app/layouts/Layout.astro';
import { BlogDetail } from '@widgets/blog';
import {
	getBlogLocalizedPaths,
	getBlogPost,
	getBlogPosts,
	getBlogSlug,
} from '@entities/blog';
import { Language } from '@shared/config/i18n';
import { useTranslations } from '@shared/lib/i18n';

export async function getStaticPaths() {
	const posts = await getBlogPosts(Language.SPANISH);
	return posts.map(post => ({
		params: { slug: getBlogSlug(post) },
	}));
}

const slug = Astro.params.slug ?? '';
const t = useTranslations(Language.SPANISH);
const post = await getBlogPost(Language.SPANISH, slug);

if (!post) {
	return Astro.redirect('/404');
}

const localizedPaths = await getBlogLocalizedPaths(post);
const { Content } = await render(post);
---

<Layout
	title={`${post.data.title} | Blog | David Sandoval`}
	description={post.data.description}
	img_preview={post.data.heroImage?.src ?? '/projects/portfolio.webp'}
	isHome={false}
	article
	{localizedPaths}
>
	<div class="py-16 md:py-24">
		<BlogDetail
			{post}
			{Content}
			backText={t('blog.back')}
			backLink="/es/blog"
			publishedLabel={t('blog.published')}
			updatedLabel={t('blog.updated')}
			tagsLabel={t('blog.tags')}
		/>
	</div>
</Layout>
