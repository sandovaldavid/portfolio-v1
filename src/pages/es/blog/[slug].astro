---
import { render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Layout from '@app/layouts/Layout.astro';
import { getBlogLocalizedPaths, getBlogPost, getBlogPosts, getBlogSlug } from '@entities/blog';
import {
	createScopedUiTranslator,
	getLanguageFromLocale,
	Language,
} from '@shared/config/i18n';
import { BlogDetail } from '@widgets/blog';

export async function getStaticPaths() {
	const posts = await getBlogPosts(Language.SPANISH);
	return posts.map(post => ({
		params: { slug: getBlogSlug(post) },
	}));
}

const lang = getLanguageFromLocale(Astro.currentLocale);
const slug = Astro.params.slug ?? '';
const tBlog = createScopedUiTranslator(lang, 'pages.blog');
const post = await getBlogPost(lang, slug);

if (!post) {
	return Astro.redirect('/404');
}

const localizedPaths = await getBlogLocalizedPaths(post);
const { Content } = await render(post);
---

<Layout
	title={`${post.data.title} | Blog | David Sandoval`}
	description={post.data.description}
	img_preview={post.data.heroImage?.src ?? '/projects/portfolio.webp'}
	imageAlt={post.data.title}
	pageType="blog"
	publishedTime={post.data.pubDate}
	modifiedTime={post.data.updatedDate}
	breadcrumbLabel={post.data.title}
	{localizedPaths}
>
	<div class="py-16 md:py-24">
		<BlogDetail
			{post}
			{Content}
			backText={tBlog('back')}
			backLink={getRelativeLocaleUrl(lang, 'blog')}
			publishedLabel={tBlog('published')}
			updatedLabel={tBlog('updated')}
			tagsLabel={tBlog('tags')}
		/>
	</div>
</Layout>
