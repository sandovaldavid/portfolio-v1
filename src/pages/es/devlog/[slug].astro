---
import { render } from 'astro:content';
import Layout from '@app/layouts/Layout.astro';
import { DevlogDetail } from '@widgets/devlog';
import { getDevlogPosts, getDevlogSlug } from '@entities/devlog';
import { Language } from '@shared/config/i18n';
import { getLangFromUrl, useTranslations } from '@shared/lib/i18n';

export async function getStaticPaths() {
	const posts = await getDevlogPosts(Language.SPANISH);
	return posts.map(post => ({
		params: { slug: getDevlogSlug(post) },
	}));
}

const { slug } = Astro.params;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const posts = await getDevlogPosts(lang);
const post = posts.find(p => getDevlogSlug(p) === slug);

if (!post) {
	return Astro.redirect('/404');
}

const { Content } = await render(post);
---

<Layout
	title={`${post.data.title} | Devlog | David Sandoval`}
	description={post.data.summary}
	img_preview="/projects/portfolio.webp"
	isHome={false}
>
	<div class="py-16 md:py-24">
		<DevlogDetail {post} {Content} backText={t('devlog.back')} backLink="/es/devlog" />
	</div>
</Layout>
