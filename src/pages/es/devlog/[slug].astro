---
import { render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Layout from '@app/layouts/Layout.astro';
import { DevlogDetail } from '@widgets/devlog';
import {
	getDevlogLocalizedPaths,
	getDevlogPost,
	getDevlogPosts,
	getDevlogSlug,
} from '@entities/devlog';
import { getLanguageFromLocale, Language } from '@shared/config/i18n';
import { useTranslations } from '@shared/lib/i18n';

export async function getStaticPaths() {
	const posts = await getDevlogPosts(Language.SPANISH);
	return posts.map(post => ({
		params: { slug: getDevlogSlug(post) },
	}));
}

const lang = getLanguageFromLocale(Astro.currentLocale);
const slug = Astro.params.slug ?? '';
const t = useTranslations(lang);
const post = await getDevlogPost(lang, slug);

if (!post) {
	return Astro.redirect('/404');
}

const localizedPaths = await getDevlogLocalizedPaths(post);
const { Content } = await render(post);
---

<Layout
	title={`${post.data.title} | Devlog | David Sandoval`}
	description={post.data.summary}
	img_preview="/projects/portfolio.webp"
	imageAlt={post.data.title}
	pageType="devlog"
	publishedTime={post.data.pubDate}
	breadcrumbLabel={post.data.title}
	{localizedPaths}
>
	<div class="py-16 md:py-24">
		<DevlogDetail
			{post}
			{Content}
			backText={t('devlog.back')}
			backLink={getRelativeLocaleUrl(lang, 'devlog')}
		/>
	</div>
</Layout>
