---
import Layout from '@app/layouts/Layout.astro';
import { createScopedUiTranslator, Language } from '@shared/config/i18n';
import { SkillsPage } from '@widgets/skills-page';

const lang = Language.SPANISH;
const tPage = createScopedUiTranslator(lang, 'pages.skills');
---

<Layout
	title={tPage('pageTitle')}
	description={tPage('pageDescription')}
	img_preview="/projects/portfolio.webp"
	isHome={false}
>
	<SkillsPage {lang} />
</Layout>
