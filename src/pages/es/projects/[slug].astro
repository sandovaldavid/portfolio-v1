---
import Layout from '@app/layouts/Layout.astro';
import { ProjectCaseStudy } from '@widgets/project-case-study';
import { getProjectsData } from '@entities/project';
import { Language } from '@shared/config/i18n';
import { getLangFromUrl, useTranslations } from '@shared/lib/i18n';

export function getStaticPaths() {
	const t = useTranslations(Language.SPANISH);
	const projects = getProjectsData(t);
	return projects
		.filter(p => p.caseStudy)
		.map(p => ({
			params: { slug: p.slug },
			props: { slug: p.slug },
		}));
}

const { slug } = Astro.params;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projects = getProjectsData(t);
const project = projects.find(p => p.slug === slug);

if (!project) {
	return Astro.redirect('/404');
}

const pageTitle = `${project.title} — Caso de Estudio | David Sandoval`;
---

<Layout title={pageTitle} description={project.description} img_preview={project.image.src}>
	<div class="py-16 md:py-24">
		{
			project.caseStudy && (
				<ProjectCaseStudy
					project={project}
					backLink="/es/projects"
					backText={t('projects.case.back')}
					codeButtonText={t('projects.code-button')}
					previewButtonText={t('projects.preview-button')}
					labelProblem={t('projects.case.problem')}
					labelApproach={t('projects.case.approach')}
					labelTradeoffs={t('projects.case.tradeoffs')}
					labelOutcome={t('projects.case.outcome')}
					labelLearnings={t('projects.case.learnings')}
					labelTimeline={t('projects.case.timeline')}
					labelRole={t('projects.case.role')}
				/>
			)
		}
	</div>
</Layout>
