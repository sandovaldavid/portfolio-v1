---
import Layout from '@app/layouts/Layout.astro';
import { TAGS } from '@entities/technology';
import { TechPill, SectionContainer } from '@shared/ui';
import { getLocalizedPath } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

const lang = Language.ENGLISH;

const atenaTechs = [
	TAGS.TYPESCRIPT,
	TAGS.ANGULAR,
	TAGS.RXJS,
	TAGS.JAVASCRIPT,
	TAGS.CSS,
	TAGS.HTML,
	TAGS.TAILWIND,
].filter(Boolean);
---

<Layout
	title="Atena Experience - David Sandoval"
	description="Detailed professional experience and achievements of David Sandoval at Atena as a software developer."
	img_preview="/projects/portfolio.webp"
	isHome={false}
>
	<SectionContainer id="atena-details" class="w-full max-w-4xl px-4 flex flex-col gap-8">
		<!-- Section Header -->
		<div class="text-center space-y-3">
			<h2
				class="text-4xl md:text-5xl font-bold font-pixel-clean text-content-strong uppercase tracking-wide"
			>
				Mission Details: ATENA
			</h2>
			<p class="text-content-muted font-mono text-sm uppercase">
				[ ROLE: SOFTWARE DEVELOPER // RANGE: FRONTEND EXPERT ]
			</p>
		</div>

		<!-- Mission Card Dashboard -->
		<div
			class="border-2 border-black dark:border-white bg-surface shadow-[6px_6px_0px_var(--color-edge-strong)] p-6 md:p-8 flex flex-col gap-6"
		>
			<!-- Header Block -->
			<div
				class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b-2 border-dashed border-edge-subtle pb-4 gap-4"
			>
				<div>
					<span
						class="text-content-muted text-xs font-bold tracking-wider uppercase block"
						>COMPANY / ORGANIZATION</span
					>
					<span class="text-2xl font-bold text-content-strong font-mono">ATENA</span>
				</div>
				<div class="sm:text-right">
					<span
						class="text-content-muted text-xs font-bold tracking-wider uppercase block"
						>OPERATIONAL PERIOD</span
					>
					<span
						class="text-base font-bold text-status-success-text font-mono uppercase bg-status-success-bg px-2.5 py-1 border border-status-success-border"
						>[ OCTOBER 2025 – PRESENT ]</span
					>
				</div>
			</div>

			<!-- Core Duties & Achievements -->
			<div class="space-y-6">
				<div>
					<h3
						class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 mb-3"
					>
						[ MISSION OBJECTIVES ]
					</h3>
					<p class="text-content text-base leading-relaxed font-mono">
						Lead user interface engineering and design modular, maintainable, and
						high-performance frontend architectures using Angular as the core framework.
					</p>
				</div>

				<div>
					<h3
						class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 mb-3"
					>
						[ KEY ACHIEVEMENTS & ACTIONS ]
					</h3>
					<ul class="space-y-4 text-base font-mono">
						<li class="flex items-start gap-3">
							<span
								class="shrink-0 w-2 h-2 rounded-none bg-primary-500 dark:bg-primary-400 mt-2.5"
							></span>
							<span class="text-content leading-relaxed">
								<strong>Premium Angular Architecture:</strong> Engineered and refactored
								components using clean dependency injection and modular structures, enabling
								the team to scale the codebase without state conflicts.
							</span>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="shrink-0 w-2 h-2 rounded-none bg-primary-500 dark:bg-primary-400 mt-2.5"
							></span>
							<span class="text-content leading-relaxed">
								<strong>Frontend Performance Tuning:</strong> Reduced production bundle
								sizes through lazy loading, tree shaking, and asset optimization, substantially
								improving Core Web Vitals scores.
							</span>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="shrink-0 w-2 h-2 rounded-none bg-primary-500 dark:bg-primary-400 mt-2.5"
							></span>
							<span class="text-content leading-relaxed">
								<strong>Robust Reactivity with RxJS:</strong> Implemented reactive, asynchronous
								data streams for real-time state synchronization, guaranteeing highly
								dynamic and memory-leak-free user interfaces.
							</span>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="shrink-0 w-2 h-2 rounded-none bg-primary-500 dark:bg-primary-400 mt-2.5"
							></span>
							<span class="text-content leading-relaxed">
								<strong>Secure API Integration:</strong> Safely integrated backend services
								and cloud APIs, coordinating strict TypeScript schema validations across
								the data consumption layer.
							</span>
						</li>
					</ul>
				</div>

				<!-- Weapon & Tech Arsenal -->
				<div class="border-t-2 border-dashed border-edge-subtle pt-4">
					<h3
						class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 mb-3"
					>
						[ TECHNOLOGICAL WEAPONS ]
					</h3>
					<div class="flex flex-wrap gap-2.5 mt-2">
						{
							atenaTechs.map(tech => (
								<TechPill
									label={tech.name}
									icon={tech.icon}
									variant="stack"
									class="px-2.5 py-1.5 text-xs font-mono font-semibold"
								/>
							))
						}
					</div>
				</div>
			</div>
		</div>

		<!-- Back Button -->
		<div class="w-full flex justify-center mt-4">
			<a
				href={getLocalizedPath(lang, '/')}
				class="inline-flex items-center justify-center rounded-none bg-surface text-content-strong border-2 border-black dark:border-white text-base px-6 py-3.5 font-bold uppercase tracking-wider transition-all duration-100 shadow-[3px_3px_0px_0px_var(--color-edge-strong)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[5px_5px_0px_0px_var(--color-edge-strong)] active:translate-x-[1px] active:translate-y-[1px] active:shadow-[1px_1px_0px_0px_var(--color-edge-strong)]"
			>
				[ RETURN TO HOME ]
			</a>
		</div>
	</SectionContainer>
</Layout>
