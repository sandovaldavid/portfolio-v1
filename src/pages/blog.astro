---
import { getRelativeLocaleUrl } from 'astro:i18n';
import Layout from '@app/layouts/Layout.astro';
import { getBlogPosts, getBlogSlug } from '@entities/blog';
import { createScopedUiTranslator, getLanguageFromLocale } from '@shared/config/i18n';
import { BlogCard } from '@widgets/blog';

const lang = getLanguageFromLocale(Astro.currentLocale);
const tBlog = createScopedUiTranslator(lang, 'pages.blog');
const posts = await getBlogPosts(lang);
---

<Layout
	title={tBlog('pageTitle')}
	description={tBlog('pageDescription')}
	img_preview="/projects/portfolio.webp"
	isHome={false}
>
	<div class="py-16 md:py-24">
		<div class="mx-auto max-w-4xl">
			<header class="mb-12">
				<p
					class="mb-2 font-retro-tag text-sm font-bold uppercase tracking-widest text-primary-500 dark:text-primary-400"
				>
					{tBlog('label')}
				</p>
				<h1 class="mb-4 text-3xl font-bold font-pixel-clean tracking-wide md:text-5xl">
					{tBlog('heading')}
				</h1>
				<p class="max-w-2xl text-base leading-relaxed text-content-muted">
					{tBlog('subheading')}
				</p>
			</header>

			<div class="space-y-6">
				{
					posts.map(post => (
						<BlogCard
							post={post}
							readMoreText={tBlog('readMore')}
							readMoreLink={getRelativeLocaleUrl(lang, `blog/${getBlogSlug(post)}`)}
						/>
					))
				}
			</div>
		</div>
	</div>
</Layout>
