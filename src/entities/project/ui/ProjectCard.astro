---
import GitHubIcon from '@assets/technologies/GitHub.astro';
import LinkIcon from '@assets/icons/Link.astro';
import BookIcon from '@assets/icons/BookOpen.astro';
import { LinkButton, TechPill } from '@shared/ui';
import type { ProjectItem } from '../model';
import { Image } from 'astro:assets';

interface Props {
	project: ProjectItem;
	codeButtonText: string;
	previewButtonText: string;
	caseStudyText?: string;
	caseStudyLink?: string;
	variant?: 'primary' | 'secondary';
	priority?: boolean;
	/** Heading level for the card title: 'h3' under a section h2 (home), 'h2' under a page h1 */
	headingLevel?: 'h2' | 'h3';
}

const {
	project,
	codeButtonText,
	previewButtonText,
	caseStudyText,
	caseStudyLink,
	variant = 'secondary',
	priority = false,
	headingLevel = 'h3',
} = Astro.props;
const Heading = headingLevel;
const { image, title, description, tags, link, github, category } = project;
const isPrimary = variant === 'primary';
---

<article class="font-mono group h-full" style={`animation: var(--animate-fade-in);`}>
	<div
		class={isPrimary
			? 'relative h-full overflow-hidden rounded-none border-2 border-black dark:border-white bg-white/95 dark:bg-neutral-900/95 shadow-retro-lg transition-all duration-100 will-change-transform group-hover:-translate-x-[2px] group-hover:-translate-y-[2px] group-hover:shadow-retro-2xl'
			: 'relative h-full overflow-hidden rounded-none border-2 border-black dark:border-white bg-white/95 dark:bg-neutral-900/95 shadow-retro-md transition-all duration-100 will-change-transform group-hover:-translate-x-[2px] group-hover:-translate-y-[2px] group-hover:shadow-retro-xl'}
	>
		<Image
			src={image}
			width={isPrimary ? 800 : 600}
			height={isPrimary ? 500 : 380}
			class="absolute inset-0 h-full w-full object-cover"
			decoding={priority ? 'sync' : 'async'}
			loading={priority ? 'eager' : 'lazy'}
			fetchpriority={priority ? 'high' : 'auto'}
			alt={`${title} project image`}
		/>
		<div
			class="absolute inset-0 bg-linear-to-b from-transparent via-background/80 to-background"
		>
		</div>
		<div
			class="absolute inset-x-0 top-0 flex items-center gap-2 border-b-2 border-black dark:border-white bg-white/90 dark:bg-neutral-900 px-4 py-3"
		>
			<span class="size-3 border border-black dark:border-white bg-red-500" aria-hidden="true"
			></span>
			<span
				class="size-3 border border-black dark:border-white bg-yellow-500"
				aria-hidden="true"></span>
			<span
				class="size-3 border border-black dark:border-white bg-green-500"
				aria-hidden="true"></span>
			<span
				class="ml-auto font-retro-tag text-xs uppercase tracking-wider text-content-muted font-bold"
				>{isPrimary ? 'Feature' : 'Project'}</span
			>
		</div>

		<div
			class={isPrimary
				? 'relative flex h-full flex-col justify-end gap-3 p-6 md:p-8 min-h-[460px] pt-14'
				: 'relative flex h-full flex-col justify-end gap-3 p-5 min-h-[320px] pt-14'}
		>
			{
				category && (
					<p class="font-retro-tag text-sm font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400">
						{category}
					</p>
				)
			}
			<Heading
				class={isPrimary
					? 'text-content-strong text-3xl font-bold font-pixel-clean tracking-wide'
					: 'text-content-strong text-2xl font-bold font-pixel-clean tracking-wide'}
			>
				{title}
			</Heading>
			<p class="text-base text-content leading-relaxed line-clamp-3">
				{description}
			</p>

			<ul class="flex flex-row flex-wrap gap-2 pt-1">
				{
					tags.map(tag => (
						<li>
							<TechPill
								label={tag.name}
								icon={tag.icon}
								size="sm"
								variant="card"
								class={tag.class}
							/>
						</li>
					))
				}
			</ul>

			<footer class="mt-3 flex flex-wrap items-center gap-3">
				{
					github && (
						<LinkButton href={github}>
							<GitHubIcon class="size-5" />
							{codeButtonText}
						</LinkButton>
					)
				}
				{
					link && (
						<LinkButton href={link}>
							<LinkIcon class="size-4" />
							{previewButtonText}
						</LinkButton>
					)
				}
				{
					caseStudyText && caseStudyLink && (
						<LinkButton href={caseStudyLink}>
							<BookIcon class="size-4" />
							{caseStudyText}
						</LinkButton>
					)
				}
			</footer>
		</div>
	</div>
</article>
