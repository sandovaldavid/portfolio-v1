---
import { getProjectsData, ProjectCard } from '@entities/project';
import { createScopedUiTranslator, Language } from '@shared/config/i18n';
import { getLangFromUrl, getLocalizedPath } from '@shared/lib/i18n';

interface Props {
	showAll?: boolean;
}
const { showAll = false } = Astro.props;

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const tProjects = createScopedUiTranslator(lang, 'sections.projects');
const projects = await getProjectsData(lang);

const projectsToDisplay = showAll
	? projects
	: projects.filter(project => project.featured).slice(0, 2);
---

<section class="font-sans w-full">
	<div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full items-stretch">
		{
			projectsToDisplay.map((project, i) => (
				<div class="h-full">
					<ProjectCard
						project={project}
						variant="secondary"
						headingLevel={showAll ? 'h2' : 'h3'}
						codeButtonText={tProjects('codeButton')}
						previewButtonText={tProjects('previewButton')}
						cardTypeText={tProjects(project.featured ? 'cardFeature' : 'cardProject')}
						caseStudyText={tProjects('caseStudy')}
						caseStudyLink={getLocalizedPath(lang, `/projects/${project.slug}`)}
						priority={i < 2}
					/>
				</div>
			))
		}
	</div>

	{
		!showAll && (
			<div class="w-full flex justify-center mt-12">
				<a
					href={getLocalizedPath(lang, '/projects')}
					class="inline-flex items-center justify-center rounded-none bg-surface text-content-strong border-2 border-black dark:border-white text-base px-6 py-3.5 font-bold uppercase tracking-wider transition-all duration-100 shadow-retro-md hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-retro-xl active:translate-x-[1px] active:translate-y-[1px] active:shadow-retro-xs"
				>
					{tProjects('viewAll')}
				</a>
			</div>
		)
	}
</section>
