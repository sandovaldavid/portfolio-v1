---
import { getProjectsData, ProjectCard } from '@entities/project';
import { getLangFromUrl, getLocalizedPath, useTranslations } from '@shared/lib/i18n';

interface Props {
	showAll?: boolean;
}
const { showAll = false } = Astro.props;

const lang = getLangFromUrl(new URL(Astro.request.url));
const t = useTranslations(lang);
const PROJECTS = getProjectsData(t);

// Sort so featured come first, then slice if we are on home page
const projectsToDisplay = showAll
	? PROJECTS
	: PROJECTS.filter(project => project.featured).slice(0, 2);
---

<section class="font-sans w-full">
	<div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full items-stretch">
		{
			projectsToDisplay.map((project, i) => (
				<div class="h-full">
					<ProjectCard
						project={project}
						variant="secondary"
						codeButtonText={t('projects.code-button')}
						previewButtonText={t('projects.preview-button')}
						caseStudyText={project.caseStudy ? t('projects.case.study') : undefined}
						caseStudyLink={
							project.caseStudy
								? getLocalizedPath(lang, `/projects/${project.slug}`)
								: undefined
						}
						priority={i < 2}
					/>
				</div>
			))
		}
	</div>

	{
		!showAll && (
			<div class="w-full flex justify-center mt-12">
				<a
					href={getLocalizedPath(lang, '/projects')}
					class="inline-flex items-center justify-center rounded-none bg-surface text-content-strong border-2 border-black dark:border-white text-base px-6 py-3.5 font-bold uppercase tracking-wider transition-all duration-100 shadow-[3px_3px_0px_0px_var(--color-edge-strong)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[5px_5px_0px_0px_var(--color-edge-strong)] active:translate-x-[1px] active:translate-y-[1px] active:shadow-[1px_1px_0px_0px_var(--color-edge-strong)]"
				>
					{t('projects.view-all')}
				</a>
			</div>
		)
	}
</section>
