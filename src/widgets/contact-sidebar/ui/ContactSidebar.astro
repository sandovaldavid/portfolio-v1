---
/**
 * ContactSidebar Widget
 * Floating left-side contact bar with social icon links
 * FSD Layer: Widgets > contact-sidebar > UI
 */
import { getLangFromUrl } from '@shared/lib/i18n';
import { siteConfig } from '@shared/config/site.config';

const lang = getLangFromUrl(new URL(Astro.request.url));
const isEN = lang === 'en';

const links = [
	{
		label: 'GitHub',
		href: siteConfig.social.github,
		tooltip: `@${siteConfig.social.githubUsername}`,
		external: true,
		svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4.5 h-4.5"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
	},
	{
		label: 'LinkedIn',
		href: siteConfig.social.linkedin,
		tooltip: `in/${siteConfig.social.linkedinUsername}`,
		external: true,
		svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4.5 h-4.5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
	},
	{
		label: 'Email',
		href: `mailto:${siteConfig.email}`,
		tooltip: siteConfig.email,
		external: false,
		svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4.5 h-4.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
	},
	{
		label: 'Link Hub',
		href: siteConfig.social.linkHub,
		tooltip: 'Link Hub',
		external: true,
		svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4.5 h-4.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
	},
	{
		label: isEN ? 'Resume' : 'CV',
		href: isEN ? siteConfig.resume.en : siteConfig.resume.es,
		tooltip: isEN ? 'Download Resume' : 'Descargar CV',
		external: true,
		svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4.5 h-4.5"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/></svg>`,
	},
];
---

<!-- Contact Sidebar — fixed left edge, vertical icon bar -->
<aside
	id="contact-sidebar"
	class="fixed left-0 top-1/2 -translate-y-1/2 z-30 flex flex-col items-center gap-0 hidden xl:flex"
	aria-label="Social contact links"
>
	<!-- Top line -->
	<div class="w-px h-16 bg-edge-strong opacity-60"></div>

	<!-- Icon links -->
	<div
		class="flex flex-col border-2 border-black dark:border-white bg-surface shadow-[3px_3px_0px_0px_var(--color-primary-500)] divide-y-2 divide-black dark:divide-white"
	>
		{
			links.map(({ label, href, tooltip, external, svg }) => (
				<a
					href={href}
					target={external ? '_blank' : undefined}
					rel={external ? 'noopener noreferrer' : undefined}
					title={tooltip}
					aria-label={label}
					class="group relative flex items-center justify-center w-10 h-10 text-content-muted hover:text-badge-brand-text hover:bg-badge-brand-bg transition-all duration-150"
				>
					<Fragment set:html={svg} />
					{/* Tooltip */}
					<span class="pointer-events-none absolute left-full ml-3 whitespace-nowrap font-gaming-mono text-xs font-bold uppercase tracking-wider bg-surface border-2 border-black dark:border-white text-content-strong px-2.5 py-1.5 shadow-[2px_2px_0px_var(--color-primary-500)] opacity-0 group-hover:opacity-100 translate-x-1 group-hover:translate-x-0 transition-all duration-150 z-50">
						{tooltip}
					</span>
				</a>
			))
		}
	</div>

	<!-- Bottom line -->
	<div class="w-px h-16 bg-edge-strong opacity-60"></div>
</aside>
