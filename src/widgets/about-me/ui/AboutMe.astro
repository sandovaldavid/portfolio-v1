---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);
const personalImageAlt = 'Juan David';
---

<div class="space-y-6">
	<!-- First Card: Text Content and Profile Image -->
	<article
		class="rounded-none bg-surface border-2 border-border-strong p-8 md:p-10 shadow-[4px_4px_0px_0px_var(--color-border-strong)] transition-all duration-100"
	>
		<div class="flex flex-col items-center justify-center gap-8 md:gap-12 md:flex-row">
			<!-- Text Content -->
			<div
				class="flex-1 space-y-5 [&>p]:text-neutral-700 dark:[&>p]:text-neutral-300 [&>p>strong]:text-primary-500 dark:[&>p>strong]:text-primary-400 [&>p>strong]:font-semibold text-pretty"
			>
				<p set:html={t('about-me.paragraph1')} />
				
				<div class="pt-2">
					<a
						href={getLocalizedPath(lang, '/about')}
						class="inline-flex items-center justify-center rounded-none bg-surface text-text-main border-2 border-black dark:border-white text-xs px-5 py-3 font-bold uppercase tracking-wider transition-all duration-100 shadow-[2.5px_2.5px_0px_0px_var(--color-border-strong)] hover:-translate-x-[1px] hover:-translate-y-[1px] hover:shadow-[3.5px_3.5px_0px_0px_var(--color-border-strong)] active:translate-x-[1px] active:translate-y-[1px] active:shadow-[1px_1px_0px_0px_var(--color-border-strong)]"
					>
						{t('about-me.read-more')}
					</a>
				</div>
			</div>

			<!-- Profile Image -->
			<div class="shrink-0">
				<img
					width="240"
					height="240"
					src="/profile/perfil.webp"
					alt={personalImageAlt}
					class="w-48 h-48 md:w-56 md:h-56 object-cover aspect-square rounded-none border-2 border-black dark:border-white shadow-[4px_4px_0px_0px_var(--color-border-strong)]"
					style="object-position: 50% 50%"
				/>
			</div>
		</div>
	</article>

	<!-- Atena Current Work Card -->
	<article
		class="rounded-none bg-surface border-2 border-border-strong p-8 md:p-10 shadow-[4px_4px_0px_0px_var(--color-border-strong)] transition-all duration-100 flex flex-col md:flex-row justify-between items-start md:items-center gap-6"
	>
		<div class="space-y-3 flex-1">
			<h3 class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400">
				{t('about-me.atena.title')}
			</h3>
			<p class="text-neutral-700 dark:text-neutral-300 text-base leading-relaxed" set:html={t('about-me.atena.summary')} />
		</div>
		<div class="shrink-0 w-full md:w-auto mt-2 md:mt-0">
			<a
				href={getLocalizedPath(lang, '/atena')}
				class="w-full md:w-auto inline-flex items-center justify-center rounded-none bg-primary-500 text-white dark:text-black border-2 border-black dark:border-white text-xs px-5 py-3 font-bold uppercase tracking-wider transition-all duration-100 shadow-[2.5px_2.5px_0px_0px_var(--color-border-strong)] hover:-translate-x-[1px] hover:-translate-y-[1px] hover:shadow-[3.5px_3.5px_0px_0px_var(--color-border-strong)] active:translate-x-[1px] active:translate-y-[1px] active:shadow-[1px_1px_0px_0px_var(--color-border-strong)]"
			>
				{t('about-me.atena.button')}
			</a>
		</div>
	</article>
</div>
