---
import { getLangFromUrl, useTranslations } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);
const personalImageAlt = 'Juan David';

const focusAreas = [
	t('about-me.focus1'),
	t('about-me.focus2'),
	t('about-me.focus3'),
	t('about-me.focus4'),
	t('about-me.focus5'),
	t('about-me.focus6'),
];
---

<div class="space-y-8">
	<!-- First Card: Text Content and Profile Image -->
	<article
		class="rounded-3xl bg-neutral-100/80 dark:bg-neutral-800/80 border border-neutral-300/80 dark:border-neutral-700/80 backdrop-blur-sm p-8 md:p-10 shadow-lg shadow-neutral-200/50 dark:shadow-neutral-950/50"
	>
		<div class="flex flex-col items-center justify-center gap-8 md:gap-12 md:flex-row">
			<!-- Text Content -->
			<div
				class="flex-1 space-y-4 [&>p]:text-neutral-700 dark:[&>p]:text-neutral-300 [&>p>strong]:text-primary-500 dark:[&>p>strong]:text-primary-400 [&>p>strong]:font-semibold text-pretty"
			>
				<p set:html={t('about-me.paragraph1')} />
				<p set:html={t('about-me.paragraph2')} />
				<p set:html={t('about-me.paragraph3')} />
			</div>

			<!-- Profile Image -->
			<div class="shrink-0">
				<img
					width="240"
					height="240"
					src="/profile/perfil.webp"
					alt={personalImageAlt}
					class="w-56 h-56 object-cover aspect-square rounded-2xl ring-2 ring-primary-500/40 shadow-lg shadow-primary-500/20"
					style="object-position: 50% 50%"
				/>
			</div>
		</div>
	</article>

	<!-- Second Card: Currently Focused On -->
	<article
		class="rounded-3xl bg-neutral-100/80 dark:bg-neutral-800/80 border border-neutral-300/80 dark:border-neutral-700/80 backdrop-blur-sm p-8 md:p-10 shadow-lg shadow-neutral-200/50 dark:shadow-neutral-950/50"
	>
		<h3 class="text-2xl font-bold text-neutral-900 dark:text-neutral-50 mb-6 md:mb-8">
			{t('about-me.currently-focused')}
		</h3>
		<ul class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
			{
				focusAreas.map((area, idx) => (
					<li
						class="flex items-start gap-3 transition-all duration-300"
						style={`animation: var(--animate-slide-up); animation-delay: ${idx * 50}ms;`}
					>
						<span class="shrink-0 w-2 h-2 rounded-full bg-primary-500 dark:bg-primary-400 mt-2" />
						<span class="text-neutral-700 dark:text-neutral-300 text-base leading-relaxed">
							{area}
						</span>
					</li>
				))
			}
		</ul>
	</article>
</div>
