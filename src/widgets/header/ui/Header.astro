---
/**
 * Header Widget Component
 * Main navigation header with responsive design
 * FSD Layer: Widgets > Header > UI
 *
 * Architecture: Composes smaller UI components following FSD
 * - BrandLogo: Left section with logo
 * - DesktopNav: Center navigation (md and above)
 * - MobileNav: Right section with mobile menu
 * - Features: ThemeToggle, LanguagePicker
 */

import { getRelativeLocaleUrl } from 'astro:i18n';
import { LinkButton } from '@shared/ui';
import { createScopedUiTranslator, getLanguageFromLocale } from '@shared/config/i18n';
import { siteConfig } from '@shared/config/site.config';
import BrandLogo from './BrandLogo.astro';
import DesktopNav from './DesktopNav.astro';
import MobileNav from './MobileNav.astro';

const lang = getLanguageFromLocale(Astro.currentLocale);
const tNavigation = createScopedUiTranslator(lang, 'navigation');
const tAccessibility = createScopedUiTranslator(lang, 'accessibility');
const homeUrl = getRelativeLocaleUrl(lang, '');
const homeSectionUrl = (section: string) => `${homeUrl}#${section}`;

const navItems = [
	{
		title: tNavigation('experience'),
		label: 'experience',
		icon: 'experience',
		url: homeSectionUrl('experience'),
	},
	{
		title: tNavigation('research'),
		label: 'research',
		icon: 'research',
		url: homeSectionUrl('research'),
	},
	{
		title: tNavigation('projects'),
		label: 'projects',
		icon: 'projects',
		prefetch: true,
		url: homeSectionUrl('projects'),
	},
	{
		title: tNavigation('blog'),
		label: 'blog',
		icon: 'blog',
		prefetch: true,
		url: getRelativeLocaleUrl(lang, 'blog'),
	},
	{
		title: tNavigation('about'),
		label: 'about-me',
		icon: 'about-me',
		prefetch: true,
		url: homeSectionUrl('about-me'),
	},
	{
		title: tNavigation('stack'),
		label: 'technologies',
		icon: 'technologies',
		url: homeSectionUrl('technologies'),
	},
];
---

<header
	class="fixed top-0 left-0 right-0 z-40 navbar-header font-mono text-content-strong bg-surface border-b-2 border-edge-strong"
>
	<div class="flex items-center justify-between px-4 py-4 md:px-8 max-w-7xl mx-auto w-full">
		<!-- Left: Brand Logo -->
		<div class="w-auto md:w-48 lg:w-72 shrink-0">
			<BrandLogo href={homeUrl} />
		</div>

		<!-- Center: Desktop Navigation -->
		<div class="flex-1 flex justify-center">
			<DesktopNav navLabel={tAccessibility('mainNavigation')} {navItems} />
		</div>

		<!-- Right: Actions (Desktop) -->
		<div class="hidden md:flex items-center justify-end gap-4 shrink-0 md:w-48 lg:w-72">
			<LinkButton
				href={lang === 'en' ? siteConfig.resume.en : siteConfig.resume.es}
				target="_blank"
				variant="primary"
				class="font-mono text-xs uppercase tracking-wider px-3.5 py-1.5"
			>
				{tNavigation('resume')}
			</LinkButton>
		</div>

		<!-- Mobile Menu Button -->
		<div class="flex md:hidden items-center gap-3 shrink-0">
			<MobileNav
				{navItems}
				{lang}
				menuLabel={tAccessibility('mobileNavigation')}
				openLabel={tAccessibility('openMenu')}
				closeLabel={tAccessibility('closeMenu')}
				resumeLabel={tNavigation('resume')}
			/>
		</div>
	</div>
</header>

<script>
	// Active link highlighting with Intersection Observer
	const setupScrollSpy = () => {
		const sections = document.querySelectorAll('section[id]');
		const navLinks = document.querySelectorAll<HTMLElement>('header nav a[data-section-id]');

		const observer = new IntersectionObserver(
			(entries: IntersectionObserverEntry[]) => {
				entries.forEach((entry: IntersectionObserverEntry) => {
					if (entry.isIntersecting) {
						navLinks.forEach(link => {
							if (link.dataset.sectionId === entry.target.id) {
								link.classList.add('active', 'text-primary-500');
							} else {
								link.classList.remove('active', 'text-primary-500');
							}
						});
					}
				});
			},
			{ root: null, rootMargin: '-30% 0px -70% 0px', threshold: 0 }
		);

		sections.forEach(section => observer.observe(section));
		return observer;
	};

	let spyObserver = setupScrollSpy();

	// Re-observe sections after client-side navigation
	document.addEventListener('astro:page-load', () => {
		spyObserver.disconnect();
		spyObserver = setupScrollSpy();
	});

	// Handle visibility changes
	document.addEventListener('visibilitychange', () => {
		if (document.visibilityState === 'hidden') {
			spyObserver.disconnect();
		} else {
			setupScrollSpy();
		}
	});
</script>

<style>
	.navbar-header {
		animation: navbar-shadow 1s linear both;
		animation-timeline: scroll();
		animation-range: 0 100px;
	}

	@keyframes navbar-shadow {
		0% {
			background: transparent;
			backdrop-filter: none;
			box-shadow: none;
		}
		to {
			background: rgba(248, 250, 252, 0.78);
			backdrop-filter: blur(14px);
			box-shadow:
				0 8px 24px -6px rgb(0 0 0 / 0.12),
				0 6px 12px -6px rgb(0 0 0 / 0.14);
		}
	}

	:global(.dark) .navbar-header {
		animation: navbar-shadow-dark 1s linear both;
		animation-timeline: scroll();
		animation-range: 0 100px;
	}

	@keyframes navbar-shadow-dark {
		0% {
			background: transparent;
			backdrop-filter: none;
			box-shadow: none;
		}
		to {
			background: rgba(15, 23, 42, 0.88);
			backdrop-filter: blur(14px);
			box-shadow:
				0 8px 24px -6px rgb(0 0 0 / 0.45),
				0 6px 12px -6px rgb(0 0 0 / 0.35);
		}
	}
</style>
