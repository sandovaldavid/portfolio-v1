---
import { LinkButton } from '@shared/ui';
import MenuIcon from '@assets/icons/MenuIcon.astro';
import BriefcaseIcon from '@assets/icons/Briefcase.astro';
import BrainIcon from '@assets/icons/Brain.astro';
import CodeIcon from '@assets/icons/Code.astro';
import ProfileCheckIcon from '@assets/icons/ProfileCheck.astro';
import ScrollTextIcon from '@assets/icons/ScrollText.astro';
import BookOpenIcon from '@assets/icons/BookOpen.astro';
import SystemIcon from '@assets/icons/System.astro';
import type { Language } from '@shared/config/i18n';
import { siteConfig } from '@shared/config/site.config';

interface Props {
	navItems: Array<{
		title: string;
		label: string;
		url: string;
		icon: string;
	}>;
	lang: Language;
}

const { navItems, lang } = Astro.props;

const menuLabel = lang === 'en' ? 'Navigation menu' : 'Menú de navegación';
---

<nav class="flex md:hidden w-full items-center justify-between">
	<button
		id="mobile-menu-btn"
		class="p-2 rounded-none border-2 border-black dark:border-white bg-surface shadow-retro-sm text-content-strong focus:outline-none focus:ring-2 focus:ring-primary-500 transition-all duration-100 active:translate-x-[1px] active:translate-y-[1px] active:shadow-none"
		aria-label="Toggle menu"
		aria-haspopup="dialog"
		aria-controls="mobile-menu"
		aria-expanded="false"
	>
		<MenuIcon class="size-6" />
	</button>
</nav>

<!-- Mobile Menu Overlay -->
<div
	id="mobile-menu"
	role="dialog"
	aria-modal="true"
	aria-label={menuLabel}
	class="fixed inset-0 w-full h-screen bg-background/95 backdrop-blur-md z-50 hidden items-center justify-center transition-all duration-100"
>
	<div class="flex flex-col items-center justify-center gap-6 w-full max-w-sm px-6">
		<!-- Close Button -->
		<button
			id="mobile-menu-close"
			class="absolute top-6 right-6 p-2 rounded-none bg-surface border-2 border-edge-strong text-content-strong hover:bg-surface-highlight transition-all duration-100 shadow-retro-sm active:translate-x-[1px] active:translate-y-[1px] active:shadow-retro-xs"
			aria-label="Close menu"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				class="w-6 h-6"
				fill="none"
				viewBox="0 0 24 24"
				stroke="currentColor"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M6 18L18 6M6 6l12 12"></path>
			</svg>
		</button>

		<!-- Navigation Items -->
		<nav class="flex flex-col items-center gap-3 w-full" role="navigation">
			{
				navItems.map(link => (
					<a
						class="w-full flex items-center justify-center gap-2 px-6 py-3 rounded-none text-base font-bold uppercase tracking-wider font-mono text-content-strong hover:text-primary-500 hover:bg-surface-highlight border-2 border-transparent hover:border-edge-strong transition-all duration-100 whitespace-nowrap"
						aria-label={link.label}
						href={link.url}
						data-close-menu="true"
					>
						{link.icon === 'experience' && <BriefcaseIcon class="size-5" />}
						{link.icon === 'research' && <BrainIcon class="size-5" />}
						{link.icon === 'projects' && <CodeIcon class="size-5" />}
						{link.icon === 'devlog' && <ScrollTextIcon class="size-5" />}
						{link.icon === 'blog' && <BookOpenIcon class="size-5" />}
						{link.icon === 'about-me' && <ProfileCheckIcon class="size-5" />}
						{link.icon === 'technologies' && <SystemIcon class="size-5" />}
						<span>{link.title}</span>
					</a>
				))
			}
		</nav>

		<!-- Actions: Resume -->
		<div class="flex flex-col items-center gap-4 mt-6 w-full">
			<LinkButton
				href={lang === 'en' ? siteConfig.resume.en : siteConfig.resume.es}
				target="_blank"
				variant="primary"
			>
				Resume
			</LinkButton>
		</div>
	</div>
</div>

<script>
	// The header is re-rendered on every client-side navigation, so the open/
	// close listeners are (re)wired on astro:page-load. Document-level listeners
	// are attached once and resolve the current elements live.
	const openMobileMenu = () => {
		const menu = document.getElementById('mobile-menu');
		const btn = document.getElementById('mobile-menu-btn');
		const close = document.getElementById('mobile-menu-close');
		menu?.classList.remove('hidden');
		menu?.classList.add('flex');
		btn?.setAttribute('aria-expanded', 'true');
		// Move focus into the dialog for keyboard/AT users.
		close?.focus();
	};

	const closeMobileMenu = () => {
		const menu = document.getElementById('mobile-menu');
		const btn = document.getElementById('mobile-menu-btn');
		if (!menu || menu.classList.contains('hidden')) return;
		menu.classList.add('hidden');
		menu.classList.remove('flex');
		btn?.setAttribute('aria-expanded', 'false');
		// Return focus to the trigger after dismissing.
		btn?.focus();
	};

	const setupMobileNav = () => {
		const btn = document.getElementById('mobile-menu-btn');
		const menu = document.getElementById('mobile-menu');
		const close = document.getElementById('mobile-menu-close');
		if (!btn || !menu) return;

		if (btn.dataset.navReady !== 'true') {
			btn.dataset.navReady = 'true';
			btn.addEventListener('click', e => {
				e.stopPropagation();
				openMobileMenu();
			});
		}

		if (close && close.dataset.navReady !== 'true') {
			close.dataset.navReady = 'true';
			close.addEventListener('click', e => {
				e.stopPropagation();
				closeMobileMenu();
			});
		}
	};

	// Close on nav-item click — closest() so clicks on the inner icon/label
	// (not just the <a>) still dismiss the menu. Attached once.
	document.addEventListener('click', e => {
		const target = e.target as HTMLElement | null;
		if (target?.closest?.('[data-close-menu]')) closeMobileMenu();
	});

	// Close on outside click (attached once, resolves elements live).
	document.addEventListener('click', e => {
		const menu = document.getElementById('mobile-menu');
		const btn = document.getElementById('mobile-menu-btn');
		if (menu && !menu.classList.contains('hidden')) {
			const target = e.target;
			if (target instanceof Node && !menu.contains(target) && target !== btn) {
				closeMobileMenu();
			}
		}
	});

	// Escape closes the dialog (dismissible). Attached once.
	document.addEventListener('keydown', e => {
		if (e.key === 'Escape') closeMobileMenu();
	});

	document.addEventListener('astro:page-load', setupMobileNav);
</script>
