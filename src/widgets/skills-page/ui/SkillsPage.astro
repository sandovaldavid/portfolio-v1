---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { createScopedUiTranslator, Language } from '@shared/config/i18n';
import { TAGS } from '@shared/config/technology';
import { SectionContainer } from '@shared/ui';

interface Props {
	lang: Language;
}

const { lang } = Astro.props;
const tPage = createScopedUiTranslator(lang, 'pages.skills');

const categories = [
	{
		heading: tPage('frontendHeading'),
		technologies: [
			TAGS.TYPESCRIPT,
			TAGS.ANGULAR,
			TAGS.RXJS,
			TAGS.NEXTJS,
			TAGS.REACT,
			TAGS.ASTRO,
			TAGS.TAILWIND,
			TAGS.JAVASCRIPT,
			TAGS.CSS,
			TAGS.HTML,
			TAGS.BOOTSTRAP,
		],
	},
	{
		heading: tPage('backendHeading'),
		technologies: [
			TAGS.CSHARP,
			TAGS.JAVA,
			TAGS.PYTHON,
			TAGS.DJANGO,
			TAGS.EXPRESS,
			TAGS.POSTGRESQL,
			TAGS.MYSQL,
			TAGS.SQLITE,
		],
	},
	{
		heading: tPage('toolsHeading'),
		technologies: [TAGS.CLOUDINARY, TAGS.SANITY, TAGS.CHARTJS, TAGS.MARKDOWN],
	},
];
---

<SectionContainer id="all-skills" class="w-full max-w-5xl px-4 flex flex-col gap-8">
	<div class="text-center space-y-3 mb-4">
		<h1
			class="text-4xl md:text-5xl font-bold font-pixel-clean text-content-strong uppercase tracking-wide"
		>
			{tPage('heading')}
		</h1>
		<p class="text-content-muted font-mono text-base uppercase">
			[ {tPage('status')} ]
		</p>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full mt-2">
		{
			categories.map((category, categoryIndex) => (
				<article
					class:list={[
						'rounded-none bg-surface border-2 border-black dark:border-white p-6 shadow-[3px_3px_0px_var(--color-primary-500)] hover:-translate-y-1 hover:shadow-[5px_5px_0px_var(--color-primary-500)] transition-all duration-150 flex flex-col gap-4',
						categoryIndex === 2 && 'md:col-span-2 lg:col-span-1',
					]}
				>
					<h2 class="font-pixel-clean text-2xl font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400 border-b-2 border-dashed border-edge-subtle pb-2">
						[ {category.heading} ]
					</h2>
					<div class="grid grid-cols-2 gap-2">
						{category.technologies.map(technology => {
							const Icon = technology.icon;
							return (
								<div class="flex items-center gap-2 p-2 border border-edge-subtle bg-surface/50 hover:bg-primary-500/5 hover:border-primary-500/30 transition-all duration-150 group cursor-default">
									{Icon && (
										<Icon class="w-4 h-4 text-primary-500 dark:text-primary-400 shrink-0" />
									)}
									<span class="font-gaming-mono text-xs uppercase tracking-wider text-content-strong font-bold">
										{technology.name}
									</span>
								</div>
							);
						})}
					</div>
				</article>
			))
		}
	</div>

	<div class="w-full flex justify-center mt-8">
		<a
			href={getRelativeLocaleUrl(lang, '')}
			class="inline-flex items-center justify-center rounded-none bg-primary-500 text-white dark:text-black border-2 border-black dark:border-white text-base px-6 py-3.5 font-bold uppercase tracking-wider transition-all duration-100 shadow-retro-md hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-retro-xl active:translate-x-[1px] active:translate-y-[1px] active:shadow-none"
		>
			[ {tPage('returnHome')} ]
		</a>
	</div>
</SectionContainer>
