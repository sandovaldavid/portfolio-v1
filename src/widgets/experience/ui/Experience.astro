---
import ArrowRightIcon from '@assets/icons/ArrowRight.astro';
import { getExperienceData } from '@entities/experience';
import { createScopedUiTranslator, getLanguageFromLocale } from '@shared/config/i18n';
import ExperienceItem from './ExperienceItem.astro';

const lang = getLanguageFromLocale(Astro.currentLocale);
const tAccessibility = createScopedUiTranslator(lang, 'accessibility');

const EXPERIENCE = await getExperienceData(lang);
---

<section class="font-sans">
	<div class="grid grid-cols-1 md:grid-cols-5 gap-8">
		<!-- Left: Vertical Tabs -->
		<div class="md:col-span-2">
			<div
				id="experience-tablist"
				role="tablist"
				aria-label={tAccessibility('experienceTabs')}
				class="flex md:flex-col gap-3 overflow-x-auto md:overflow-visible bg-surface border-2 border-edge-strong p-4 rounded-none shadow-retro-sm"
			>
				{
					EXPERIENCE.map((exp, idx) => (
						<button
							role="tab"
							id={`exp-tab-${exp.experienceId}`}
							aria-controls={`exp-panel-${exp.experienceId}`}
							aria-selected={idx === 0 ? 'true' : 'false'}
							tabindex={idx === 0 ? 0 : -1}
							data-index={idx}
							data-experience-id={exp.experienceId}
							data-active={idx === 0 ? 'true' : 'false'}
							class="group relative pl-4 md:pl-6 pr-4 py-3 rounded-none text-left whitespace-nowrap md:whitespace-normal border-2 border-transparent data-[active=true]:border-edge-strong data-[active=true]:bg-badge-brand-bg text-content-muted data-[active=true]:text-content-strong hover:text-content-strong transition-all duration-100 font-bold uppercase tracking-wider text-sm font-gaming-mono cursor-pointer"
						>
							{/* Active indicator bar */}
							<div class="absolute left-0 top-0 bottom-0 w-1 bg-primary-500 scale-y-0 group-data-[active=true]:scale-y-100 transition-transform duration-150 origin-center hidden md:block" />
							<div class="absolute bottom-0 left-0 right-0 h-1 bg-primary-500 scale-x-0 group-data-[active=true]:scale-x-100 transition-transform duration-150 origin-center block md:hidden" />

							<div class="flex flex-col">
								<span class="font-bold flex items-center">
									<span class="text-primary-500 mr-1.5 scale-0 group-data-[active=true]:scale-100 transition-transform duration-150 origin-left">
										<ArrowRightIcon
											class="size-3.5"
											aria-hidden="true"
											focusable="false"
										/>
									</span>
									{exp.company ?? exp.title}
								</span>
								{exp.company && (
									<span class="text-content-muted text-xs md:text-sm pl-4 group-data-[active=true]:pl-4 transition-all duration-150">
										{exp.title}
									</span>
								)}
							</div>
						</button>
					))
				}
			</div>
		</div>

		<!-- Right: Detail Panel -->
		<div class="md:col-span-3">
			<div class="relative" style="display:grid;">
				{
					EXPERIENCE.map((exp, idx) => (
						<div
							role="tabpanel"
							id={`exp-panel-${exp.experienceId}`}
							aria-labelledby={`exp-tab-${exp.experienceId}`}
							class={`[grid-area:1/1] transition-opacity duration-300 ${idx === 0 ? 'opacity-100 pointer-events-auto' : 'opacity-0 pointer-events-none'}`}
							data-active={idx === 0}
							data-experience-id={exp.experienceId}
						>
							<ExperienceItem {...exp} />
						</div>
					))
				}
			</div>
		</div>
	</div>

	<script>
		// ARIA-compliant tabs. Bundled + astro:page-load so the tabs stay
		// interactive after client-side navigation.
		const setupExperienceTabs = () => {
			const tablist = document.getElementById('experience-tablist');
			if (!tablist || tablist.dataset.tabsReady === 'true') return;
			tablist.dataset.tabsReady = 'true';

			const tabs = Array.from(tablist.querySelectorAll<HTMLElement>('[role="tab"]'));
			const panels = tabs
				.map(tab => document.getElementById(tab.getAttribute('aria-controls') ?? ''))
				.filter((panel): panel is HTMLElement => panel instanceof HTMLElement);

			const updatePanelAnimations = (index: number) => {
				panels.forEach((panel, i) => {
					panel.dataset.active = String(i === index);
				});
			};

			const activateTab = (index: number, opts = { focus: false }) => {
				tabs.forEach((tab, i) => {
					const selected = i === index;
					tab.setAttribute('aria-selected', String(selected));
					tab.tabIndex = selected ? 0 : -1;
					tab.dataset.active = String(selected);
					const panel = panels[i];
					if (panel) {
						if (selected) {
							panel.classList.remove('opacity-0', 'pointer-events-none');
							panel.classList.add('opacity-100', 'pointer-events-auto');
						} else {
							panel.classList.remove('opacity-100', 'pointer-events-auto');
							panel.classList.add('opacity-0', 'pointer-events-none');
						}
					}
				});
				updatePanelAnimations(index);
				if (opts.focus) {
					tabs[index]?.focus({ preventScroll: true });
				}
			};

			tabs.forEach((tab, i) => {
				tab.addEventListener('click', () => activateTab(i, { focus: false }));
				tab.addEventListener('keydown', e => {
					const key = e.key;
					let next = i;
					if (key === 'ArrowDown' || key === 'ArrowRight') next = (i + 1) % tabs.length;
					else if (key === 'ArrowUp' || key === 'ArrowLeft')
						next = (i - 1 + tabs.length) % tabs.length;
					else if (key === 'Home') next = 0;
					else if (key === 'End') next = tabs.length - 1;
					else if (key === 'Enter' || key === ' ') activateTab(i, { focus: true });
					if (
						next !== i &&
						['ArrowDown', 'ArrowRight', 'ArrowUp', 'ArrowLeft', 'Home', 'End'].includes(
							key
						)
					) {
						e.preventDefault();
						tabs[next]?.focus({ preventScroll: true });
					}
				});
			});

			activateTab(0, { focus: false });
			updatePanelAnimations(0);
		};

		document.addEventListener('astro:page-load', setupExperienceTabs);
	</script>
</section>
