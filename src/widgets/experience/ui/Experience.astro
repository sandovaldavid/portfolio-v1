---
import ExperienceItem from './ExperienceItem.astro';
import { getExperienceData } from '@entities/experience';
import { getLangFromUrl, useTranslations } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);

const EXPERIENCE = getExperienceData(t);
---
<section class="font-sans">
	<div class="grid grid-cols-1 md:grid-cols-5 gap-8">
		<!-- Left: Vertical Tabs -->
		<div class="md:col-span-2">
			<div
				id="experience-tablist"
				role="tablist"
				aria-label="Experience tabs"
				class="flex md:flex-col gap-3 overflow-x-auto md:overflow-visible bg-neutral-900 p-4 rounded-2xl"
			>
				{
					EXPERIENCE.map((exp, idx) => (
						<button
							role="tab"
							id={`exp-tab-${idx}`}
							aria-controls={`exp-panel-${idx}`}
							aria-selected={idx === 0 ? 'true' : 'false'}
							tabindex={idx === 0 ? 0 : -1}
							data-index={idx}
							class="relative px-4 py-3 rounded-lg text-left whitespace-nowrap md:whitespace-normal data-[active=true]:border-l-4 text-neutral-400 hover:text-neutral-300 hover:bg-neutral-800 transition-colors duration-200 data-[active=true]:bg-neutral-800 data-[active=true]:text-neutral-50 data-[active=true]:border-l-primary-500"
						>
							<div class="absolute left-0 top-0 bottom-0 w-1 bg-primary-500 rounded-l-lg hidden data-[active=true]:block" />
							<div class="flex flex-col">
								<span class="font-semibold">{exp.company ?? exp.title}</span>
								{exp.company && <span class="text-neutral-500 text-xs md:text-sm">{exp.title}</span>}
							</div>
						</button>
					))
				}
			</div>
		</div>

		<!-- Right: Detail Panel -->
		<div class="md:col-span-3">
			{
				EXPERIENCE.map((exp, idx) => (
					<div
						role="tabpanel"
						id={`exp-panel-${idx}`}
						aria-labelledby={`exp-tab-${idx}`}
						hidden={idx !== 0}
						class="transition-opacity duration-200"
					>
						<ExperienceItem {...exp} />
					</div>
				))
			}
		</div>
	</div>

	<script is:inline>
		// Basic ARIA-compliant tabs behavior
		const tablist = document.getElementById('experience-tablist');
		if (tablist) {
			const tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
			const panels = Array.from(document.querySelectorAll('[role="tabpanel"]'));

			function activateTab(index) {
				tabs.forEach((tab, i) => {
					const selected = i === index;
					tab.setAttribute('aria-selected', String(selected));
					tab.tabIndex = selected ? 0 : -1;
					tab.dataset.active = String(selected);
					const panel = panels[i];
					if (panel) panel.hidden = !selected;
				});
				tabs[index]?.focus();
			}

			tabs.forEach((tab, i) => {
				tab.addEventListener('click', () => activateTab(i));
				tab.addEventListener('keydown', (e) => {
					const key = e.key;
					let next = i;
					if (key === 'ArrowDown' || key === 'ArrowRight') next = (i + 1) % tabs.length;
					else if (key === 'ArrowUp' || key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length;
					else if (key === 'Home') next = 0;
					else if (key === 'End') next = tabs.length - 1;
					else if (key === 'Enter' || key === ' ') activateTab(i);
					if (next !== i && ['ArrowDown','ArrowRight','ArrowUp','ArrowLeft','Home','End'].includes(key)) {
						e.preventDefault();
						tabs[next].focus();
					}
				});
			});
			// Set initial active state
			activateTab(0);
		}
	</script>
</section>
