---
import ExperienceItem from './ExperienceItem.astro';
import { getExperienceData } from '@entities/experience';
import { getLangFromUrl, useTranslationsList } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const tList = useTranslationsList(lang);

const EXPERIENCE = getExperienceData(tList);
---

<section class="font-sans">
	<div class="grid grid-cols-1 md:grid-cols-5 gap-8">
		<!-- Left: Vertical Tabs -->
		<div class="md:col-span-2">
			<div
				id="experience-tablist"
				role="tablist"
				aria-label="Experience tabs"
				class="flex md:flex-col gap-3 overflow-x-auto md:overflow-visible bg-neutral-100 dark:bg-neutral-900 p-4 rounded-2xl"
			>
				{
					EXPERIENCE.map((exp, idx) => (
						<button
							role="tab"
							id={`exp-tab-${idx}`}
							aria-controls={`exp-panel-${idx}`}
							aria-selected={idx === 0 ? 'true' : 'false'}
							tabindex={idx === 0 ? 0 : -1}
							data-index={idx}
							class="relative px-4 py-3 rounded-lg text-left whitespace-nowrap md:whitespace-normal data-[active=true]:border-l-4 text-neutral-600 dark:text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-800 transition-colors duration-200 data-[active=true]:bg-neutral-200 dark:data-[active=true]:bg-neutral-800 data-[active=true]:text-neutral-900 dark:data-[active=true]:text-neutral-50 data-[active=true]:border-l-primary-500"
						>
							<div class="absolute left-0 top-0 bottom-0 w-1 bg-primary-500 rounded-l-lg hidden data-[active=true]:block" />
							<div class="flex flex-col">
								<span class="font-semibold">{exp.company ?? exp.title}</span>
								{exp.company && (
									<span class="text-neutral-500 dark:text-neutral-500 text-xs md:text-sm">
										{exp.title}
									</span>
								)}
							</div>
						</button>
					))
				}
			</div>
		</div>

		<!-- Right: Detail Panel -->
		<div class="md:col-span-3 min-h-[520px]">
			{
				EXPERIENCE.map((exp, idx) => (
					<div
						role="tabpanel"
						id={`exp-panel-${idx}`}
						aria-labelledby={`exp-tab-${idx}`}
						hidden={idx !== 0}
						class="transition-all duration-300 ease-out data-[active=true]:animate-in data-[active=true]:fade-in data-[active=true]:slide-up"
						data-active={idx === 0}
					>
						<ExperienceItem {...exp} />
					</div>
				))
			}
		</div>
	</div>

	<script is:inline>
		// Basic ARIA-compliant tabs behavior
		const tablist = document.getElementById('experience-tablist');
		if (tablist) {
			const tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
			const panels = Array.from(document.querySelectorAll('[role="tabpanel"]'));

			function updatePanelAnimations(index) {
				panels.forEach((panel, i) => {
					panel.dataset.active = String(i === index);
				});
			}
			function activateTab(index, opts = { focus: false }) {
				tabs.forEach((tab, i) => {
					const selected = i === index;
					tab.setAttribute('aria-selected', String(selected));
					tab.tabIndex = selected ? 0 : -1;
					tab.dataset.active = String(selected);
					const panel = panels[i];
					if (panel) panel.hidden = !selected;
				});
				updatePanelAnimations(index);
				if (opts.focus) {
					if (typeof tabs[index]?.focus === 'function') {
						try {
							tabs[index].focus({ preventScroll: true });
						} catch {
							tabs[index].focus();
						}
					}
				}
			}

			tabs.forEach((tab, i) => {
				tab.addEventListener('click', () => activateTab(i, { focus: false }));
				tab.addEventListener('keydown', e => {
					const key = e.key;
					let next = i;
					if (key === 'ArrowDown' || key === 'ArrowRight') next = (i + 1) % tabs.length;
					else if (key === 'ArrowUp' || key === 'ArrowLeft')
						next = (i - 1 + tabs.length) % tabs.length;
					else if (key === 'Home') next = 0;
					else if (key === 'End') next = tabs.length - 1;
					else if (key === 'Enter' || key === ' ') activateTab(i, { focus: true });
					if (
						next !== i &&
						['ArrowDown', 'ArrowRight', 'ArrowUp', 'ArrowLeft', 'Home', 'End'].includes(
							key
						)
					) {
						e.preventDefault();
						tabs[next].focus({ preventScroll: true });
					}
				});
			});
			// Set initial active state without focusing (prevents scroll jump)
			activateTab(0, { focus: false });
			updatePanelAnimations(0);
		}
	</script>
</section>
