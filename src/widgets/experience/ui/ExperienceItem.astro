---
import ArrowRightIcon from '@assets/icons/ArrowRight.astro';
import type { ExperienceItem as ExperienceItemData } from '@entities/experience';
import { createScopedUiTranslator, getLanguageFromLocale } from '@shared/config/i18n';
import { LinkInline } from '@shared/ui';

type Props = Pick<
	ExperienceItemData,
	'title' | 'date' | 'description' | 'technologies' | 'link' | 'company'
>;

const { title, date, description, technologies, link, company } = Astro.props;
const lang = getLanguageFromLocale(Astro.currentLocale);
const tExperience = createScopedUiTranslator(lang, 'sections.experience');
---

<div
	class="flex flex-col gap-5 p-6 rounded-none bg-surface border-2 border-edge-strong text-content shadow-[4px_4px_0px_0px_var(--color-primary-500)] transition-all duration-100"
>
	<div class="space-y-1">
		<h3
			class="text-content-strong font-bold text-2xl sm:text-3xl tracking-wide font-pixel-clean"
		>
			{title}
		</h3>
		<div
			class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm sm:text-base font-bold font-gaming-mono uppercase tracking-wider"
		>
			{
				company && (
					<>
						<span class="text-primary-500 dark:text-primary-400">{company}</span>
						<span class="text-content-muted">·</span>
					</>
				)
			}
			<span class="text-content-muted">{date}</span>
		</div>
	</div>

	<ul class="space-y-3 text-content leading-relaxed">
		{
			description.map((point, idx) => (
				<li
					class="flex items-start gap-2.5 text-base transition-all duration-300"
					style={`animation: var(--animate-slide-up); animation-delay: ${idx * 50}ms;`}
				>
					<ArrowRightIcon
						class="size-3.5 text-primary-500 shrink-0 mt-1.5"
						aria-hidden="true"
						focusable="false"
					/>
					<span class="leading-relaxed">{point}</span>
				</li>
			))
		}
	</ul>

	{
		technologies.length > 0 && (
			<div
				class="flex flex-wrap gap-2 pt-2 justify-start"
				style="animation: var(--animate-slide-up); animation-delay: 150ms;"
			>
				{technologies.map(tech => (
					<span class="px-3 py-1.5 rounded-none bg-badge-brand-bg text-badge-brand-text text-sm font-bold uppercase tracking-wider border-2 border-black dark:border-white shadow-retro-sm hover:-translate-y-0.5 hover:bg-badge-brand-bg-hover transition-all duration-100">
						{tech}
					</span>
				))}
			</div>
		)
	}

	{
		link && (
			<div class="pt-3 flex items-center gap-1">
				<LinkInline href={link}>
					{tExperience('learnMore')}
					<ArrowRightIcon class="size-4 ml-1" aria-hidden="true" focusable="false" />
				</LinkInline>
			</div>
		)
	}
</div>
