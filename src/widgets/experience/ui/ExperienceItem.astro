---
import { LinkInline } from '@shared/ui';
import { getLangFromUrl, useTranslations } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

interface Props {
	title: string;
	date: string;
	description: string | string[];
	technologies: string | string[];
	link?: string;
	company?: string;
}
const { title, date, description, technologies, link, company } = Astro.props;
const descriptionItems = Array.isArray(description) ? description : [description];
const technologyItems = Array.isArray(technologies) ? technologies : [technologies];

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);
---

<div
	class="flex flex-col gap-5 p-6 rounded-none bg-surface border-2 border-border-strong text-text-body shadow-[4px_4px_0px_0px_var(--color-primary-500)] transition-all duration-100"
>
	<div class="space-y-1">
		<h3 class="text-text-main font-bold text-2xl sm:text-3xl tracking-wide font-pixel-clean">
			{title}
		</h3>
		<div
			class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm sm:text-base font-bold font-gaming-mono uppercase tracking-wider"
		>
			{
				company && (
					<>
						<span class="text-primary-500 dark:text-primary-400">{company}</span>
						<span class="text-neutral-600 dark:text-neutral-400">·</span>
					</>
				)
			}
			<span class="text-neutral-600 dark:text-neutral-400">{date}</span>
		</div>
	</div>

	<!-- Bullet Points Description -->
	<ul class="space-y-3 text-neutral-700 dark:text-neutral-300 leading-relaxed">
		{
			descriptionItems.map((point, idx) => (
				<li
					class="flex items-start gap-2.5 text-base transition-all duration-300"
					style={`animation: var(--animate-slide-up); animation-delay: ${idx * 50}ms;`}
				>
					<span class="text-primary-500 shrink-0 mt-1.5 text-xs font-bold font-gaming-mono">
						▸
					</span>
					<span class="leading-relaxed">{point}</span>
				</li>
			))
		}
	</ul>

	<!-- Technologies Tags -->
	{
		technologyItems && technologyItems.length > 0 && (
			<div
				class="flex flex-wrap gap-2 pt-2 justify-start"
				style="animation: var(--animate-slide-up); animation-delay: 150ms;"
			>
				{technologyItems.map(tech => (
					<span class="px-3 py-1.5 rounded-none bg-primary-500/10 text-primary-600 dark:text-primary-400 text-sm font-bold uppercase tracking-wider border-2 border-black dark:border-white shadow-[1.5px_1.5px_0px_0px_var(--color-border-strong)] hover:-translate-y-0.5 hover:bg-primary-500/20 transition-all duration-100">
						{tech}
					</span>
				))}
			</div>
		)
	}

	{
		link && (
			<div class="pt-3 flex items-center gap-1">
				<LinkInline href={link}>
					{t('experience.learn-more')}
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="w-4 h-4 ml-1"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke="currentColor"
						fill="none"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path stroke="none" d="M0 0h24v24H0z" fill="none" />
						<path d="M9 6l6 6l-6 6" />
					</svg>
				</LinkInline>
			</div>
		)
	}
</div>
