---
import { LinkInline } from '@shared/ui';
import { getLangFromUrl, useTranslations } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

interface Props {
	title: string;
	date: string;
	description: string[];
	technologies: string[];
	link?: string;
	company?: string;
}
const { title, date, description, technologies, link, company } = Astro.props;

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);
---

<div class="flex flex-col gap-5 p-6 rounded-2xl bg-neutral-800/80 border border-neutral-700/80 text-neutral-300 shadow-lg shadow-neutral-950/50 backdrop-blur-sm transition-all duration-300">
	<div class="space-y-2">
		<h3 class="text-neutral-50 font-bold text-3xl">{title}</h3>
		<time class="block text-primary-400 text-xl font-medium">{date}</time>
	</div>

	<!-- Bullet Points Description -->
	<ul class="space-y-2 list-disc list-inside text-neutral-300 leading-relaxed">
		{
			description.map((point, idx) => (
				<li class="ml-2 text-base transition-all duration-300" style={`animation: var(--animate-slide-up); animation-delay: ${idx * 50}ms;`}>
					{point}
				</li>
			))
		}
	</ul>

	<!-- Technologies Tags -->
	{
		technologies && technologies.length > 0 && (
			<div class="flex flex-wrap gap-2 pt-2 justify-start" style="animation: var(--animate-slide-up); animation-delay: 150ms;">
				{technologies.map((tech) => (
					<span class="px-3 py-1.5 rounded-full bg-primary-500/15 text-primary-300 text-sm font-medium border border-primary-500/40 hover:border-primary-400/60 hover:bg-primary-500/25 transition-all duration-300">
						{tech}
					</span>
				))}
			</div>
		)
	}

	{
		link && (
			<div class="pt-3 flex items-center gap-1">
				<LinkInline href={link}>
					{t('experience.learn-more')}
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="w-4 h-4 ml-1"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke="currentColor"
						fill="none"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path stroke="none" d="M0 0h24v24H0z" fill="none" />
						<path d="M9 6l6 6l-6 6" />
					</svg>
				</LinkInline>
			</div>
		)
	}
</div>
