---
import { getLangFromUrl, getLocalizedPath, useTranslations } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);
---

<div
	class="w-full min-h-[calc(100dvh-4.5rem)] hero-gradient flex flex-col items-center justify-start md:justify-center py-8 md:py-0 px-4"
>
	<div class="w-full max-w-5xl flex flex-col items-center gap-10">
		<!-- Top header banner -->
		<div
			class="w-full text-center border-2 border-dashed border-primary-500/60 p-3 font-retro-tag text-xs sm:text-sm text-primary-400 tracking-widest uppercase animate-pulse"
		>
			{t('hero.banner')}
		</div>

		<!-- Title Name -->
		<div class="text-center space-y-2">
			<span
				class="font-retro-tag text-[10px] sm:text-xs uppercase tracking-widest text-primary-500 font-bold block"
				style="animation: var(--animate-fade-in); animation-delay: 0ms;"
			>
				{t('hero.title')}
			</span>
			<h1
				class="text-4xl sm:text-6xl lg:text-7xl text-center text-neutral-900 dark:text-white font-pixel tracking-wider leading-none uppercase"
				style="animation: var(--animate-fade-in); animation-delay: 100ms; text-shadow: 5px 5px 0px var(--color-primary-500);"
			>
				David Sandoval
			</h1>
			<p
				class="text-sm sm:text-base text-text-muted font-gaming-mono tracking-wide max-w-xl mx-auto"
				style="animation: var(--animate-fade-in); animation-delay: 150ms;"
			>
				{t('hero.subtitle')}
			</p>
			<p
				class="text-xs sm:text-sm text-primary-500 font-gaming-mono tracking-wide"
				style="animation: var(--animate-fade-in); animation-delay: 200ms;"
			>
				{t('hero.credential')}
			</p>
		</div>

		<!-- Character Select Dashboard (Enlarged) -->
		<div
			class="w-full grid grid-cols-1 md:grid-cols-3 border-2 border-black dark:border-white bg-surface shadow-[8px_8px_0px_0px_var(--color-border-strong)] rounded-none overflow-hidden font-mono mt-2"
		>
			<!-- Column 1: Avatar Portrait (Enlarged) -->
			<div
				class="flex flex-col items-center justify-center p-8 border-b-2 md:border-b-0 md:border-r-2 border-black dark:border-white bg-neutral-100/50 dark:bg-black/20 shrink-0"
			>
				<div
					class="relative w-48 h-48 md:w-56 md:h-56 border-2 border-black dark:border-white shadow-[4px_4px_0px_var(--color-border-strong)] overflow-hidden bg-black"
				>
					<img
						src="/profile/perfil.webp"
						alt="David Sandoval character sprite"
						class="w-full h-full object-cover aspect-square"
					/>
					<div
						class="absolute bottom-0 inset-x-0 bg-primary-500 text-white dark:text-black text-[10px] font-pixel text-center py-1.5 uppercase tracking-widest"
					>
						{t('hero.stats.player')}
					</div>
				</div>
				<span
					class="font-retro-tag text-[10px] text-text-muted mt-4 uppercase tracking-wider"
					>{t('hero.stats.level')}</span
				>
			</div>

			<!-- Column 2 & 3: Stats Details (Enlarged) -->
			<div class="col-span-2 p-8 md:p-10 flex flex-col justify-between gap-6 bg-surface">
				<div
					class="w-full border-b-2 border-dashed border-border-subtle pb-3 flex justify-between items-center"
				>
					<span
						class="font-pixel-clean text-3xl md:text-4xl font-bold uppercase tracking-wider text-text-main"
					>
						{t('hero.stats.characterStats')}
					</span>
					<span
						class="font-retro-tag text-[10px] bg-success-500 text-black px-2.5 py-1 font-bold animate-pulse uppercase"
					>
						{t('hero.stats.online')}
					</span>
				</div>

				<div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 text-base">
					<div class="flex justify-between border-b border-border-subtle pb-1.5">
						<span class="text-text-muted font-bold uppercase tracking-wide"
							>{t('hero.stats.class')}</span
						>
						<span class="text-text-main font-semibold"
							>{t('hero.stats.systemsArchitect')}</span
						>
					</div>
					<div class="flex justify-between border-b border-border-subtle pb-1.5">
						<span class="text-text-muted font-bold uppercase tracking-wide"
							>{t('hero.stats.alignment')}</span
						>
						<span class="text-text-main font-semibold">{t('hero.stats.cleanCode')}</span
						>
					</div>
					<div class="flex justify-between border-b border-border-subtle pb-1.5">
						<span class="text-text-muted font-bold uppercase tracking-wide"
							>{t('hero.stats.specialties')}</span
						>
						<span class="text-text-main font-semibold">{t('hero.stats.techStack')}</span
						>
					</div>
					<div class="flex justify-between border-b border-border-subtle pb-1.5">
						<span class="text-text-muted font-bold uppercase tracking-wide"
							>{t('hero.stats.loc')}</span
						>
						<span class="text-text-main font-semibold">{t('hero.stats.location')}</span>
					</div>
					<div class="flex justify-between border-b border-border-subtle pb-1.5">
						<span class="text-text-muted font-bold uppercase tracking-wide"
							>{t('hero.stats.hpMana')}</span
						>
						<span class="text-primary-500 font-bold">{t('hero.stats.hpValue')}</span>
					</div>
					<div class="flex justify-between border-b border-border-subtle pb-1.5">
						<span class="text-text-muted font-bold uppercase tracking-wide"
							>{t('hero.stats.skillLevel')}</span
						>
						<span class="text-text-main font-semibold">{t('hero.stats.lvlValue')}</span>
					</div>
				</div>

				<!-- Stats Progress Bar -->
				<div class="space-y-2">
					<div
						class="flex justify-between text-xs font-bold uppercase tracking-wider text-text-muted"
					>
						<span>{t('hero.stats.expPoints')}</span>
						<span>{t('hero.stats.expComplete')}</span>
					</div>
					<div
						class="w-full h-5 border-2 border-black dark:border-white bg-black/10 dark:bg-black/30 p-0.5"
					>
						<div class="h-full bg-primary-500 w-full animate-pulse"></div>
					</div>
				</div>
			</div>
		</div>

		<!-- CTA Arcade Button -->
		<div class="mt-4">
			<a
				href={getLocalizedPath(lang, '/#experience')}
				class="inline-flex items-center justify-center rounded-none bg-primary-500 text-white dark:text-black border-2 border-black dark:border-white text-base sm:text-lg px-9 py-4.5 font-bold uppercase tracking-wider transition-all duration-100 shadow-[4px_4px_0px_0px_var(--color-border-strong)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[6px_6px_0px_0px_var(--color-border-strong)] active:translate-x-[1px] active:translate-y-[1px] active:shadow-[1px_1px_0px_0px_var(--color-border-strong)]"
			>
				{t('hero.cta.start')}
			</a>
		</div>
	</div>
</div>
