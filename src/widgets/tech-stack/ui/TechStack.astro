---
import { TAGS } from '@entities/technology';
import { TechPill } from '@shared/ui';

/**
 * TechStack Widget - Infinite scrolling carousel of technologies
 * Displays key technologies used in the portfolio with smooth animation
 */

// Select main technologies for the carousel
const selectedTechs = [
	TAGS.TYPESCRIPT,
	TAGS.ANGULAR,
	TAGS.RXJS,
	TAGS.NEXTJS,
	TAGS.REACT,
	TAGS.ASTRO,
	TAGS.TAILWIND,
	TAGS.PYTHON,
	TAGS.DJANGO,
	TAGS.POSTGRESQL,
	TAGS.MYSQL,
	TAGS.EXPRESS,
	TAGS.JAVASCRIPT,
	TAGS.CLOUDINARY,
	TAGS.SANITY,
	TAGS.CHARTJS,
	TAGS.BOOTSTRAP,
];

// For mobile: show only first 6 technologies in a clean grid
const mobileTechs = selectedTechs.slice(0, 6);
const duplicatedTechs = [...selectedTechs, ...selectedTechs];
---

<div class="font-sans w-full overflow-hidden py-6 md:py-8">
	<!-- Mobile: Static grid with 6 technologies -->
	<div class="md:hidden grid grid-cols-2 gap-3 max-w-sm mx-auto">
		{
			mobileTechs.map(tech => (
				<TechPill label={tech.name} icon={tech.icon} size="sm" variant="stack" />
			))
		}
	</div>

	<!-- Desktop: Infinite scrolling carousel -->
	<div class="hidden md:flex relative w-full justify-center items-center">
		<div
			class="flex gap-3 md:gap-4 animate-scroll-infinite will-change-transform"
			style="width: fit-content;"
		>
			{
				duplicatedTechs.map(tech => (
					<TechPill label={tech.name} icon={tech.icon} variant="stack" />
				))
			}
		</div>
	</div>
</div>

<style>
	@keyframes scrollInfinite {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	@layer utilities {
		.animate-scroll-infinite {
			animation: scrollInfinite 40s linear infinite;
		}

		.animate-scroll-infinite:hover {
			animation-play-state: paused;
		}
	}
</style>
