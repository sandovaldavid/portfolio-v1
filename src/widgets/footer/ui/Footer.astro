---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@shared/lib/i18n';
import { siteConfig } from '@shared/config/site.config';
import MailIcon from '@assets/icons/Mail.astro';
import LinkedInIcon from '@assets/social-networks/LinkedIn.astro';
import GitHubIcon from '@assets/technologies/GitHub.astro';
import LinkHubIcon from '@assets/social-networks/LinkHub.astro';
import CodeIcon from '@assets/icons/Code.astro';

const lang = getLangFromUrl(new URL(Astro.request.url));
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();

const socialLinks = [
	{
		name: 'GitHub',
		href: siteConfig.social.github,
		icon: GitHubIcon,
	},
	{
		name: 'LinkedIn',
		href: siteConfig.social.linkedin,
		icon: LinkedInIcon,
	},
	{
		name: 'Email',
		href: `mailto:${siteConfig.email}`,
		icon: MailIcon,
	},
	{
		name: 'Link Hub',
		href: siteConfig.social.linkHub,
		icon: LinkHubIcon,
	},
];
---

<footer
	class="mt-28 px-4 sm:px-6 lg:px-8 pb-8 w-full border-t-2 border-edge-strong pt-20"
	id="contact"
>
	<!-- CTA Section -->
	<div class="text-center space-y-4 mb-10 max-w-2xl mx-auto">
		<h2
			class="text-4xl sm:text-5xl md:text-6xl font-bold font-pixel-clean uppercase tracking-wider text-content-strong"
		>
			{t('footer.title')}
		</h2>
		<p class="text-xs sm:text-sm font-mono uppercase text-content-muted tracking-wide">
			{t('footer.subtitle')}
		</p>
		<div class="pt-4">
			<a
				href={`mailto:${siteConfig.email}`}
				class="inline-flex items-center gap-2 px-8 py-4 bg-primary-500 text-white dark:text-black border-2 border-black dark:border-white font-mono text-sm font-bold uppercase tracking-wider shadow-[3px_3px_0px_var(--color-primary-500)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[5px_5px_0px_var(--color-primary-500)] active:translate-x-[1px] active:translate-y-[1px] active:shadow-none transition-all duration-100"
			>
				<MailIcon class="w-5 h-5" />
				{t('footer.cta')}
			</a>
		</div>
	</div>

	<!-- Social Links -->
	<div class="flex justify-center gap-4 sm:gap-5 mb-14 flex-wrap">
		{
			socialLinks.map(({ name, href, icon: Icon }) => (
				<a
					href={href}
					target="_blank"
					rel="noopener noreferrer"
					title={name}
					class="flex items-center justify-center p-3.5 bg-surface border-2 border-black dark:border-white text-content-strong shadow-[2.5px_2.5px_0px_var(--color-primary-500)] hover:-translate-x-[1.5px] hover:-translate-y-[1.5px] hover:shadow-[4px_4px_0px_var(--color-primary-500)] active:translate-x-[1px] active:translate-y-[1px] active:shadow-none transition-all duration-100"
				>
					<Icon class="w-6 h-6" />
				</a>
			))
		}
	</div>

	<!-- Bottom Bar -->
	<div
		class="flex flex-col md:flex-row items-center justify-between gap-4 pt-6 sm:pt-8 px-4 sm:px-8 border-t border-neutral-300 dark:border-neutral-800 font-mono text-xs sm:text-sm text-neutral-600 dark:text-neutral-400 text-center md:text-left"
	>
		<p>© {currentYear} {siteConfig.fullName}. {t('footer.rights')}.</p>
		<p class="flex items-center gap-2">
			{t('footer.built-with')}
			<CodeIcon class="w-4 h-4 text-primary-500" />
			<span class="text-neutral-600 dark:text-neutral-400">v2.0.0</span>
			<span aria-hidden="true">·</span>
			<a
				href={getLocalizedPath(lang, '/devlog')}
				class="underline decoration-dotted underline-offset-2 hover:text-primary-500 transition-colors"
			>
				{t('nav.devlog')}
			</a>
		</p>
	</div>
</footer>
