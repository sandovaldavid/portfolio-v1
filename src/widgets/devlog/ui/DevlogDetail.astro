---
import ArrowLeftIcon from '@assets/icons/ArrowLeft.astro';
import type { DevlogPost } from '@entities/devlog';
import { LinkInline } from '@shared/ui';

interface Props {
	post: DevlogPost;
	backText: string;
	backLink: string;
}

const { post, backText, backLink } = Astro.props;
---

<article class="mx-auto max-w-3xl">
	<header class="mb-10">
		<LinkInline href={backLink} class="mb-6 inline-flex items-center gap-2 text-sm">
			<ArrowLeftIcon class="size-4" />
			{backText}
		</LinkInline>

		<div
			class="mb-3 flex items-center gap-2 font-mono text-xs text-neutral-500 dark:text-neutral-400"
		>
			<time datetime={post.date}>[{post.date}]</time>
			<span
				class="font-retro-tag text-[10px] font-bold uppercase tracking-wider text-primary-500 dark:text-primary-400"
			>
				{post.version}
			</span>
			{
				post.tags.map(tag => (
					<span class="rounded-none border border-primary-500/40 bg-primary-500/10 px-2 py-0.5 font-retro-tag text-[9px] font-bold uppercase tracking-wider text-primary-600 dark:text-primary-400">
						{tag}
					</span>
				))
			}
		</div>

		<h1 class="mb-4 text-3xl font-bold font-pixel-clean tracking-wide md:text-4xl">
			{post.title}
		</h1>
		<p class="max-w-2xl text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
			{post.summary}
		</p>
	</header>

	<div class="prose prose-neutral dark:prose-invert max-w-none">
		<div class="whitespace-pre-wrap text-sm leading-relaxed">{post.content}</div>
	</div>
</article>
