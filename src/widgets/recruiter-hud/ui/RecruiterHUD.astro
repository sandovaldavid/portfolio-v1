---
import { getLangFromUrl } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';
import { siteConfig } from '@shared/config/site.config';
import { LanguagePicker } from '@features/language-picker';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const resumeUrl = langCode === 'en' ? siteConfig.resume.en : siteConfig.resume.es;

const copy =
	langCode === 'en'
		? {
				toggle: 'Recruiter links',
				title: 'RECRUITER QUICK LINKS',
				summary: 'Software Engineer focused on Angular, .NET and TypeScript.',
				availability: 'Available for remote opportunities across Europe and Latin America.',
				email: 'Send email',
				resume: 'Download resume',
				close: 'Close recruiter links',
				language: 'Language',
			}
		: {
				toggle: 'Enlaces para reclutadores',
				title: 'ENLACES PARA RECLUTADORES',
				summary: 'Ingeniero de software enfocado en Angular, .NET y TypeScript.',
				availability: 'Disponible para oportunidades remotas en Europa y Latinoamérica.',
				email: 'Enviar correo',
				resume: 'Descargar CV',
				close: 'Cerrar enlaces para reclutadores',
				language: 'Idioma',
			};
---

<div id="recruiter-hud" class="fixed bottom-5 right-5 z-50 font-mono">
	<button
		id="recruiter-hud-toggle"
		type="button"
		class="flex items-center gap-2 px-4 py-3 bg-primary-500 hover:bg-primary-400 text-white dark:text-black border-2 border-black dark:border-white font-bold uppercase tracking-wider shadow-retro-md hover:shadow-retro-lg cursor-pointer"
		aria-label={copy.toggle}
		aria-controls="recruiter-hud-panel"
		aria-expanded="false"
	>
		<span aria-hidden="true">[ CV ]</span>
		<span class="sr-only sm:not-sr-only">{copy.toggle}</span>
	</button>

	<div
		id="recruiter-hud-panel"
		class="absolute bottom-16 right-0 w-[min(22rem,calc(100vw-2.5rem))] bg-surface border-2 border-black dark:border-white p-5 shadow-retro-2xl hidden flex-col gap-4"
		role="dialog"
		aria-modal="false"
		aria-labelledby="recruiter-hud-title"
	>
		<div
			class="flex items-start justify-between gap-4 border-b-2 border-dashed border-edge-subtle pb-3"
		>
			<div>
				<h2
					id="recruiter-hud-title"
					class="font-pixel-clean text-xl font-bold text-primary-500"
				>
					{copy.title}
				</h2>
				<p class="mt-2 text-sm text-content-strong">{copy.summary}</p>
			</div>
			<button
				id="recruiter-hud-close"
				type="button"
				class="px-2 py-1 border border-black dark:border-white font-bold cursor-pointer"
				aria-label={copy.close}
			>
				×
			</button>
		</div>

		<p class="text-sm text-content-muted">{copy.availability}</p>

		<div class="grid gap-2">
			<a
				href={`mailto:${siteConfig.email}?subject=${encodeURIComponent(siteConfig.emailSubjectRecruiter)}`}
				class="w-full text-center px-4 py-2 bg-primary-500 text-white dark:text-black font-bold uppercase tracking-wider border-2 border-black dark:border-white shadow-retro-sm"
			>
				{copy.email}
			</a>
			<a
				href={resumeUrl}
				target="_blank"
				rel="noreferrer"
				class="w-full text-center px-4 py-2 bg-surface text-content-strong font-bold uppercase tracking-wider border-2 border-black dark:border-white shadow-retro-sm"
			>
				{copy.resume}
			</a>
			<div class="grid grid-cols-2 gap-2">
				<a
					href={siteConfig.social.github}
					target="_blank"
					rel="noreferrer"
					class="text-center px-3 py-2 border-2 border-black dark:border-white font-bold uppercase"
				>
					GitHub
				</a>
				<a
					href={siteConfig.social.linkedin}
					target="_blank"
					rel="noreferrer"
					class="text-center px-3 py-2 border-2 border-black dark:border-white font-bold uppercase"
				>
					LinkedIn
				</a>
			</div>
		</div>

		<div class="flex items-center justify-between gap-3 border-t border-edge-subtle pt-3">
			<span class="text-xs font-bold text-content-muted uppercase tracking-widest">
				{copy.language}
			</span>
			<LanguagePicker currentLang={lang} />
		</div>
	</div>
</div>

<script data-astro-rerun>
	(function () {
		const root = document.getElementById('recruiter-hud');
		if (!root || root.dataset.bound === 'true') return;
		root.dataset.bound = 'true';

		const toggle = root.querySelector('#recruiter-hud-toggle');
		const close = root.querySelector('#recruiter-hud-close');
		const panel = root.querySelector('#recruiter-hud-panel');

		if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

		const setOpen = open => {
			panel.classList.toggle('hidden', !open);
			panel.classList.toggle('flex', open);
			toggle.setAttribute('aria-expanded', String(open));
			if (open) {
				const firstLink = panel.querySelector('a, button');
				if (firstLink instanceof HTMLElement) firstLink.focus();
			}
		};

		toggle.addEventListener('click', () => {
			setOpen(toggle.getAttribute('aria-expanded') !== 'true');
		});

		close?.addEventListener('click', () => {
			setOpen(false);
			toggle.focus();
		});

		root.addEventListener('keydown', event => {
			if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
				setOpen(false);
				toggle.focus();
			}
		});
	})();
</script>
