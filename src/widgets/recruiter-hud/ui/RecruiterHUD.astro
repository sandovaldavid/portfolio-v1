	/* Animación para el texto flotante de copiar */
	@keyframes float-up-fade {
		0% {
			transform: translate(-50%, 0);
			opacity: 1;
		}
		100% {
			transform: translate(-50%, -30px);
			opacity: 0;
		}
	}
</style>
