---
import ArrowLeftIcon from '@assets/icons/ArrowLeft.astro';
import ArrowRightIcon from '@assets/icons/ArrowRight.astro';
import BrainIcon from '@assets/icons/Brain.astro';
import { getResearchContent } from '@entities/research';
import { createScopedUiTranslator, Language } from '@shared/config/i18n';
import { siteConfig } from '@shared/config/site.config';

interface Props {
	lang: Language;
	backHref?: string;
}

const { lang, backHref = '/#research' } = Astro.props;
const research = await getResearchContent(lang);
const tPage = createScopedUiTranslator(lang, 'pages.research');

const labels = {
	problem: tPage('problemLabel'),
	hypothesis: tPage('hypothesisLabel'),
	approach: tPage('approachLabel'),
	dataset: tPage('datasetLabel'),
	metrics: tPage('metricsLabel'),
	architecture: tPage('architectureLabel'),
	pipeline: tPage('pipelineLabel'),
	keywords: tPage('keywordsLabel'),
	status: tPage('statusLabel'),
	contact: tPage('contactLabel'),
	engineeredFeatures: tPage('engineeredFeaturesLabel'),
};

const metrics = [
	{ prefix: 'ACC', text: research.metrics.accuracy },
	{ prefix: 'F1', text: research.metrics.f1 },
	{ prefix: 'AUC', text: research.metrics.auc },
	{ prefix: 'LOSS', text: research.metrics.loss },
];
---

<div class="w-full max-w-5xl mx-auto px-4 font-mono">
	<a
		href={backHref}
		class="inline-flex items-center gap-2 mb-8 text-xs font-bold uppercase tracking-wider text-content-muted hover:text-primary-500 transition-colors group"
	>
		<ArrowLeftIcon
			class="size-4 group-hover:-translate-x-1 transition-transform"
			aria-hidden="true"
			focusable="false"
		/>
		{tPage('backButton')}
	</a>

	<div
		class="border-2 border-black dark:border-white bg-primary-500 px-6 py-5 mb-8 shadow-retro-2xl"
	>
		<div class="flex items-start gap-4">
			<BrainIcon class="w-8 h-8 text-white dark:text-black shrink-0 mt-1" />
			<div class="flex-1">
				<p
					class="font-gaming-mono text-sm uppercase tracking-wider text-white dark:text-black/90 mb-1 font-bold"
				>
					{research.institution} · {research.label}
				</p>
				<h1
					class="font-pixel-clean text-xl sm:text-3xl font-bold text-white dark:text-black uppercase leading-snug"
				>
					{research.title}
				</h1>
			</div>
			<span
				class="shrink-0 font-gaming-mono text-xs bg-white dark:bg-black text-primary-600 dark:text-primary-400 px-2.5 py-1 font-bold uppercase tracking-wider animate-pulse whitespace-nowrap self-start"
			>
				{research.status}
			</span>
		</div>
	</div>

	<div class="grid grid-cols-1 lg:grid-cols-5 gap-6 items-start">
		<div class="lg:col-span-3 flex flex-col gap-6">
			<div class="border-2 border-edge-subtle bg-surface p-5">
				<h2
					class="font-gaming-mono text-xl sm:text-2xl font-bold text-primary-500 uppercase tracking-wider mb-3"
				>
					▸ {labels.problem}
				</h2>
				<p class="text-base leading-relaxed text-content-strong">
					{research.problem}
				</p>
			</div>

			<div class="border-2 border-primary-500/40 bg-primary-500/5 p-5">
				<h2
					class="font-gaming-mono text-xl sm:text-2xl font-bold text-primary-500 uppercase tracking-wider mb-3"
				>
					▸ {labels.hypothesis}
				</h2>
				<p class="text-base leading-relaxed italic text-content-strong">
					“{research.hypothesis}”
				</p>
			</div>

			<div class="border-2 border-edge-subtle bg-surface p-5">
				<h2
					class="font-gaming-mono text-xl sm:text-2xl font-bold text-primary-500 uppercase tracking-wider mb-3"
				>
					▸ {labels.approach}
				</h2>
				<p class="text-base leading-relaxed text-content-strong mb-4">
					{research.approach}
				</p>

				<div class="mt-4">
					<p
						class="font-gaming-mono text-sm text-content-muted uppercase tracking-wider mb-2 font-bold"
					>
						{labels.pipeline}
					</p>
					<div class="flex flex-wrap items-center gap-1">
						{
							research.pipelineSteps.map((step, index) => (
								<>
									<span class="font-gaming-mono text-xs sm:text-sm uppercase border border-primary-500/50 text-primary-500 px-2.5 py-1.5 bg-primary-500/5 font-bold">
										{step}
									</span>
									{index < research.pipelineSteps.length - 1 && (
										<span
											class="text-primary-500 font-bold text-xs"
											aria-hidden="true"
										>
											→
										</span>
									)}
								</>
							))
						}
					</div>
				</div>
			</div>

			<div class="border-2 border-edge-subtle bg-surface p-5">
				<h2
					class="font-gaming-mono text-xl sm:text-2xl font-bold text-primary-500 uppercase tracking-wider mb-3"
				>
					▸ {labels.engineeredFeatures}
				</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
					{
						research.engineeredFeatures.map((feature, index) => (
							<div class="flex items-start gap-2 text-sm text-content-strong">
								<span class="font-pixel-clean text-xs font-bold bg-primary-500/20 text-primary-600 dark:text-primary-400 px-1.5 py-0.5 shrink-0 mt-0.5 min-w-[28px] text-center">
									F{String(index + 1).padStart(2, '0')}
								</span>
								<span class="leading-snug">{feature}</span>
							</div>
						))
					}
				</div>
			</div>

			<div class="border-2 border-edge-subtle bg-surface p-5">
				<h2
					class="font-gaming-mono text-xl sm:text-2xl font-bold text-primary-500 uppercase tracking-wider mb-3"
				>
					▸ {labels.dataset}
				</h2>
				<p class="text-base leading-relaxed text-content-strong">
					{research.dataset}
				</p>
			</div>
		</div>

		<div class="lg:col-span-2 flex flex-col gap-6">
			<div class="border-2 border-edge-subtle bg-surface p-5">
				<h2
					class="font-gaming-mono text-xl sm:text-2xl font-bold text-primary-500 uppercase tracking-wider mb-3"
				>
					▸ {labels.architecture}
				</h2>
				<div class="flex flex-col gap-2">
					{
						research.architecture.map(item => (
							<div class="border border-edge-subtle p-2.5 text-sm flex justify-between items-start gap-4">
								<span class="font-bold text-primary-500 uppercase tracking-wider shrink-0 text-xs sm:text-sm font-gaming-mono">
									{item.label}
								</span>
								<span class="text-content-strong leading-snug text-right">
									{item.value}
								</span>
							</div>
						))
					}
				</div>
			</div>

			<div class="border-2 border-edge-subtle bg-surface p-5">
				<h2
					class="font-gaming-mono text-xl sm:text-2xl font-bold text-primary-500 uppercase tracking-wider mb-3"
				>
					▸ {labels.metrics}
				</h2>
				<div class="flex flex-col gap-2">
					{
						metrics.map(({ prefix, text }) => (
							<div class="flex items-start gap-2">
								<span class="shrink-0 font-pixel-clean text-sm font-bold bg-primary-500 text-white dark:text-black px-2 py-1 mt-0.5 uppercase min-w-[36px] text-center">
									{prefix}
								</span>
								<span class="text-sm text-content-strong leading-snug">{text}</span>
							</div>
						))
					}
				</div>
			</div>

			<div class="border-2 border-status-success-border bg-status-success-bg p-5">
				<h2
					class="font-gaming-mono text-xl sm:text-2xl font-bold text-status-success-text uppercase tracking-wider mb-3"
				>
					▸ {labels.status}
				</h2>
				<div class="flex items-center gap-2 mb-2">
					<span class="w-2.5 h-2.5 bg-emerald-500 animate-pulse rounded-none shrink-0"
					></span>
					<span
						class="font-gaming-mono text-xs sm:text-sm font-bold text-status-success-text uppercase"
					>
						{research.status}
					</span>
				</div>
				<p class="text-base text-content-muted leading-relaxed">
					{research.currentStatus}
				</p>
			</div>

			<div class="border-2 border-edge-subtle bg-surface p-5">
				<h2
					class="font-gaming-mono text-xl sm:text-2xl font-bold text-content-muted uppercase tracking-wider mb-3"
				>
					{labels.keywords}
				</h2>
				<div class="flex flex-wrap gap-1.5">
					{
						research.keywords.map(keyword => (
							<span class="font-gaming-mono text-xs sm:text-sm uppercase border border-badge-brand-outline-border text-badge-brand-text px-2 py-0.5 hover:bg-badge-brand-outline-bg-hover transition-colors cursor-default font-bold">
								{keyword}
							</span>
						))
					}
				</div>
			</div>
		</div>
	</div>

	<div
		class="border-2 border-black dark:border-white bg-primary-500 px-6 py-4 mt-8 shadow-retro-2xl"
	>
		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
			<div class="flex items-center gap-3 flex-1 min-w-0">
				<span
					class="shrink-0 font-gaming-mono text-lg text-white dark:text-black"
					aria-hidden="true">✉</span
				>
				<div class="flex flex-col gap-0.5 min-w-0">
					<h2
						class="font-gaming-mono text-lg sm:text-xl font-bold text-white dark:text-black/90 uppercase tracking-wider"
					>
						{labels.contact}
					</h2>
					<p class="text-sm text-white/90 dark:text-black/90 leading-snug">
						{tPage('contactCta')}
					</p>
				</div>
			</div>
			<a
				href={`mailto:${siteConfig.email}?subject=${encodeURIComponent(tPage('contactButton'))}`}
				class="shrink-0 flex items-center justify-center gap-1.5 px-5 py-2 bg-white dark:bg-black text-primary-500 dark:text-primary-400 font-gaming-mono text-xs sm:text-sm font-bold uppercase tracking-wider hover:bg-white/90 dark:hover:bg-black/90 hover:-translate-x-px hover:-translate-y-px transition-all whitespace-nowrap self-start sm:self-center"
			>
				<ArrowRightIcon class="size-4" aria-hidden="true" focusable="false" />
				{tPage('contactButton')}
			</a>
		</div>
	</div>
</div>
