---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';
import BrainIcon from '@assets/icons/Brain.astro';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);


const isEN = lang === Language.ENGLISH;

const summary = isEN
	? 'Applying Bidirectional LSTM neural networks to detect OSS repository abandonment risk from GitHub activity time series — commits, issues, PRs, and contributor patterns — and benchmarked against traditional ML baselines.'
	: 'Aplicación de redes BiLSTM para detectar el riesgo de abandono de repositorios OSS a partir de series temporales de actividad en GitHub — commits, issues, PRs y patrones de contribuidores — evaluado frente a baselines de ML tradicional.';

const techStack = ['BiLSTM', 'Deep Learning', 'MSR', 'Python', 'TensorFlow', 'GitHub API'];

---

<section class="w-full h-full flex items-center justify-center px-4 py-6">
	<article class="w-full max-w-3xl border-2 border-black dark:border-white bg-surface shadow-[6px_6px_0px_0px_var(--color-border-strong)] font-mono overflow-hidden">

		<!-- Header Bar -->
		<div class="border-b-2 border-black dark:border-white bg-primary-500 px-5 py-3.5 flex items-start justify-between gap-4">
			<div class="flex items-start gap-3">
				<BrainIcon class="w-5 h-5 text-white dark:text-black shrink-0 mt-0.5" />
				<div>
					<p class="font-retro-tag text-xs uppercase tracking-widest text-white/80 dark:text-black/70 leading-none">
						{t('research.thesis.institution')} · {t('research.thesis.label')}
					</p>
					<h3 class="font-pixel-clean text-base sm:text-lg font-bold text-white dark:text-black uppercase leading-tight mt-1">
						{t('research.thesis.title')}
					</h3>
				</div>
			</div>
			<span class="shrink-0 font-retro-tag text-[10px] bg-white dark:bg-black text-primary-600 dark:text-primary-400 px-2.5 py-1 font-bold uppercase tracking-widest animate-pulse whitespace-nowrap">
				{t('research.thesis.status')}
			</span>
		</div>

		<!-- Body -->
		<div class="px-5 py-5 space-y-5">

			<!-- Summary -->
			<p class="text-sm sm:text-base leading-relaxed text-text-main">
				{summary}
			</p>

			<!-- Tech stack -->
			<div>
				<h4 class="font-retro-tag text-xs font-bold text-primary-500 uppercase tracking-widest mb-2.5">
					▸ {isEN ? 'TECH STACK' : 'TECNOLOGÍAS'}
				</h4>
				<div class="flex flex-wrap gap-2">
					{techStack.map(tag => (
						<span class="font-retro-tag text-xs uppercase tracking-wider border-2 border-primary-500 text-primary-500 dark:text-primary-400 px-3 py-1 font-bold bg-primary-500/5">
							{tag}
						</span>
					))}
				</div>
			</div>

			<!-- CTA -->
			<div class="border-t-2 border-dashed border-border-subtle pt-4 flex items-center justify-between gap-4">
				<p class="text-xs text-text-muted leading-snug">
					{isEN
						? 'Full methodology, architecture & pipeline on the research page.'
						: 'Metodología completa, arquitectura y pipeline en la página de investigación.'}
				</p>
				<a
					href={getLocalizedPath(lang, '/research')}
					class="shrink-0 inline-flex items-center gap-2 font-retro-tag text-xs font-bold uppercase tracking-widest px-4 py-2 bg-primary-500 text-white dark:text-black border-2 border-black dark:border-white shadow-[2px_2px_0px_var(--color-border-strong)] hover:-translate-x-[1px] hover:-translate-y-[1px] hover:shadow-[3px_3px_0px_var(--color-border-strong)] active:translate-x-[1px] active:translate-y-[1px] active:shadow-none transition-all whitespace-nowrap"
				>
					{isEN ? '▸ FULL RESEARCH' : '▸ VER COMPLETO'}
				</a>
			</div>

		</div>
	</article>
</section>
