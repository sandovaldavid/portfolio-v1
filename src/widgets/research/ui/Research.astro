---
import { getLangFromUrl, useTranslations, useTranslationsList } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';
import BrainIcon from '@assets/icons/Brain.astro';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);
const tList = useTranslationsList(lang);

const keywords = tList('research.thesis.keywords') as string[];

const isEN = lang === Language.ENGLISH;
const labels = {
	problem: isEN ? 'PROBLEM STATEMENT' : 'PLANTEAMIENTO DEL PROBLEMA',
	hypothesis: isEN ? 'RESEARCH HYPOTHESIS' : 'HIPÓTESIS DE INVESTIGACIÓN',
	approach: isEN ? 'METHODOLOGY' : 'METODOLOGÍA',
	dataset: isEN ? 'DATASET' : 'CONJUNTO DE DATOS',
	metrics: isEN ? 'EVALUATION METRICS' : 'MÉTRICAS DE EVALUACIÓN',
	keywords: isEN ? 'KEYWORDS' : 'PALABRAS CLAVE',
	institution: isEN ? 'INSTITUTION' : 'INSTITUCIÓN',
};
---

<section class="w-full h-full flex items-center justify-center px-4 py-6">
	<article class="w-full max-w-4xl border-2 border-black dark:border-white bg-surface shadow-[6px_6px_0px_0px_var(--color-border-strong)] font-mono overflow-hidden">

		<!-- Header Bar -->
		<div class="border-b-2 border-black dark:border-white bg-primary-500 px-6 py-3 flex items-center justify-between gap-4">
			<div class="flex items-center gap-3">
				<BrainIcon class="w-5 h-5 text-white dark:text-black shrink-0" />
				<div>
					<p class="font-retro-tag text-[9px] uppercase tracking-widest text-white/80 dark:text-black/70 leading-none">
						{t('research.thesis.institution')} · {t('research.thesis.label')}
					</p>
					<h3 class="font-pixel-clean text-sm sm:text-base font-bold text-white dark:text-black uppercase leading-tight mt-0.5">
						{t('research.thesis.title')}
					</h3>
				</div>
			</div>
			<span class="shrink-0 font-retro-tag text-[9px] bg-white dark:bg-black text-primary-600 dark:text-primary-400 px-2 py-1 font-bold uppercase tracking-widest animate-pulse whitespace-nowrap">
				{t('research.thesis.status')}
			</span>
		</div>

		<!-- Body -->
		<div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-5">

			<!-- Problem -->
			<div class="md:col-span-2 border border-border-subtle p-4 bg-neutral-50 dark:bg-black/20">
				<h4 class="font-retro-tag text-[9px] font-bold text-primary-500 uppercase tracking-widest mb-2">
					▸ {labels.problem}
				</h4>
				<p class="text-xs sm:text-sm leading-relaxed text-text-main">
					{t('research.thesis.problem')}
				</p>
			</div>

			<!-- Hypothesis -->
			<div class="md:col-span-2 border border-primary-500/40 p-4 bg-primary-500/5">
				<h4 class="font-retro-tag text-[9px] font-bold text-primary-500 uppercase tracking-widest mb-2">
					▸ {labels.hypothesis}
				</h4>
				<p class="text-xs sm:text-sm leading-relaxed italic text-text-main">
					"{t('research.thesis.hypothesis')}"
				</p>
			</div>

			<!-- Methodology -->
			<div class="border border-border-subtle p-4 bg-neutral-50 dark:bg-black/20">
				<h4 class="font-retro-tag text-[9px] font-bold text-primary-500 uppercase tracking-widest mb-2">
					▸ {labels.approach}
				</h4>
				<p class="text-xs sm:text-sm leading-relaxed text-text-main">
					{t('research.thesis.approach')}
				</p>
			</div>

			<!-- Dataset -->
			<div class="border border-border-subtle p-4 bg-neutral-50 dark:bg-black/20">
				<h4 class="font-retro-tag text-[9px] font-bold text-primary-500 uppercase tracking-widest mb-2">
					▸ {labels.dataset}
				</h4>
				<p class="text-xs sm:text-sm leading-relaxed text-text-main">
					{t('research.thesis.dataset')}
				</p>
			</div>

			<!-- Metrics -->
			<div class="md:col-span-2 border border-border-subtle p-4 bg-neutral-50 dark:bg-black/20">
				<h4 class="font-retro-tag text-[9px] font-bold text-primary-500 uppercase tracking-widest mb-3">
					▸ {labels.metrics}
				</h4>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
					{[
						{ key: 'research.thesis.metrics.accuracy', prefix: 'ACC' },
						{ key: 'research.thesis.metrics.f1', prefix: 'F1' },
						{ key: 'research.thesis.metrics.auc', prefix: 'AUC' },
						{ key: 'research.thesis.metrics.loss', prefix: 'LOSS' },
					].map(({ key, prefix }) => (
						<div class="flex items-start gap-2">
							<span class="shrink-0 font-pixel-clean text-[9px] font-bold bg-primary-500 text-white dark:text-black px-1.5 py-0.5 mt-0.5 uppercase">
								{prefix}
							</span>
							<span class="text-xs sm:text-sm text-text-main leading-snug">
								{t(key as Parameters<typeof t>[0])}
							</span>
						</div>
					))}
				</div>
			</div>

			<!-- Keywords -->
			<div class="md:col-span-2 border-t-2 border-dashed border-border-subtle pt-4">
				<h4 class="font-retro-tag text-[9px] font-bold text-text-muted uppercase tracking-widest mb-2">
					{labels.keywords}
				</h4>
				<div class="flex flex-wrap gap-2">
					{keywords.map(keyword => (
						<span class="font-retro-tag text-[10px] uppercase tracking-wider border border-primary-500/50 text-primary-500 dark:text-primary-400 px-2.5 py-1 hover:bg-primary-500/10 transition-colors">
							{keyword}
						</span>
					))}
				</div>
			</div>

		</div>
	</article>
</section>
