---
import { getLangFromUrl, useTranslations, useTranslationsList } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';
import BrainIcon from '@assets/icons/Brain.astro';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);
const tList = useTranslationsList(lang);

const keywords = tList('research.thesis.keywords') as string[];
---

<section class="space-y-6">
	<article
		class="rounded-3xl bg-neutral-100/80 dark:bg-neutral-800/80 border border-neutral-300/80 dark:border-neutral-700/80 backdrop-blur-sm p-8 md:p-10 shadow-lg shadow-neutral-200/50 dark:shadow-neutral-950/50"
	>
		<!-- Thesis Header -->
		<div class="flex items-start gap-4 mb-6">
			<div
				class="shrink-0 w-12 h-12 rounded-xl bg-primary-500/10 dark:bg-primary-400/10 flex items-center justify-center"
			>
				<BrainIcon class="w-6 h-6 text-primary-500 dark:text-primary-400" />
			</div>
			<div class="flex-1">
				<h3 class="text-2xl font-bold text-neutral-900 dark:text-neutral-50 mb-2">
					{t('research.thesis.title')}
				</h3>
				<div
					class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-500/10 dark:bg-primary-400/10 border border-primary-500/20 dark:border-primary-400/20"
				>
					<span
						class="w-2 h-2 rounded-full bg-primary-500 dark:bg-primary-400 animate-pulse"
					></span>
					<span class="text-sm font-medium text-primary-700 dark:text-primary-300">
						{t('research.thesis.status')}
					</span>
				</div>
			</div>
		</div>

		<!-- Thesis Details -->
		<div class="space-y-5 text-neutral-700 dark:text-neutral-300">
			<!-- Problem -->
			<div>
				<h4
					class="text-sm font-semibold text-neutral-900 dark:text-neutral-50 mb-2 uppercase tracking-wide"
				>
					{lang === Language.ENGLISH ? 'Problem' : 'Problema'}
				</h4>
				<p class="text-base leading-relaxed">
					{t('research.thesis.problem')}
				</p>
			</div>

			<!-- Hypothesis -->
			<div>
				<h4
					class="text-sm font-semibold text-neutral-900 dark:text-neutral-50 mb-2 uppercase tracking-wide"
				>
					{lang === Language.ENGLISH ? 'Hypothesis' : 'Hipótesis'}
				</h4>
				<p class="text-base leading-relaxed italic">
					{t('research.thesis.hypothesis')}
				</p>
			</div>

			<!-- Dataset -->
			<div>
				<h4
					class="text-sm font-semibold text-neutral-900 dark:text-neutral-50 mb-2 uppercase tracking-wide"
				>
					Dataset
				</h4>
				<p class="text-base leading-relaxed">
					{t('research.thesis.dataset')}
				</p>
			</div>

			<!-- Evaluation -->
			<div>
				<h4
					class="text-sm font-semibold text-neutral-900 dark:text-neutral-50 mb-2 uppercase tracking-wide"
				>
					{t('research.thesis.metrics-title')}
				</h4>
				<ul class="space-y-2">
					<li class="flex items-start gap-2">
						<span
							class="shrink-0 w-1.5 h-1.5 rounded-full bg-primary-500 dark:bg-primary-400 mt-2"
						></span>
						<span class="text-base leading-relaxed"
							>{t('research.thesis.metrics.mae')}</span
						>
					</li>
					<li class="flex items-start gap-2">
						<span
							class="shrink-0 w-1.5 h-1.5 rounded-full bg-primary-500 dark:bg-primary-400 mt-2"
						></span>
						<span class="text-base leading-relaxed"
							>{t('research.thesis.metrics.loss')}</span
						>
					</li>
				</ul>
			</div>

			<!-- Keywords -->
			<div class="pt-4 border-t border-neutral-300 dark:border-neutral-700">
				<div class="flex flex-wrap gap-2">
					{
						keywords.map(keyword => (
							<span class="inline-flex items-center px-3 py-1 rounded-lg bg-neutral-200 dark:bg-neutral-700 text-sm font-medium text-neutral-800 dark:text-neutral-200">
								{keyword}
							</span>
						))
					}
				</div>
			</div>
		</div>
	</article>
</section>
