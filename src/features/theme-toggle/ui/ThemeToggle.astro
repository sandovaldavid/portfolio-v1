---
import SunIcon from '@assets/icons/Sun.astro';
import MoonIcon from '@assets/icons/Moon.astro';
import SystemIcon from '@assets/icons/System.astro';
import { createScopedUiTranslator, getLanguageFromLocale } from '@shared/config/i18n';

const lang = getLanguageFromLocale(Astro.currentLocale);
const tTheme = createScopedUiTranslator(lang, 'theme');

const THEMES = [
	{ id: 'light', name: tTheme('light') },
	{ id: 'dark', name: tTheme('dark') },
	{ id: 'system', name: tTheme('system') },
];
---

<div class="theme-toggle relative ml-1 mr-1">
	<button
		class="theme-toggle-btn relative appearance-none border-none size-7 flex justify-center items-center rounded-lg hover:bg-neutral-200/80 dark:hover:bg-neutral-800/80 hover:scale-110 transition-all duration-300 p-1"
		aria-label={tTheme('select')}
	>
		<span class="sr-only">{tTheme('select')}</span>
		<SunIcon data-icon="light" class="theme-icon absolute size-5 transition-all text-content" />
		<MoonIcon
			data-icon="dark"
			class="theme-icon hidden absolute size-5 transition-all text-content"
		/>
		<SystemIcon
			data-icon="system"
			class="theme-icon hidden absolute size-5 transition-all text-content"
		/>
	</button>

	<div
		class="themes-menu absolute hidden w-28 top-10 right-0 text-sm p-1.5 rounded-xl border border-neutral-200/50 dark:border-neutral-700/50 bg-neutral-50/95 dark:bg-neutral-800/95 backdrop-blur-lg shadow-lg shadow-neutral-900/10 dark:shadow-neutral-950/30 z-50 transition-all duration-200"
	>
		<ul class="space-y-0.5">
			{
				THEMES.map(theme => (
					<li
						data-theme={theme.id}
						class="themes-menu-option px-3 py-2 cursor-pointer rounded-lg text-content hover:text-primary-600 dark:hover:text-primary-400 hover:bg-neutral-200/70 dark:hover:bg-neutral-700/70 transition-all duration-200 font-medium"
					>
						{theme.name}
					</li>
				))
			}
		</ul>
	</div>
</div>

<script>
	// View-transition safe: listeners are (re)wired on every page load, while
	// document/window listeners are attached once. See Astro docs → View
	// transitions → Script behavior (astro:page-load).
	const media = window.matchMedia('(prefers-color-scheme: dark)');

	// Applies the theme globally and syncs every toggle's icons to live DOM.
	const applyTheme = (theme: string) => {
		const isDark = theme === 'dark' || (theme === 'system' && media.matches);
		document.documentElement.classList.toggle('dark', isDark);
		document.querySelectorAll<HTMLElement>('.theme-toggle').forEach(root => {
			const show = (selector: string, on: boolean) => {
				const el = root.querySelector<HTMLElement>(selector);
				if (el) el.style.display = on ? 'block' : 'none';
			};
			show('[data-icon="light"]', theme === 'light');
			show('[data-icon="dark"]', theme === 'dark');
			show('[data-icon="system"]', theme === 'system');
		});
	};

	// Wires each toggle instance; guarded so re-runs never double-bind.
	const setupThemeToggles = () => {
		document.querySelectorAll<HTMLElement>('.theme-toggle').forEach(root => {
			if (root.dataset.themeReady === 'true') return;
			root.dataset.themeReady = 'true';

			const btn = root.querySelector<HTMLButtonElement>('.theme-toggle-btn');
			const menu = root.querySelector<HTMLDivElement>('.themes-menu');
			const opts = root.querySelectorAll<HTMLLIElement>('.themes-menu-option');
			if (!btn || !menu) {
				console.error('Required elements not found in theme toggle');
				return;
			}

			const toggleMenu = (e: Event) => {
				e.stopPropagation();
				e.preventDefault();
				menu.classList.toggle('hidden');
			};
			btn.addEventListener('click', toggleMenu);
			btn.addEventListener('touchend', toggleMenu);

			opts.forEach(opt => {
				opt.addEventListener('click', () => {
					const theme = opt.getAttribute('data-theme');
					if (!theme) return;
					localStorage.setItem('theme', theme);
					applyTheme(theme);
					menu.classList.add('hidden');
				});
			});
		});

		// Re-sync icons to the persisted theme after each (re)render.
		applyTheme(localStorage.getItem('theme') || 'dark');
	};

	// Attach document/window listeners once — they survive navigation.
	media.addEventListener('change', () => {
		if ((localStorage.getItem('theme') || 'dark') === 'system') applyTheme('system');
	});
	document.addEventListener('click', (e: MouseEvent) => {
		const target = e.target as Node;
		document.querySelectorAll<HTMLElement>('.theme-toggle').forEach(root => {
			const menu = root.querySelector<HTMLDivElement>('.themes-menu');
			if (menu && !menu.classList.contains('hidden') && !root.contains(target)) {
				menu.classList.add('hidden');
			}
		});
	});

	// Runs on first load and after every client-side navigation.
	document.addEventListener('astro:page-load', setupThemeToggles);
</script>
