---
import {
	AVAILABLE_LANGUAGES,
	DEFAULT_LANGUAGE,
	LANGUAGE_LABELS,
	createScopedUiTranslator,
} from '@shared/config/i18n';
import { getLangFromUrl } from '@shared/lib/i18n';

const url = new URL(Astro.request.url);
const currentLang = getLangFromUrl(url);
const pathname = url.pathname;
const tAccessibility = createScopedUiTranslator(currentLang, 'accessibility');

/**
 * Generates the correct path for language switching.
 * Astro-native counterpart resolution is implemented by issue #139.
 */
const getLanguagePath = (targetLang: string): string => {
	const cleanPath = pathname.replace(/^\/(es|en)(\/|$)/, '/');

	if (targetLang === DEFAULT_LANGUAGE) {
		return cleanPath === '' ? '/' : cleanPath;
	}

	if (cleanPath === '/' || cleanPath === '') {
		return '/es/';
	}

	return `/es${cleanPath}`;
};
---

<div
	class="flex items-center gap-2 font-mono"
	role="group"
	aria-label={tAccessibility('chooseLanguage')}
>
	{
		AVAILABLE_LANGUAGES.map(lang => {
			const isActive = currentLang === lang;
			const path = isActive ? '#' : getLanguagePath(lang);
			const label = isActive
				? `${LANGUAGE_LABELS[lang]}, ${tAccessibility('currentPage')}`
				: LANGUAGE_LABELS[lang];

			return (
				<a
					href={path}
					class={`px-2.5 py-1 text-xs font-bold transition-all duration-100 uppercase tracking-wider border-2 border-black dark:border-white ${
						isActive
							? 'bg-primary-500 text-white dark:text-black shadow-retro-xs translate-x-[1.5px] translate-y-[1.5px] cursor-default pointer-events-none'
							: 'bg-surface text-content-strong shadow-retro-sm hover:-translate-x-[1px] hover:-translate-y-[1px] hover:shadow-retro-md active:translate-x-[1.5px] active:translate-y-[1.5px] active:shadow-retro-xs'
					}`}
					aria-label={label}
					aria-current={isActive ? 'page' : undefined}
				>
					{lang.toUpperCase()}
				</a>
			);
		})
	}
</div>
