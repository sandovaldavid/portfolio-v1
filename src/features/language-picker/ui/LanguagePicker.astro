---
import {
	AVAILABLE_LANGUAGES,
	LANGUAGE_LABELS,
	createScopedUiTranslator,
	getLanguageFromLocale,
} from '@shared/config/i18n';
import type { LanguagePickerProps } from '../model';

const { currentLang: providedCurrentLang, localizedPaths } = Astro.props as LanguagePickerProps;
const currentLang = providedCurrentLang ?? getLanguageFromLocale(Astro.currentLocale);
const tAccessibility = createScopedUiTranslator(currentLang, 'accessibility');
const baseClass =
	'px-2.5 py-1 text-xs font-bold transition-all duration-100 uppercase tracking-wider border-2 border-black dark:border-white';
---

<div
	class="flex items-center gap-2 font-mono"
	role="group"
	aria-label={tAccessibility('chooseLanguage')}
>
	{
		AVAILABLE_LANGUAGES.map(lang => {
			const isActive = currentLang === lang;
			const path = localizedPaths[lang];
			const isUnavailable = !path;
			const label = isActive
				? `${LANGUAGE_LABELS[lang]}, ${tAccessibility('currentPage')}`
				: isUnavailable
					? `${LANGUAGE_LABELS[lang]}, ${tAccessibility('translationUnavailable')}`
					: LANGUAGE_LABELS[lang];

			if (isUnavailable) {
				return (
					<button
						type="button"
						disabled
						class={`${baseClass} cursor-not-allowed opacity-50 bg-surface text-content-muted`}
						aria-label={label}
					>
						{lang.toUpperCase()}
					</button>
				);
			}

			return (
				<a
					href={path}
					data-language-base-path={path}
					class={`${baseClass} ${
						isActive
							? 'bg-primary-500 text-white dark:text-black shadow-retro-xs translate-x-[1.5px] translate-y-[1.5px] cursor-default pointer-events-none'
							: 'bg-surface text-content-strong shadow-retro-sm hover:-translate-x-[1px] hover:-translate-y-[1px] hover:shadow-retro-md active:translate-x-[1.5px] active:translate-y-[1.5px] active:shadow-retro-xs'
					}`}
					aria-label={label}
					aria-current={isActive ? 'page' : undefined}
				>
					{lang.toUpperCase()}
				</a>
			);
		})
	}
</div>

<script>
	const preservePathShape = (pathname: string, trailingSlash: boolean): string => {
		if (pathname === '/') return pathname;
		if (trailingSlash) return pathname.endsWith('/') ? pathname : `${pathname}/`;
		return pathname.endsWith('/') ? pathname.slice(0, -1) : pathname;
	};

	const syncLanguageLinkState = () => {
		const preserveTrailingSlash = window.location.pathname.endsWith('/');

		document.querySelectorAll<HTMLAnchorElement>('[data-language-base-path]').forEach(link => {
			const basePath = link.dataset.languageBasePath;
			if (!basePath) return;

			const target = new URL(basePath, window.location.origin);
			const targetPath = preservePathShape(target.pathname, preserveTrailingSlash);

			target.search = window.location.search;
			target.hash = window.location.hash;
			link.href = `${targetPath}${target.search}${target.hash}`;
		});
	};

	syncLanguageLinkState();
	document.addEventListener('astro:page-load', syncLanguageLinkState);
	window.addEventListener('hashchange', syncLanguageLinkState);
</script>
