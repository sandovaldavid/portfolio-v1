---
import { AVAILABLE_LANGUAGES, DEFAULT_LANGUAGE } from '@shared/config/i18n';
import { getLangFromUrl } from '@shared/lib/i18n';

const url = new URL(Astro.request.url);
const currentLang = getLangFromUrl(url);
const pathname = url.pathname;

/**
 * Generates the correct path for language switching
 * English (default): / or /page
 * Spanish: /es/ or /es/page
 */
const getLanguagePath = (targetLang: string): string => {
	// Remove any language prefix (/es or /en) from the pathname
	const cleanPath = pathname.replace(/^\/(es|en)(\/|$)/, '/');

	if (targetLang === DEFAULT_LANGUAGE) {
		// For English (default), return path without prefix
		return cleanPath === '' ? '/' : cleanPath;
	}

	// For Spanish, add /es prefix
	if (cleanPath === '/' || cleanPath === '') {
		return '/es/';
	}

	return `/es${cleanPath}`;
};
---

<div class="flex items-center gap-2 font-mono">
	{
		AVAILABLE_LANGUAGES.map(lang => {
			const isActive = currentLang === lang;
			const path = isActive ? '#' : getLanguagePath(lang);

			return (
				<a
					href={path}
					class={`px-2.5 py-1 text-xs font-bold transition-all duration-100 uppercase tracking-wider border-2 border-black dark:border-white ${
						isActive
							? 'bg-primary-500 text-white dark:text-black shadow-[1px_1px_0px_0px_var(--color-border-strong)] translate-x-[1.5px] translate-y-[1.5px] cursor-default pointer-events-none'
							: 'bg-surface text-text-main shadow-[2.5px_2.5px_0px_0px_var(--color-border-strong)] hover:-translate-x-[1px] hover:-translate-y-[1px] hover:shadow-[3.5px_3.5px_0px_0px_var(--color-border-strong)] active:translate-x-[1.5px] active:translate-y-[1.5px] active:shadow-[1px_1px_0px_0px_var(--color-border-strong)]'
					}`}
					aria-current={isActive ? 'page' : undefined}
				>
					{lang.toUpperCase()}
				</a>
			);
		})
	}
</div>
