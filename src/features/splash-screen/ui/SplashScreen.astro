---
import { getLangFromUrl, useTranslations } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';
import { siteConfig } from '@shared/config/site.config';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);

const year = new Date().getFullYear();
const handleUpper = siteConfig.handle.toUpperCase();
---

<div
	id="splash-screen"
	data-name={siteConfig.name.toUpperCase()}
	data-initializing={t('splash.initializing')}
	data-loading-stack={t('splash.loading-stack')}
	data-connecting-github={t('splash.connecting-github')}
	data-ready-player={t('splash.ready-player')}
	data-welcome={t('splash.welcome')}
	data-prepare={t('splash.prepare')}
	class="fixed inset-0 w-screen h-screen bg-[#07090e] z-[9999] flex flex-col items-center justify-center font-mono text-primary-500 overflow-hidden select-none"
>
	<!-- Blocking inline script to prevent Flash of Uninitialized Splash Screen (FOSS) -->
	<script is:inline>
		try {
			if (sessionStorage.getItem('pf_booted') === 'true') {
				document.getElementById('splash-screen').style.display = 'none';
			} else {
				document.body.style.overflow = 'hidden';
			}
		} catch (e) {}
	</script>

	<!-- CRT scanlines grid overlay -->
	<div class="crt-overlay pointer-events-none absolute inset-0 z-10 opacity-[0.15]"></div>

	<!-- Content Container -->
	<div class="w-full max-w-2xl px-6 flex flex-col gap-6 text-left relative z-20">
		<!-- BIOS Header -->
		<div class="text-[#00ff88]/80 text-xs sm:text-sm border-b border-[#00ff88]/20 pb-4 space-y-1">
			<p>PORTFOLIO SYSTEM BIOS V2.0 // (C) {year} {handleUpper}</p>
			<p>CPU: BiLSTM MACHINE LEARNING CO-PROCESSOR</p>
			<p>RAM: 1024KB RETRO GAMING BUFFER // OK</p>
		</div>

		<!-- Boot sequence output -->
		<div id="boot-output" class="text-sm space-y-2 min-h-[160px] md:min-h-[140px] overflow-y-auto">
			<!-- Lines will be dynamically generated by JS -->
		</div>

		<!-- Prompt and Button -->
		<div id="boot-actions" class="opacity-0 transition-opacity duration-500 flex flex-col items-center gap-4 mt-4">
			<button
				id="boot-btn"
				class="w-full sm:w-auto px-8 py-3 bg-primary-500 text-white dark:text-black font-pixel text-[10px] sm:text-xs tracking-widest border-2 border-black dark:border-white shadow-[4px_4px_0px_var(--color-border-strong)] active:translate-x-[2px] active:translate-y-[2px] active:shadow-[2px_2px_0px_var(--color-border-strong)] hover:bg-primary-400 focus:outline-none transition-all cursor-pointer animate-pulse"
			>
				{t('splash.press-enter')}
			</button>
		</div>
	</div>
</div>

<script>
	const splash = document.getElementById('splash-screen');

	// Only execute boot scripts if the splash screen is active and visible
	if (splash && splash.style.display !== 'none') {
		const bootOutput = document.getElementById('boot-output');
		const bootActions = document.getElementById('boot-actions');
		const bootBtn = document.getElementById('boot-btn');

		const name = splash.getAttribute('data-name') || '';
		const initializing = splash.getAttribute('data-initializing') || '';
		const loadingStack = splash.getAttribute('data-loading-stack') || '';
		const connectingGithub = splash.getAttribute('data-connecting-github') || '';
		const readyPlayer = splash.getAttribute('data-ready-player') || '';
		const welcome = splash.getAttribute('data-welcome') || '';
		const prepare = splash.getAttribute('data-prepare') || '';

		const lines = [
			{ text: initializing, delay: 100, color: 'text-primary-500' },
			{ text: loadingStack, delay: 450, color: 'text-neutral-400' },
			{ text: connectingGithub, delay: 800, color: 'text-neutral-400' },
			{ text: `${readyPlayer}${name}`, delay: 1150, color: 'text-[#00ff88] font-bold' },
			{ text: welcome, delay: 1550, color: 'text-white' },
			{ text: prepare, delay: 2050, color: 'text-white' }
		];

		// Play boot lines
		lines.forEach((line) => {
			setTimeout(() => {
				if (!bootOutput) return;
				const p = document.createElement('p');
				p.className = `${line.color} transition-all duration-300`;
				p.innerHTML = line.text;
				bootOutput.appendChild(p);
				bootOutput.scrollTop = bootOutput.scrollHeight;
			}, line.delay);
		});

		// Reveal start button
		setTimeout(() => {
			if (bootActions) {
				bootActions.classList.remove('opacity-0');
				bootActions.classList.add('opacity-100');
			}
		}, 2550);

		// Dismiss function
		const dismissSplash = () => {
			// Play CRT power-off animation
			splash.classList.add('dismissing');

			setTimeout(() => {
				splash.style.display = 'none';
				document.body.style.overflow = '';
				try {
					sessionStorage.setItem('pf_booted', 'true');
				} catch {
					/* ignore */
				}
			}, 600); // Match CSS animation duration
		};

		if (bootBtn) {
			bootBtn.addEventListener('click', dismissSplash);
		}

		window.addEventListener('keydown', (e) => {
			if (e.key === 'Enter') {
				dismissSplash();
			}
		});
	}
</script>

<style>
	.crt-overlay {
		background: linear-gradient(
			rgba(18, 16, 16, 0) 50%,
			rgba(0, 0, 0, 0.25) 50%
		);
		background-size: 100% 4px;
	}

	#splash-screen.dismissing {
		animation: crt-power-off 0.6s cubic-bezier(0.19, 1, 0.22, 1) forwards;
		pointer-events: none;
	}

	@keyframes crt-power-off {
		0% {
			transform: scale(1);
			opacity: 1;
		}
		50% {
			transform: scaleY(0.005) scaleX(1);
			opacity: 0.8;
			background: #ffffff;
			filter: brightness(2);
		}
		100% {
			transform: scale(0);
			opacity: 0;
			background: #000000;
		}
	}
</style>
