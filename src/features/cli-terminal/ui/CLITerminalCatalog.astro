---
import { getLangFromUrl } from '@shared/lib/i18n';
import { createScopedUiTranslator, getUiCatalogNamespace, Language } from '@shared/config/i18n';
import { siteConfig } from '@shared/config/site.config';

const lang = getLangFromUrl(new URL(Astro.request.url));
const tCli = createScopedUiTranslator(lang, 'cli');
const tAccessibility = createScopedUiTranslator(lang, 'accessibility');
const runtimeCopy = getUiCatalogNamespace(lang, 'cli');
const resumeUrl = lang === Language.ENGLISH ? siteConfig.resume.en : siteConfig.resume.es;

const navigationShortcuts: [string, string][] = [
	['j', tCli('shortcuts.scrollDown')],
	['k', tCli('shortcuts.scrollUp')],
	['gg', tCli('shortcuts.goTop')],
	['G', tCli('shortcuts.goBottom')],
];
const sectionShortcuts: [string, string][] = [
	['1', tCli('sections.hero')],
	['2', tCli('sections.experience')],
	['3', tCli('sections.research')],
	['4', tCli('sections.projects')],
	['5', tCli('sections.about')],
	['6', tCli('sections.technologies')],
];
const actionShortcuts: [string, string][] = [
	[':', tCli('shortcuts.openTerminal')],
	['/', tCli('shortcuts.navigateSection')],
	['?', tCli('shortcuts.showShortcuts')],
	['Esc', tCli('shortcuts.closeOverlay')],
];
const sectionNames = [
	tCli('sections.hero'),
	tCli('sections.experience'),
	tCli('sections.research'),
	tCli('sections.projects'),
	tCli('sections.about'),
	tCli('sections.technologies'),
];
const easterRows = [
	{ label: tCli('easter.coffeeLabel'), value: tCli('easter.coffeeValue'), color: '#00ff88' },
	{ label: tCli('easter.bugsLabel'), value: tCli('easter.bugsValue'), color: '#f87171' },
	{ label: tCli('easter.tabsLabel'), value: tCli('easter.tabsValue'), color: '#facc15' },
	{ label: tCli('easter.commitLabel'), value: tCli('easter.commitValue'), color: '#00b0ff' },
	{ label: tCli('easter.editorLabel'), value: tCli('easter.editorValue'), color: '#00ff88' },
	{ label: tCli('easter.vimLabel'), value: tCli('easter.vimValue'), color: '#00ff88' },
	{
		label: tCli('easter.debugLabel'),
		value: tCli('easter.debugValue'),
		color: 'rgba(255,255,255,0.7)',
	},
	{ label: tCli('easter.deployLabel'), value: tCli('easter.deployValue'), color: '#facc15' },
	{ label: tCli('easter.teamLabel'), value: tCli('easter.teamValue'), color: '#00ff88' },
];
---

<div id="cli-terminal-root">
	<div
		id="cli-runtime-data"
		hidden
		data-copy={JSON.stringify(runtimeCopy)}
		data-section-names={JSON.stringify(sectionNames)}
		data-resume-url={resumeUrl}
		data-github-user={siteConfig.social.githubUsername}
		data-email={siteConfig.email}
		data-linkedin={siteConfig.social.linkedinUsername}
		data-site-url={siteConfig.url}
	>
	</div>

	<div
		id="cli-overlay"
		role="dialog"
		aria-modal="true"
		aria-label={tAccessibility('terminalDialog')}
		class="fixed inset-0 z-[200] bg-black/85 backdrop-blur-sm hidden items-center justify-center p-4"
	>
		<div class="w-full max-w-2xl">
			<div
				class="bg-[#0a0a0a] border-2 border-[#00b0ff] shadow-[0_0_30px_rgba(0,176,255,0.35)] font-mono"
			>
				<div
					class="flex items-center gap-2 px-4 py-2.5 bg-[#111] border-b border-[#00b0ff]/40 select-none"
				>
					<button
						id="cli-close-dot"
						aria-label={tAccessibility('closeTerminal')}
						class="w-3 h-3 rounded-full bg-red-500 hover:brightness-125 cursor-pointer"
					></button>
					<div class="w-3 h-3 rounded-full bg-yellow-500" aria-hidden="true"></div>
					<div class="w-3 h-3 rounded-full bg-[#00ff88]" aria-hidden="true"></div>
					<span class="ml-3 text-xs text-[#00b0ff]/70 tracking-widest uppercase">
						portfolio@sandovaldavid:~
					</span>
					<span class="ml-auto text-xs text-[#00b0ff]/60 hidden sm:block">
						[{tCli('terminal.escapeHint')}]
					</span>
				</div>
				<div
					id="cli-output"
					class="h-96 overflow-y-auto p-4 space-y-0.5"
					aria-live="polite"
					aria-relevant="additions"
				>
				</div>
				<div class="flex items-center border-t border-[#00b0ff]/30 px-4 py-3 bg-[#0a0a0a]">
					<span
						class="text-[#00b0ff] mr-2 text-sm font-bold select-none"
						aria-hidden="true">$</span
					>
					<input
						id="cli-input"
						type="text"
						class="flex-1 bg-transparent text-sm text-white outline-none placeholder:text-white/40 caret-[#00b0ff]"
						placeholder={tCli('terminal.placeholder')}
						autocomplete="off"
						spellcheck="false"
						aria-label={tAccessibility('terminalInput')}
					/>
					<span class="text-xs text-white/40 uppercase tracking-widest hidden sm:block">
						{tCli('terminal.tabHint')}
					</span>
				</div>
			</div>
		</div>
	</div>

	<div
		id="shortcuts-modal"
		role="dialog"
		aria-modal="true"
		aria-label={tCli('shortcuts.title')}
		class="fixed inset-0 z-[200] bg-black/85 backdrop-blur-sm hidden items-center justify-center p-4"
	>
		<div
			class="w-full max-w-lg bg-surface border-2 border-black dark:border-white shadow-retro-3xl font-mono"
		>
			<div
				class="flex items-center justify-between px-5 py-3 border-b-2 border-dashed border-edge-subtle"
			>
				<span
					class="text-primary-500 dark:text-primary-400 font-pixel-clean text-xs font-bold tracking-wider uppercase"
				>
					{tCli('shortcuts.title')}
				</span>
				<button
					id="shortcuts-close"
					class="px-1.5 py-0.5 border border-black dark:border-white text-xs font-bold hover:bg-red-500 hover:text-white dark:hover:text-black transition-colors cursor-pointer"
					aria-label={tCli('shortcuts.closeOverlay')}
				>
					<span aria-hidden="true">×</span>
				</button>
			</div>

			<div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-6 text-xs">
				<div>
					<div
						class="text-content-muted uppercase tracking-widest text-xs pb-1 mb-3 border-b border-edge-subtle"
					>
						{tCli('shortcuts.navigationHeading')}
					</div>
					<div class="space-y-2">
						{
							navigationShortcuts.map(([key, label]) => (
								<div class="flex items-center gap-2.5">
									<kbd class="inline-block min-w-[28px] text-center px-2 py-0.5 border border-black dark:border-white bg-neutral-100 dark:bg-neutral-800 text-xs font-bold shadow-retro-sm">
										{key}
									</kbd>
									<span class="text-content-muted">{label}</span>
								</div>
							))
						}
					</div>
				</div>

				<div>
					<div
						class="text-content-muted uppercase tracking-widest text-xs pb-1 mb-3 border-b border-edge-subtle"
					>
						{tCli('shortcuts.sectionsHeading')}
					</div>
					<div class="space-y-2">
						{
							sectionShortcuts.map(([key, label]) => (
								<div class="flex items-center gap-2.5">
									<kbd class="inline-block min-w-[28px] text-center px-2 py-0.5 border border-black dark:border-white bg-neutral-100 dark:bg-neutral-800 text-xs font-bold shadow-retro-sm">
										{key}
									</kbd>
									<span class="text-content-muted">{label}</span>
								</div>
							))
						}
					</div>
				</div>

				<div>
					<div
						class="text-content-muted uppercase tracking-widest text-xs pb-1 mb-3 border-b border-edge-subtle"
					>
						{tCli('shortcuts.actionsHeading')}
					</div>
					<div class="space-y-2">
						{
							actionShortcuts.map(([key, label]) => (
								<div class="flex items-center gap-2.5">
									<kbd class="inline-block min-w-[28px] text-center px-2 py-0.5 border border-black dark:border-white bg-neutral-100 dark:bg-neutral-800 text-xs font-bold shadow-retro-sm">
										{key}
									</kbd>
									<span class="text-content-muted">{label}</span>
								</div>
							))
						}
					</div>
				</div>

				<div class="opacity-60">
					<div
						class="text-content-muted uppercase tracking-widest text-xs pb-1 mb-3 border-b border-edge-subtle"
					>
						{tCli('shortcuts.secretHeading')}
					</div>
					<div class="space-y-2">
						<div class="flex items-center gap-2.5">
							<kbd
								class="inline-block min-w-[28px] text-center px-2 py-0.5 border border-black/40 dark:border-white/30 bg-neutral-100/50 dark:bg-neutral-800/50 text-xs font-bold opacity-50"
							>
								??
							</kbd>
							<span class="text-content-muted/80 text-xs italic">
								{tCli('shortcuts.secretHint')}
							</span>
						</div>
						<div class="text-sm text-content-muted italic pl-1">
							{tCli('shortcuts.secretMessage')}
						</div>
					</div>
				</div>
			</div>

			<div
				class="px-5 py-2.5 border-t-2 border-dashed border-edge-subtle text-sm text-content-muted/80 text-center uppercase tracking-widest"
			>
				{tCli('shortcuts.footer')}
			</div>
		</div>
	</div>

	<div
		id="easter-egg-overlay"
		role="dialog"
		aria-modal="true"
		aria-label={tAccessibility('secretMode')}
		class="fixed inset-0 z-[300] bg-black/95 hidden items-center justify-center p-4"
	>
		<div
			class="absolute inset-0 pointer-events-none opacity-25"
			style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,176,255,0.05) 2px, rgba(0,176,255,0.05) 4px);"
		>
		</div>
		<div class="w-full max-w-md font-mono space-y-4 relative z-10">
			<div class="border-2 border-red-500 bg-red-950/30 px-6 py-4 text-center">
				<div class="text-red-400 font-bold tracking-[0.4rem] text-xl animate-pulse">
					{tCli('easter.classified')}
				</div>
				<div class="text-error-500/80 text-xs mt-1.5 tracking-widest">
					{tCli('easter.protocol')}
				</div>
				<div class="text-error-500/80 text-xs mt-0.5">
					{tCli('easter.clearance')}
				</div>
			</div>

			<div
				id="egg-loading"
				class="bg-black/60 border border-[#00b0ff]/30 p-4 text-xs space-y-1 min-h-[9rem] overflow-hidden"
			>
			</div>

			<div id="egg-stats" class="hidden border-2 border-[#00ff88] bg-[#00ff88]/5 p-4">
				<div class="text-[#00ff88] font-bold tracking-widest text-xs mb-3 uppercase">
					{tCli('easter.statsTitle')}
				</div>
				<div class="space-y-2 text-xs">
					{
						easterRows.map(({ label, value, color }) => (
							<div class="flex justify-between gap-4">
								<span class="text-white/50 shrink-0">{label}</span>
								<span style={`color: ${color}`}>{value}</span>
							</div>
						))
					}
				</div>
				<div
					class="mt-4 pt-3 border-t border-[#00ff88]/20 text-xs text-[#00ff88]/40 text-center"
				>
					{tCli('easter.footer')}
				</div>
			</div>

			<div class="flex gap-3">
				<a
					href={`mailto:${siteConfig.email}?subject=${encodeURIComponent(siteConfig.emailSubjectRecruiter)}`}
					class="flex-1 py-2.5 border-2 border-[#00ff88] bg-[#00ff88]/10 text-[#00ff88] text-xs uppercase tracking-widest font-bold hover:bg-[#00ff88]/20 transition-colors cursor-pointer text-center"
				>
					{tCli('easter.hire')}
				</a>
				<button
					id="egg-close"
					class="flex-1 py-2.5 border-2 border-white/20 text-white/40 text-xs uppercase tracking-widest hover:border-white/50 hover:text-white/60 transition-colors cursor-pointer"
				>
					{tCli('easter.close')}
				</button>
			</div>
		</div>
	</div>
</div>

<script>
	import { setupCliTerminal } from '../model/runtime';

	setupCliTerminal();
	document.addEventListener('astro:page-load', setupCliTerminal);
</script>

<style is:global>
	.pf-glitch {
		animation: pf-glitch-anim 0.45s linear;
	}

	@keyframes pf-glitch-anim {
		0% {
			filter: none;
			transform: translate(0);
		}
		15% {
			filter: hue-rotate(90deg) brightness(1.4);
			transform: translate(-3px, 1px);
		}
		30% {
			filter: hue-rotate(180deg) saturate(2);
			transform: translate(3px, -2px);
		}
		50% {
			filter: hue-rotate(270deg) brightness(0.8);
			transform: translate(-2px, 2px);
		}
		70% {
			filter: hue-rotate(360deg) contrast(1.5);
			transform: translate(2px, -1px);
		}
		85% {
			filter: invert(0.08);
			transform: translate(-1px, 1px);
		}
		100% {
			filter: none;
			transform: translate(0);
		}
	}
</style>
