	document.addEventListener('keydown', e => {
		if (isInInput()) return;
		if (e.ctrlKey || e.metaKey || e.altKey) return;

		const key = e.key;

		if (anyOverlayOpen()) {
			if (key === 'Escape') {
				closeCLI();
				closeShortcutsModal();
				easterEggOverlay.classList.add('hidden');
				easterEggOverlay.classList.remove('flex');
			}
			return;
		}

		if (key === ':') {
			e.preventDefault();
			openCLI('');
			return;
		}
		if (key === '/') {
			e.preventDefault();
			openCLI('goto ');
			return;
		}
		if (key === '?') {
			e.preventDefault();
			openShortcutsModal();
			return;
		}
		if (key === 'j') {
			window.scrollBy({ top: 280, behavior: 'smooth' });
			return;
		}
		if (key === 'k') {
			window.scrollBy({ top: -280, behavior: 'smooth' });
			return;
		}
		if (key === 'G') {
			e.preventDefault();
			window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
			keyBuffer = '';
			if (keyTimer) clearTimeout(keyTimer);
			return;
		}

		keyBuffer += key;
		if (keyTimer) clearTimeout(keyTimer);

		if (keyBuffer.endsWith('gg')) {
			window.scrollTo({ top: 0, behavior: 'smooth' });
			keyBuffer = '';
			return;
		}

		if (keyBuffer.includes('12')) {
			e.preventDefault();
			triggerEasterEgg();
			keyBuffer = '';
			return;
		}

		keyTimer = setTimeout(() => {
			const last = keyBuffer.replace(/\D/g, '').slice(-1);
			const num = parseInt(last);
			if (!isNaN(num) && num >= 1 && num <= 6) {
				navigateToSection(num);
			}
			keyBuffer = '';
		}, 360);
	});
</script>

<style is:global>
	.pf-glitch {
		animation: pf-glitch-anim 0.45s linear;
	}
	@keyframes pf-glitch-anim {
		0% {
			filter: none;
			transform: translate(0);
		}
		15% {
			filter: hue-rotate(90deg) brightness(1.4);
			transform: translate(-3px, 1px);
		}
		30% {
			filter: hue-rotate(180deg) saturate(2);
			transform: translate(3px, -2px);
		}
		50% {
			filter: hue-rotate(270deg) brightness(0.8);
			transform: translate(-2px, 2px);
		}
		70% {
			filter: hue-rotate(360deg) contrast(1.5);
			transform: translate(2px, -1px);
		}
		85% {
			filter: invert(0.08);
			transform: translate(-1px, 1px);
		}
		100% {
			filter: none;
			transform: translate(0);
		}
	}
</style>
