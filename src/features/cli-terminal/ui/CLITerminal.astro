	// ── CLI input events ──────────────────────────────────────────────────
	cliInput.addEventListener('keydown', e => {
		if (e.key === 'Enter') {
			const val = cliInput.value;
			cliInput.value = '';
			handleCommand(val);
		} else if (e.key === 'Escape') {
			closeCLI();
		} else if (e.key === 'ArrowUp') {
			e.preventDefault();
			if (cliHistoryIndex < cliHistory.length - 1) {
				cliHistoryIndex++;
				cliInput.value = cliHistory[cliHistoryIndex]!;
			}
		} else if (e.key === 'ArrowDown') {
			e.preventDefault();
			if (cliHistoryIndex > 0) {
				cliHistoryIndex--;
				cliInput.value = cliHistory[cliHistoryIndex]!;
			} else {
				cliHistoryIndex = -1;
				cliInput.value = '';
			}
		} else if (e.key === 'Tab') {
			e.preventDefault();
			const cmds = [
				'help',
				'whoami',
				'about',
				'research',
				'ls',
				'goto ',
				'github',
				'contact',
				'skills',
				'matrix',
				'open resume',
				'clear',
				'vim',
				'nvim',
				'sudo',
				'exit',
				':q',
			];
			const match = cmds.find(c => c.startsWith(cliInput.value) && c !== cliInput.value);
			if (match) cliInput.value = match;
		}
	});

