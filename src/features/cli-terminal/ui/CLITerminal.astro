---
// CLITerminal — Global keyboard engine + CLI overlay + shortcuts modal + easter egg
// Activated by pressing : (CLI), / (goto), ? (shortcuts), j/k/gg/G (scroll), 1-6 (sections), 12 (secret)
import { getLangFromUrl } from '@shared/lib/i18n';
import { siteConfig } from '@shared/config/site.config';

const langCode = getLangFromUrl(new URL(Astro.request.url));
const isEn = langCode === 'en';

// ─── Shortcuts Modal ─────────────────────────────────────────────────────────
const kbTitle = isEn ? '⌨ KEYBOARD SHORTCUTS' : '⌨ ATAJOS DE TECLADO';
const kbNavHeading = isEn ? 'VIM NAVIGATION' : 'NAVEGACIÓN VIM';
const kbVimRows: [string, string][] = [
	['j', isEn ? 'Scroll down' : 'Scroll abajo'],
	['k', isEn ? 'Scroll up' : 'Scroll arriba'],
	['gg', isEn ? 'Go to top' : 'Ir al inicio'],
	['G', isEn ? 'Go to bottom' : 'Ir al final'],
];
const kbSectionsHeading = isEn ? 'SECTIONS (1 – 6)' : 'SECCIONES (1 – 6)';
const kbSectionRows: [string, string][] = [
	['1', isEn ? 'Hero / Home' : 'Hero / Inicio'],
	['2', isEn ? 'Experience' : 'Experiencia'],
	['3', isEn ? 'Research' : 'Investigación'],
	['4', isEn ? 'Projects' : 'Proyectos'],
	['5', isEn ? 'About Me' : 'Sobre mí'],
	['6', isEn ? 'Technologies' : 'Tecnologías'],
];
const kbActionsHeading = isEn ? 'TERMINAL & ACTIONS' : 'TERMINAL & ACCIONES';
const kbActionRows: [string, string][] = [
	[':', isEn ? 'Open CLI terminal' : 'Abrir terminal CLI'],
	['/', isEn ? 'Navigate to section' : 'Navegar a sección'],
	['?', isEn ? 'Show shortcuts' : 'Mostrar atajos'],
	['Esc', isEn ? 'Close overlay' : 'Cerrar overlay'],
];
const kbSecretHeading = isEn ? '??? SECRET MODE' : '??? MODO SECRETO';
const kbSecretHint = isEn ? "There's a hidden code..." : 'Existe un código oculto...';
const kbSecretMsg = isEn
	? 'Curious recruiters always find interesting things.'
	: 'Los reclutadores curiosos siempre encuentran cosas interesantes.';
const kbFooter = isEn
	? 'Shortcuts active outside text fields'
	: 'Atajos activos fuera de campos de texto';

// ─── CLI Terminal ─────────────────────────────────────────────────────────────
const cliPlaceholder = isEn
	? "type a command… (try 'help')"
	: "escribe un comando… (prueba 'help')";
const cliTabHint = isEn ? 'TAB autocomplete' : 'TAB autocompletar';

// ─── Easter Egg ───────────────────────────────────────────────────────────────
const eggProtocol = isEn
	? 'DEVELOPER PROTOCOL 12 — INITIATED'
	: 'PROTOCOLO DESARROLLADOR 12 — INICIADO';
const eggClearance = isEn
	? 'clearance level: RECRUITER_CURIOUS'
	: 'nivel de acceso: RECLUTADOR_CURIOSO';
const eggStatsTitle = isEn
	? '⚡ DEVELOPER SECRETS — FULLY EXPOSED'
	: '⚡ SECRETOS DEL DEVELOPER — TOTALMENTE EXPUESTOS';

interface EggRow {
	label: string;
	value: string;
	color: string;
}
const eggRows: EggRow[] = isEn
	? [
			{ label: '☕ COFFEE TODAY', value: '████████░░ ~4 cups', color: '#00ff88' },
			{ label: '🐛 BUGS IN PROD', value: '[ CLASSIFIED ]', color: '#f87171' },
			{ label: '📑 STACK OVERFLOW TABS', value: '47 open', color: '#facc15' },
			{ label: '⏰ LAST COMMIT', value: '3:17 AM (yesterday)', color: '#00b0ff' },
			{ label: '💻 REAL EDITOR', value: 'Neovim (btw)', color: '#00ff88' },
			{ label: '🎯 VIM CONFIRMED', value: "You're proof ←", color: '#00ff88' },
			{ label: '🔧 FAVORITE DEBUG', value: 'print("here3")', color: 'rgba(255,255,255,0.7)' },
			{ label: '🚀 DEPLOY PHILOSOPHY', value: 'Ship it → fix it', color: '#facc15' },
			{ label: '🤝 TEAM PLAYER', value: 'CONFIRMED ✓', color: '#00ff88' },
		]
	: [
			{ label: '☕ CAFÉ HOY', value: '████████░░ ~4 tazas', color: '#00ff88' },
			{ label: '🐛 BUGS EN PROD', value: '[ CLASIFICADO ]', color: '#f87171' },
			{ label: '📑 TABS STACK OVERFLOW', value: '47 abiertas', color: '#facc15' },
			{ label: '⏰ ÚLTIMO COMMIT', value: '3:17 AM (ayer)', color: '#00b0ff' },
			{ label: '💻 EDITOR REAL', value: 'Neovim (btw)', color: '#00ff88' },
			{ label: '🎯 VIM CONFIRMADO', value: 'Tú eres prueba ←', color: '#00ff88' },
			{ label: '🔧 DEBUG FAVORITO', value: 'print("aqui3")', color: 'rgba(255,255,255,0.7)' },
			{ label: '🚀 FILOSOFÍA DEPLOY', value: 'Ship it → fix it', color: '#facc15' },
			{ label: '🤝 TEAM PLAYER', value: 'CONFIRMED ✓', color: '#00ff88' },
		];

const eggFooterMsg = isEn
	? 'You found the easter egg. That says a lot about you as a developer.'
	: 'Has encontrado el easter egg. Eso dice mucho de ti como developer.';
const eggCloseBtn = isEn ? '[ CLOSE FILE ]' : '[ CERRAR ARCHIVO ]';

// ─── JS runtime data (passed via data attributes) ────────────────────────────
const navSectionNames = isEn
	? ['Hero', 'Experience', 'Research', 'Projects', 'About Me', 'Technologies']
	: ['Hero', 'Experiencia', 'Investigación', 'Proyectos', 'Sobre mí', 'Tecnologías'];

const resumeUrl = isEn ? siteConfig.resume.en : siteConfig.resume.es;
---

<!-- Hidden i18n data for client-side JS -->
<div
	id="cli-i18n"
	hidden
	data-lang={langCode}
	data-section-names={JSON.stringify(navSectionNames)}
	data-resume-url={resumeUrl}
	data-github-user={siteConfig.social.githubUsername}
	data-email={siteConfig.email}
	data-linkedin={siteConfig.social.linkedinUsername}
	data-site-url={siteConfig.url}
>
</div>

<!-- ═══════════════════════════════════════════════════════
     CLI TERMINAL OVERLAY
═══════════════════════════════════════════════════════ -->
<div
	id="cli-overlay"
	role="dialog"
	aria-modal="true"
	aria-label="Portfolio CLI Terminal"
	class="fixed inset-0 z-[200] bg-black/85 backdrop-blur-sm hidden items-center justify-center p-4"
>
	<div class="w-full max-w-2xl">
		<div
			class="bg-[#0a0a0a] border-2 border-[#00b0ff] shadow-[0_0_30px_rgba(0,176,255,0.35)] font-mono"
		>
			<!-- Title bar -->
			<div
				class="flex items-center gap-2 px-4 py-2.5 bg-[#111] border-b border-[#00b0ff]/40 select-none"
			>
				<button
					id="cli-close-dot"
					aria-label="Close terminal"
					class="w-3 h-3 rounded-full bg-red-500 hover:brightness-125 cursor-pointer"
				></button>
				<div class="w-3 h-3 rounded-full bg-yellow-500"></div>
				<div class="w-3 h-3 rounded-full bg-[#00ff88]"></div>
				<span class="ml-3 text-xs text-[#00b0ff]/70 tracking-widest uppercase"
					>portfolio@sandovaldavid:~</span
				>
				<span class="ml-auto text-xs text-[#00b0ff]/60 hidden sm:block"
					>[ ESC · close ]</span
				>
			</div>
			<!-- Output area -->
			<div
				id="cli-output"
				class="h-96 overflow-y-auto p-4 space-y-0.5"
				aria-live="polite"
				aria-relevant="additions"
			>
			</div>
			<!-- Input line -->
			<div class="flex items-center border-t border-[#00b0ff]/30 px-4 py-3 bg-[#0a0a0a]">
				<span class="text-[#00b0ff] mr-2 text-sm font-bold select-none">❯</span>
				<input
					id="cli-input"
					type="text"
					class="flex-1 bg-transparent text-sm text-white outline-none placeholder:text-white/40 caret-[#00b0ff]"
					placeholder={cliPlaceholder}
					autocomplete="off"
					spellcheck="false"
					aria-label={isEn
						? 'Terminal command input'
						: 'Entrada de comandos de la terminal'}
				/>
				<span class="text-xs text-white/40 uppercase tracking-widest hidden sm:block"
					>{cliTabHint}</span
				>
			</div>
		</div>
	</div>
</div>

<!-- ═══════════════════════════════════════════════════════
     KEYBOARD SHORTCUTS MODAL
═══════════════════════════════════════════════════════ -->
<div
	id="shortcuts-modal"
	role="dialog"
	aria-modal="true"
	aria-label={kbTitle}
	class="fixed inset-0 z-[200] bg-black/85 backdrop-blur-sm hidden items-center justify-center p-4"
>
	<div
		class="w-full max-w-lg bg-surface border-2 border-black dark:border-white shadow-[8px_8px_0px_var(--color-edge-strong)] font-mono"
	>
		<!-- Header -->
		<div
			class="flex items-center justify-between px-5 py-3 border-b-2 border-dashed border-edge-subtle"
		>
			<span
				class="text-primary-500 dark:text-primary-400 font-pixel-clean text-xs font-bold tracking-wider uppercase"
				>{kbTitle}</span
			>
			<button
				id="shortcuts-close"
				class="px-1.5 py-0.5 border border-black dark:border-white text-xs font-bold hover:bg-red-500 hover:text-white dark:hover:text-black transition-colors cursor-pointer"
				>X</button
			>
		</div>

		<!-- Grid -->
		<div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-6 text-xs">
			<!-- Vim navigation -->
			<div>
				<div
					class="text-content-muted uppercase tracking-widest text-xs pb-1 mb-3 border-b border-edge-subtle"
				>
					{kbNavHeading}
				</div>
				<div class="space-y-2">
					{
						kbVimRows.map(([key, label]) => (
							<div class="flex items-center gap-2.5">
								<kbd class="inline-block min-w-[28px] text-center px-2 py-0.5 border border-black dark:border-white bg-neutral-100 dark:bg-neutral-800 text-xs font-bold shadow-[1.5px_1.5px_0_var(--color-edge-strong)]">
									{key}
								</kbd>
								<span class="text-content-muted">{label}</span>
							</div>
						))
					}
				</div>
			</div>

			<!-- Sections -->
			<div>
				<div
					class="text-content-muted uppercase tracking-widest text-xs pb-1 mb-3 border-b border-edge-subtle"
				>
					{kbSectionsHeading}
				</div>
				<div class="space-y-2">
					{
						kbSectionRows.map(([key, label]) => (
							<div class="flex items-center gap-2.5">
								<kbd class="inline-block min-w-[28px] text-center px-2 py-0.5 border border-black dark:border-white bg-neutral-100 dark:bg-neutral-800 text-xs font-bold shadow-[1.5px_1.5px_0_var(--color-edge-strong)]">
									{key}
								</kbd>
								<span class="text-content-muted">{label}</span>
							</div>
						))
					}
				</div>
			</div>

			<!-- Terminal & actions -->
			<div>
				<div
					class="text-content-muted uppercase tracking-widest text-xs pb-1 mb-3 border-b border-edge-subtle"
				>
					{kbActionsHeading}
				</div>
				<div class="space-y-2">
					{
						kbActionRows.map(([key, label]) => (
							<div class="flex items-center gap-2.5">
								<kbd class="inline-block min-w-[28px] text-center px-2 py-0.5 border border-black dark:border-white bg-neutral-100 dark:bg-neutral-800 text-xs font-bold shadow-[1.5px_1.5px_0_var(--color-edge-strong)]">
									{key}
								</kbd>
								<span class="text-content-muted">{label}</span>
							</div>
						))
					}
				</div>
			</div>

			<!-- Secret hint -->
			<div class="opacity-60">
				<div
					class="text-content-muted uppercase tracking-widest text-xs pb-1 mb-3 border-b border-edge-subtle opacity-60"
				>
					{kbSecretHeading}
				</div>
				<div class="space-y-2">
					<div class="flex items-center gap-2.5">
						<kbd
							class="inline-block min-w-[28px] text-center px-2 py-0.5 border border-black/40 dark:border-white/30 bg-neutral-100/50 dark:bg-neutral-800/50 text-xs font-bold opacity-50"
							>??</kbd
						>
						<span class="text-content-muted/80 text-xs italic">{kbSecretHint}</span>
					</div>
					<div class="text-sm text-content-muted italic pl-1">
						{kbSecretMsg}
					</div>
				</div>
			</div>
		</div>

		<div
			class="px-5 py-2.5 border-t-2 border-dashed border-edge-subtle text-sm text-content-muted/80 text-center uppercase tracking-widest"
		>
			{kbFooter}
		</div>
	</div>
</div>

<!-- ═══════════════════════════════════════════════════════
     EASTER EGG — PROTOCOL 12
═══════════════════════════════════════════════════════ -->
<div
	id="easter-egg-overlay"
	role="dialog"
	aria-modal="true"
	aria-label="Developer secret mode"
	class="fixed inset-0 z-[300] bg-black/95 hidden items-center justify-center p-4"
>
	<!-- CRT scanlines -->
	<div
		class="absolute inset-0 pointer-events-none opacity-25"
		style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,176,255,0.05) 2px, rgba(0,176,255,0.05) 4px);"
	>
	</div>

	<div class="w-full max-w-md font-mono space-y-4 relative z-10">
		<!-- CLASSIFIED header -->
		<div class="border-2 border-red-500 bg-red-950/30 px-6 py-4 text-center">
			<div class="text-red-400 font-bold tracking-[0.4rem] text-xl animate-pulse">
				⚠ CLASSIFIED ⚠
			</div>
			<div class="text-error-500/80 text-xs mt-1.5 tracking-widest">
				{eggProtocol}
			</div>
			<div class="text-error-500/80 text-xs mt-0.5">
				{eggClearance}
			</div>
		</div>

		<!-- Loading sequence (filled by JS) -->
		<div
			id="egg-loading"
			class="bg-black/60 border border-[#00b0ff]/30 p-4 text-xs space-y-1 min-h-[9rem] overflow-hidden"
		>
		</div>

		<!-- Secrets revealed -->
		<div id="egg-stats" class="hidden border-2 border-[#00ff88] bg-[#00ff88]/5 p-4">
			<div class="text-[#00ff88] font-bold tracking-widest text-xs mb-3 uppercase">
				{eggStatsTitle}
			</div>
			<div class="space-y-2 text-xs">
				{
					eggRows.map(({ label, value, color }) => (
						<div class="flex justify-between gap-4">
							<span class="text-white/50 shrink-0">{label}</span>
							<span style={`color: ${color}`}>{value}</span>
						</div>
					))
				}
			</div>
			<div
				class="mt-4 pt-3 border-t border-[#00ff88]/20 text-xs text-[#00ff88]/40 text-center"
			>
				{eggFooterMsg}
			</div>
		</div>

		<!-- Buttons -->
		<div class="flex gap-3">
			<a
				id="egg-hire-btn"
				href={`mailto:${siteConfig.email}?subject=${encodeURIComponent(siteConfig.emailSubjectRecruiter)}`}
				class="flex-1 py-2.5 border-2 border-[#00ff88] bg-[#00ff88]/10 text-[#00ff88] text-xs uppercase tracking-widest font-bold hover:bg-[#00ff88]/20 transition-colors cursor-pointer text-center"
			>
				[ HIRE THIS DEV ]
			</a>
			<button
				id="egg-close"
				class="flex-1 py-2.5 border-2 border-white/20 text-white/40 text-xs uppercase tracking-widest hover:border-white/50 hover:text-white/60 transition-colors cursor-pointer"
			>
				{eggCloseBtn}
			</button>
		</div>
	</div>
</div>

<script>
	// ── Interfaces ──────────────────────────────────────────────────────
	interface GitHubStats {
		login: string;
		name: string;
		followers: number;
		following: number;
		public_repos: number;
		totalStars: number;
		totalForks: number;
		topLangs: string[];
		bio: string | null;
	}

	// ── i18n runtime data ────────────────────────────────────────────────
	const i18nEl = document.getElementById('cli-i18n') as HTMLElement;
	const lang = i18nEl?.dataset.lang ?? 'es';
	const isEn = lang === 'en';
	const sectionNames: string[] = JSON.parse(
		i18nEl?.dataset.sectionNames ??
			'["Hero","Experience","Research","Projects","About Me","Technologies"]'
	);
	const resumeUrl =
		i18nEl?.dataset.resumeUrl ?? 'https://github.com/sandovaldavid/resume/releases/latest';
	const GITHUB_USER = i18nEl?.dataset.githubUser ?? 'sandovaldavid';
	const CONTACT_EMAIL = i18nEl?.dataset.email ?? 'hello@sandovaldavid.com';
	const CONTACT_LINKEDIN = i18nEl?.dataset.linkedin ?? 'jdavidsandoval';
	const SITE_URL = i18nEl?.dataset.siteUrl ?? 'sandovaldavid.com';

	// ── Element refs ─────────────────────────────────────────────────────
	const cliOverlay = document.getElementById('cli-overlay')!;
	const cliOutput = document.getElementById('cli-output')!;
	const cliInput = document.getElementById('cli-input') as HTMLInputElement;
	const cliCloseDot = document.getElementById('cli-close-dot')!;

	const shortcutsModal = document.getElementById('shortcuts-modal')!;
	const shortcutsClose = document.getElementById('shortcuts-close')!;

	const easterEggOverlay = document.getElementById('easter-egg-overlay')!;
	const eggLoading = document.getElementById('egg-loading')!;
	const eggStats = document.getElementById('egg-stats')!;
	const eggClose = document.getElementById('egg-close')!;

	// ── State ────────────────────────────────────────────────────────────
	let cliHistory: string[] = [];
	let cliHistoryIndex = -1;
	let cliBooted = false;
	let githubCache: GitHubStats | null = null;
	let keyBuffer = '';
	let keyTimer: ReturnType<typeof setTimeout> | null = null;

	// ── Helpers ──────────────────────────────────────────────────────────
	function isInInput(): boolean {
		const el = document.activeElement as HTMLElement | null;
		if (!el) return false;
		return el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.isContentEditable;
	}

	function anyOverlayOpen(): boolean {
		return (
			!cliOverlay.classList.contains('hidden') ||
			!shortcutsModal.classList.contains('hidden') ||
			!easterEggOverlay.classList.contains('hidden')
		);
	}

	function escHtml(s: string): string {
		return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
	}

	// ── CLI print utilities ───────────────────────────────────────────────
	type LineType = 'output' | 'command' | 'error' | 'info' | 'muted' | 'warning';

	function printLine(html: string, type: LineType = 'output') {
		const colorMap: Record<LineType, string> = {
			output: 'text-[#00ff88]',
			command: 'text-white',
			error: 'text-red-400',
			info: 'text-[#00b0ff]',
			muted: 'text-white/40',
			warning: 'text-yellow-400',
		};
		const line = document.createElement('div');
		line.className = `${colorMap[type]} text-sm leading-relaxed`;
		line.innerHTML = html;
		cliOutput.appendChild(line);
		cliOutput.scrollTop = cliOutput.scrollHeight;
	}

	function printBlank() {
		const spacer = document.createElement('div');
		spacer.className = 'h-1.5';
		cliOutput.appendChild(spacer);
		cliOutput.scrollTop = cliOutput.scrollHeight;
	}

	function clearOutput() {
		cliOutput.innerHTML = '';
		cliBooted = false;
	}

	// ── CLI open / close ─────────────────────────────────────────────────
	function openCLI(prefill = '') {
		cliOverlay.classList.remove('hidden');
		cliOverlay.classList.add('flex');
		if (!cliBooted) bootCLI();
		cliInput.value = prefill;
		requestAnimationFrame(() => cliInput.focus());
	}

	function closeCLI() {
		cliOverlay.classList.add('hidden');
		cliOverlay.classList.remove('flex');
	}

	// ── Boot sequence ─────────────────────────────────────────────────────
	function bootCLI() {
		cliBooted = true;
		const lines: Array<[string, LineType]> = [
			['╔══════════════════════════════════════════╗', 'info'],
			['║  PORTFOLIO OS v2.0 — sandovaldavid.com  ║', 'info'],
			['║  Software Engineer · BiLSTM Researcher  ║', 'info'],
			['╚══════════════════════════════════════════╝', 'info'],
		];
		lines.forEach(([text, type], i) => {
			setTimeout(() => printLine(text, type), i * 40);
		});
		setTimeout(
			() => {
				printBlank();
				const helpTag = '<span class="text-yellow-400 font-bold">help</span>';
				const msg = isEn
					? `Ready. Type ${helpTag} for available commands.`
					: `Listo. Escribe ${helpTag} para ver los comandos disponibles.`;
				printLine(msg, 'muted');
				printBlank();
			},
			lines.length * 40 + 30
		);
	}

	// ── Section navigation ────────────────────────────────────────────────
	const SECTIONS = [
		{ num: 1, id: null as string | null, name: sectionNames[0] ?? 'Hero' },
		{ num: 2, id: 'experience', name: sectionNames[1] ?? 'Experience' },
		{ num: 3, id: 'research', name: sectionNames[2] ?? 'Research' },
		{ num: 4, id: 'projects', name: sectionNames[3] ?? 'Projects' },
		{ num: 5, id: 'about-me', name: sectionNames[4] ?? 'About Me' },
		{ num: 6, id: 'technologies', name: sectionNames[5] ?? 'Technologies' },
	];

	function navigateToSection(num: number) {
		const s = SECTIONS.find(x => x.num === num);
		if (!s) return;
		if (!s.id) {
			window.scrollTo({ top: 0, behavior: 'smooth' });
		} else {
			document.getElementById(s.id)?.scrollIntoView({ behavior: 'smooth' });
		}
		showNavPopup(`→ ${s.name}`);
	}

	function showNavPopup(text: string) {
		const el = document.createElement('div');
		el.className =
			'fixed top-[10%] left-1/2 -translate-x-1/2 bg-primary-500 text-white dark:text-black px-5 py-2 border-2 border-black dark:border-white font-mono font-bold text-xs uppercase tracking-widest z-[150] opacity-0 transition-opacity duration-200 pointer-events-none whitespace-nowrap';
		el.textContent = text;
		document.body.appendChild(el);
		requestAnimationFrame(() => {
			el.style.opacity = '1';
		});
		setTimeout(() => {
			el.style.opacity = '0';
			setTimeout(() => el.remove(), 250);
		}, 1100);
	}

	// ── GitHub Stats ──────────────────────────────────────────────────────
	async function fetchGitHubStats(): Promise<GitHubStats | null> {
		if (githubCache) return githubCache;
		// sessionStorage cache — persists across page navigations within same session
		try {
			const cached = sessionStorage.getItem('pf_gh_stats');
			if (cached) {
				githubCache = JSON.parse(cached) as GitHubStats;
				return githubCache;
			}
		} catch {
			/* ignore */
		}
		try {
			const [uRes, rRes] = await Promise.all([
				fetch(`https://api.github.com/users/${GITHUB_USER}`),
				fetch(
					`https://api.github.com/users/${GITHUB_USER}/repos?per_page=100&sort=updated`
				),
			]);
			if (!uRes.ok) throw new Error('rate limit');
			const user = await uRes.json();
			const repos: Array<{
				stargazers_count?: number;
				forks_count?: number;
				language?: string;
			}> = rRes.ok ? await rRes.json() : [];

			const totalStars = repos.reduce((n, r) => n + (r.stargazers_count ?? 0), 0);
			const totalForks = repos.reduce((n, r) => n + (r.forks_count ?? 0), 0);

			const langMap: Record<string, number> = {};
			repos.forEach(r => {
				if (r.language) langMap[r.language] = (langMap[r.language] ?? 0) + 1;
			});
			const topLangs = Object.entries(langMap)
				.sort((a, b) => b[1] - a[1])
				.slice(0, 3)
				.map(([l]) => l);

			githubCache = {
				login: user.login,
				name: user.name ?? 'David Sandoval',
				followers: user.followers,
				following: user.following,
				public_repos: user.public_repos,
				totalStars,
				totalForks,
				topLangs,
				bio: user.bio ?? null,
			};
			try {
				sessionStorage.setItem('pf_gh_stats', JSON.stringify(githubCache));
			} catch {
				/* ignore */
			}
			return githubCache;
		} catch {
			return null;
		}
	}

