---
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

interface Props {
	label: string;
	icon?: AstroComponentFactory; // Astro component for optional icon
	href?: string; // Optional link for the pill
	size?: 'sm' | 'md';
	variant?: 'card' | 'stack';
	class?: string;
}
const {
	label,
	icon: Icon,
	href,
	size = 'md',
	variant = 'card',
	class: additionalClasses = '',
} = Astro.props as Props;

// Base classes
const baseClasses = `inline-flex items-center rounded-none border-2 border-black dark:border-white transition-all duration-100 ${additionalClasses}`;

// Size-specific classes for Card variant
const cardPadding = 'px-3 py-1';
const cardText = size === 'sm' ? 'text-xs' : 'text-sm';
const cardIcon = 'mr-1.5 h-4 w-4';
const cardShadow = 'shadow-retro-sm';

// Size-specific classes for Stack variant
const stackPadding = size === 'sm' ? 'px-2.5 py-1.5 gap-1.5' : 'px-4 md:px-5 py-2.5 md:py-3 gap-2';
const stackText = size === 'sm' ? 'text-xs' : 'text-xs md:text-sm';
const stackIcon = size === 'sm' ? 'w-4 h-4 mr-0.5' : 'w-5 h-5 mr-1';
const stackBg =
	'bg-neutral-200/80 dark:bg-neutral-800/80 hover:bg-neutral-300 hover:dark:bg-neutral-700 text-content-strong font-bold uppercase tracking-wider backdrop-blur-sm';
const stackAnimation =
	'hover:border-primary-500 hover:-translate-x-[1.5px] hover:-translate-y-[1.5px] active:translate-x-[1px] active:translate-y-[1px] cursor-default';
const stackShadow =
	size === 'sm'
		? 'shadow-retro-sm hover:shadow-retro-md active:shadow-retro-xs'
		: 'shadow-retro-sm hover:shadow-retro-lg active:shadow-retro-xs';

// Final classes selection
const hasBg = additionalClasses.includes('bg-');
const hasText = additionalClasses.includes('text-');

const containerClasses =
	variant === 'stack'
		? `${baseClasses} ${stackPadding} ${stackText} ${stackBg} ${stackAnimation} ${stackShadow}`
		: `${baseClasses} ${cardPadding} ${cardText} ${cardShadow} ${hasBg ? '' : 'bg-neutral-100 dark:bg-neutral-800'} ${hasText ? '' : 'text-content-strong'} font-mono`;

const iconClasses = variant === 'stack' ? stackIcon : cardIcon;
---

{
	href ? (
		<a href={href} class={containerClasses} rel="noopener noreferrer" target="_blank">
			{Icon && <Icon class={iconClasses} />}
			<span>{label}</span>
		</a>
	) : (
		<span class={containerClasses}>
			{Icon && <Icon class={iconClasses} />}
			<span>{label}</span>
		</span>
	)
}
