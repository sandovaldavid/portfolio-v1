---
interface Props {
	variant?: keyof typeof variantClasses;
	size?: keyof typeof sizeClasses;
	class?: string;
}

const { variant = 'default', size = 'md', class: className } = Astro.props;

const variantClasses = {
	default: 'bg-surface-highlight text-content',
	primary: 'bg-badge-brand-bg text-badge-brand-text',
	secondary: 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300',
	success: 'bg-status-success-bg text-status-success-text',
	warning: 'bg-warning-500/15 text-warning-900 dark:bg-warning-500/20 dark:text-warning-500',
	danger: 'bg-error-500/10 text-error-900 dark:bg-error-500/20 dark:text-error-500',
	info: 'bg-cyan-100 text-cyan-800 dark:bg-cyan-900/30 dark:text-cyan-300',
	custom: '', // No default colors - use class prop for full customization
} as const;

const sizeClasses = {
	sm: 'px-2 py-0.5 text-xs',
	md: 'px-2.5 py-1 text-sm',
	lg: 'px-3 py-1.5 text-base',
} as const;
---

<span
	class:list={[
		'inline-flex items-center gap-1 font-bold uppercase tracking-wider rounded-none border-2 border-black dark:border-white shadow-[1.5px_1.5px_0px_0px_var(--color-edge-strong)]',
		'transition-colors duration-100',
		variant !== 'custom' && variantClasses[variant],
		sizeClasses[size],
		className,
	]}
>
	<slot />
</span>
