---
import Analytics from '@vercel/analytics/astro';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import { getPathByLocale, getRelativeLocaleUrl, pathHasLocale } from 'astro:i18n';
import '@app/styles/global.css';
import '@app/styles/print.css';
import BriefCaseIcon from '@assets/icons/Briefcase.astro';
import CodeIcon from '@assets/icons/Code.astro';
import ProfileCheckIcon from '@assets/icons/ProfileCheck.astro';
import BrainIcon from '@assets/icons/Brain.astro';
import { ContactSidebar } from '@widgets/contact-sidebar';
import { Footer } from '@widgets/footer';
import { Header } from '@widgets/header';
import { RecruiterHUD } from '@widgets/recruiter-hud';
import { TechStack } from '@widgets/tech-stack';
import { CLITerminal } from '@features/cli-terminal';
import { SplashScreen } from '@features/splash-screen';
import { SectionContainer, TitleSection } from '@shared/ui';
import {
	AVAILABLE_LANGUAGES,
	createScopedUiTranslator,
	getLanguageFromLocale,
	Language,
	type LocalizedPathMap,
} from '@shared/config/i18n';
import { siteConfig } from '@shared/config/site.config';

interface Props {
	title: string;
	description: string;
	img_preview: string;
	isHome?: boolean;
	article?: boolean;
	keywords?: string;
	localizedPaths?: LocalizedPathMap;
}

const {
	description,
	title,
	img_preview,
	isHome = false,
	article = false,
	keywords = 'Software Engineer, .NET 8, Angular 19, BiLSTM, Machine Learning, OSS, Portfolio, Peru, Astro',
	localizedPaths,
} = Astro.props;

const lang = getLanguageFromLocale(Astro.currentLocale);
const pathname = Astro.url.pathname;
const pathnameSegments = pathname.split('/').filter(Boolean);
const localePath = getPathByLocale(lang);
const routeSegments =
	pathHasLocale(pathname) && pathnameSegments[0] === localePath
		? pathnameSegments.slice(1)
		: pathnameSegments;
const routeWithoutLocale = routeSegments.join('/');
const routePath =
	routeWithoutLocale && pathname.endsWith('/') ? `${routeWithoutLocale}/` : routeWithoutLocale;
const ordinaryLocalizedPaths = Object.fromEntries(
	AVAILABLE_LANGUAGES.map(locale => [locale, getRelativeLocaleUrl(locale, routePath)])
) as LocalizedPathMap;
const resolvedLocalizedPaths = localizedPaths ?? ordinaryLocalizedPaths;
const enPath = resolvedLocalizedPaths[Language.ENGLISH];
const esPath = resolvedLocalizedPaths[Language.SPANISH];
const enUrl = enPath ? new URL(enPath, siteConfig.url).toString() : undefined;
const esUrl = esPath ? new URL(esPath, siteConfig.url).toString() : undefined;

const tAccessibility = createScopedUiTranslator(lang, 'accessibility');
const tBreadcrumbs = createScopedUiTranslator(lang, 'breadcrumbs');
const tExperience = createScopedUiTranslator(lang, 'sections.experience');
const tResearchSection = createScopedUiTranslator(lang, 'sections.research');
const tProjects = createScopedUiTranslator(lang, 'sections.projects');
const tAbout = createScopedUiTranslator(lang, 'sections.about');
const tTechStack = createScopedUiTranslator(lang, 'sections.techStack');

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).toString();
const ogImageUrl = new URL(img_preview, siteConfig.url).toString();
const ogLocale = lang === Language.ENGLISH ? 'en_US' : 'es_PE';
const ogType = article ? 'article' : 'website';

const breadcrumbLabels: Record<string, string> = {
	projects: tBreadcrumbs('projects'),
	skills: tBreadcrumbs('skills'),
	about: tBreadcrumbs('about'),
	research: tBreadcrumbs('research'),
	atena: 'Atena',
};
const breadcrumbItems: { name: string; url: string }[] = [];
if (routeSegments.length > 0) {
	breadcrumbItems.push({
		name: tBreadcrumbs('home'),
		url: getRelativeLocaleUrl(lang, ''),
	});
	routeSegments.forEach((segment, i) => {
		const segmentPath = routeSegments.slice(0, i + 1).join('/');
		breadcrumbItems.push({
			name: breadcrumbLabels[segment] || segment,
			url: getRelativeLocaleUrl(lang, segmentPath),
		});
	});
}
const breadcrumbSchema =
	breadcrumbItems.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'BreadcrumbList',
				itemListElement: breadcrumbItems.map((item, i) => ({
					'@type': 'ListItem',
					position: i + 1,
					name: item.name,
					item: new URL(item.url, siteConfig.url).toString(),
				})),
			}
		: null;

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: siteConfig.fullName,
	givenName: 'Juan David',
	familyName: 'Sandoval Salvador',
	alternateName: siteConfig.handle,
	url: siteConfig.url,
	image: `${siteConfig.url}/profile/perfil.webp`,
	sameAs: [siteConfig.social.github, siteConfig.social.linkedin],
	jobTitle: 'Software Engineer',
	worksFor: { '@type': 'Organization', name: siteConfig.currentCompany },
	address: { '@type': 'PostalAddress', addressLocality: 'Lima', addressCountry: 'PE' },
	email: siteConfig.email,
	knowsAbout: [
		'.NET 8',
		'C#',
		'Angular',
		'TypeScript',
		'BiLSTM',
		'Machine Learning',
		'Python',
		'Django',
		'Docker',
		'PostgreSQL',
	],
};
const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: siteConfig.defaultTitle,
	url: siteConfig.url,
	description: siteConfig.defaultDescription,
	inLanguage: [lang],
	author: { '@type': 'Person', name: siteConfig.fullName },
};
const articleSchema = article
	? {
			'@context': 'https://schema.org',
			'@type': 'ScholarlyArticle',
			name: title,
			description: description,
			url: canonicalUrl,
			author: {
				'@type': 'Person',
				name: siteConfig.fullName,
				url: siteConfig.url,
			},
		}
	: null;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content={siteConfig.fullName} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#0096ff" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="DevSandoval" />

		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={tAccessibility('portfolioPreviewAlt')} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={siteConfig.defaultTitle} />
		<meta property="og:locale" content={ogLocale} />

		<meta name="twitter:card" content={siteConfig.twitterCard} />
		<meta name="twitter:site" content={`@${siteConfig.handle}`} />
		<meta name="twitter:creator" content={`@${siteConfig.handle}`} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		{enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
		{esUrl && <link rel="alternate" hreflang="es" href={esUrl} />}
		{enUrl && <link rel="alternate" hreflang="x-default" href={enUrl} />}

		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${siteConfig.name} — Blog (EN)`}
			href="/rss.xml"
		/>
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${siteConfig.name} — Blog (ES)`}
			href="/es/rss.xml"
		/>

		<Font cssVariable="--font-pixel" />
		<Font cssVariable="--font-pixel-clean" preload />
		<Font cssVariable="--font-retro-tag" />
		<Font cssVariable="--font-gaming-mono" />
		<Font cssVariable="--font-mono" />

		<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		{
			breadcrumbSchema && (
				<script
					is:inline
					type="application/ld+json"
					set:html={JSON.stringify(breadcrumbSchema)}
				/>
			)
		}
		{
			articleSchema && (
				<script
					is:inline
					type="application/ld+json"
					set:html={JSON.stringify(articleSchema)}
				/>
			)
		}

		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			(function applyTheme() {
				const saved = localStorage.getItem('theme') || 'dark';
				const isDark =
					saved === 'dark' ||
					(saved === 'system' &&
						window.matchMedia('(prefers-color-scheme: dark)').matches);
				document.documentElement.classList.toggle('dark', isDark);
			})();
			document.addEventListener('astro:after-swap', () => {
				(function applyTheme() {
					const saved = localStorage.getItem('theme') || 'dark';
					const isDark =
						saved === 'dark' ||
						(saved === 'system' &&
							window.matchMedia('(prefers-color-scheme: dark)').matches);
					document.documentElement.classList.toggle('dark', isDark);
				})();
			});
		</script>
		<ClientRouter />
		<Analytics />
	</head>

	<body class="bg-background text-content flex flex-col min-h-screen">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary-500 focus:text-white dark:focus:text-black focus:font-bold focus:uppercase focus:tracking-wider focus:border-2 focus:border-black dark:focus:border-white focus:shadow-retro-lg focus:rounded-none focus:no-underline"
		>
			{tAccessibility('skipToContent')}
		</a>
		<div class="flex flex-col justify-center items-center w-full">
			<Header />
			<main id="main-content" class="w-full min-h-screen flex flex-col items-center">
				{
					isHome ? (
						<div class="pt-[4.5rem]">
							<div class="flex flex-col justify-around md:max-h-[calc(100dvh-4.5rem)]">
								<slot name="hero" />
							</div>
							<div class="flex flex-col">
								<SectionContainer
									id="experience"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<BriefCaseIcon class="size-12" />
										{tExperience('sectionTitle')}
									</TitleSection>
									<slot name="experience" />
								</SectionContainer>
								<SectionContainer
									id="research"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<BrainIcon class="size-12" />
										{tResearchSection('sectionTitle')}
									</TitleSection>
									<slot name="research" />
								</SectionContainer>

								<SectionContainer
									id="projects"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<CodeIcon class="size-12" />
										{tProjects('sectionTitle')}
									</TitleSection>
									<slot name="projects" />
								</SectionContainer>

								<SectionContainer
									id="about-me"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<ProfileCheckIcon class="size-12" />
										{tAbout('sectionTitle')}
									</TitleSection>
									<slot name="about-me" />
								</SectionContainer>

								<SectionContainer
									id="technologies"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<CodeIcon class="size-12" />
										{tTechStack('sectionTitle')}
									</TitleSection>
									<TechStack />
								</SectionContainer>
							</div>
						</div>
					) : (
						<div class="pt-28 pb-16 w-full flex flex-col items-center">
							<slot />
						</div>
					)
				}
			</main>
			<Footer />
			<RecruiterHUD localizedPaths={resolvedLocalizedPaths} />
			<CLITerminal />
			<ContactSidebar />
			{isHome && <SplashScreen />}
		</div>
	</body>
</html>
