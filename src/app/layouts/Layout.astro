---
import Analytics from '@vercel/analytics/astro';
import '@app/styles/global.css';
import '@fontsource-variable/onest';
import BriefCaseIcon from '@assets/icons/Briefcase.astro';
import CodeIcon from '@assets/icons/Code.astro';
import ProfileCheckIcon from '@assets/icons/ProfileCheck.astro';
import BrainIcon from '@assets/icons/Brain.astro';
import { Header } from '@widgets/header';
import { Footer } from '@widgets/footer';
import { TechStack } from '@widgets/tech-stack';
import { RecruiterHUD } from '@widgets/recruiter-hud';
import { ContactSidebar } from '@widgets/contact-sidebar';
import { CLITerminal } from '@features/cli-terminal';
import { SplashScreen } from '@features/splash-screen';
import { SectionContainer, TitleSection } from '@/shared/ui';
import { getLangFromUrl, useTranslations } from '@shared/lib/i18n';
import { Language } from '@shared/config/i18n';
import { siteConfig } from '@shared/config/site.config';

interface Props {
	title: string;
	description: string;
	img_preview: string;
	isHome?: boolean;
	article?: boolean;
	keywords?: string;
}
const {
	description,
	title,
	img_preview,
	isHome = true,
	article = false,
	keywords = 'Software Engineer, .NET 8, Angular 19, BiLSTM, Machine Learning, OSS, Portfolio, Peru, Astro',
} = Astro.props;
const langCode = getLangFromUrl(new URL(Astro.request.url));
const lang = langCode === 'en' ? Language.ENGLISH : Language.SPANISH;
const t = useTranslations(lang);

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).toString();
const ogImageUrl = new URL(img_preview, siteConfig.url).toString();
const ogLocale = langCode === 'en' ? 'en_US' : 'es_PE';
const ogType = article ? 'article' : 'website';

// JSON-LD structured data
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: siteConfig.fullName,
	givenName: 'Juan David',
	familyName: 'Sandoval Salvador',
	alternateName: siteConfig.handle,
	url: siteConfig.url,
	image: `${siteConfig.url}/profile/perfil.webp`,
	sameAs: [siteConfig.social.github, siteConfig.social.linkedin],
	jobTitle: 'Software Engineer',
	worksFor: { '@type': 'Organization', name: siteConfig.currentCompany },
	address: { '@type': 'PostalAddress', addressLocality: 'Piura', addressCountry: 'PE' },
	email: siteConfig.email,
	knowsAbout: [
		'.NET 8',
		'C#',
		'Angular',
		'TypeScript',
		'BiLSTM',
		'Machine Learning',
		'Python',
		'Django',
		'Docker',
		'PostgreSQL',
	],
};
const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: siteConfig.defaultTitle,
	url: siteConfig.url,
	description: siteConfig.defaultDescription,
	inLanguage: [langCode],
	author: { '@type': 'Person', name: siteConfig.fullName },
};
---

<!doctype html>
<html lang={langCode}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<!-- Primary meta -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content={siteConfig.fullName} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Favicon & PWA -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#0096ff" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="DevSandoval" />

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={`${siteConfig.name} — Portfolio preview`} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={siteConfig.defaultTitle} />
		<meta property="og:locale" content={ogLocale} />

		<!-- Twitter / X Card -->
		<meta name="twitter:card" content={siteConfig.twitterCard} />
		<meta name="twitter:site" content={`@${siteConfig.handle}`} />
		<meta name="twitter:creator" content={`@${siteConfig.handle}`} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Fonts: preload to avoid render-blocking -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&family=Silkscreen:wght@400;700&family=Share+Tech+Mono&family=JetBrains+Mono:wght@400;500;700&display=swap"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				rel="stylesheet"
				href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&family=Silkscreen:wght@400;700&family=Share+Tech+Mono&family=JetBrains+Mono:wght@400;500;700&display=swap"
			/>
		</noscript>

		<!-- Structured Data (JSON-LD) -->
		<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			// Force dark mode for high-contrast unified retro palette
			document.documentElement.classList.add('dark');
		</script>
		<Analytics />
	</head>

	<body class="bg-background text-text-body flex flex-col min-h-screen">
		<div class="flex flex-col justify-center items-center w-full">
			<Header />
			<main class="w-full min-h-screen flex flex-col items-center">
				{
					isHome ? (
						<div class="pt-[4.5rem]">
							<div class="flex flex-col justify-around md:max-h-[calc(100dvh-4.5rem)]">
								<slot name="hero" />
							</div>
							<div class="flex flex-col">
								<SectionContainer
									id="experience"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<BriefCaseIcon class="size-12" />
										{t('title.experience')}
									</TitleSection>
									<slot name="experience" />
								</SectionContainer>
								<SectionContainer
									id="research"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<BrainIcon class="size-12" />
										{t('title.research')}
									</TitleSection>
									<slot name="research" />
								</SectionContainer>

								<SectionContainer
									id="projects"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<CodeIcon class="size-12" />
										{t('title.projects')}
									</TitleSection>
									<slot name="projects" />
								</SectionContainer>

								<SectionContainer
									id="about-me"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<ProfileCheckIcon class="size-12" />
										{t('title.about-me')}
									</TitleSection>
									<slot name="about-me" />
								</SectionContainer>

								<SectionContainer
									id="technologies"
									class="min-h-[calc(100dvh-4.5rem)] py-12 md:py-16 gap-y-6"
								>
									<TitleSection className="mb-0">
										<CodeIcon class="size-12" />
										{t('title.technologies')}
									</TitleSection>
									<TechStack />
								</SectionContainer>
							</div>
						</div>
					) : (
						<div class="pt-28 pb-16 w-full flex flex-col items-center">
							<slot />
						</div>
					)
				}
			</main>
			<Footer />
			<RecruiterHUD />
			<CLITerminal />
			<ContactSidebar />
			{isHome && <SplashScreen />}
		</div>
	</body>
</html>
